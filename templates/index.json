        "custom_html": "<!-- DTechists: Shopify Fresh Product Carousel -->\n<div class=\"dtn-new-products\" data-product-limit=\"12\">\n\n  <div class=\"dtn-new-products__container\">\n\n    <div class=\"dtn-new-products__header\">\n\n      <div class=\"dtn-new-products__heading\">\n        <span class=\"dtn-new-products__eyebrow\">\n          Freshly Curated\n        </span>\n\n        <h2>The Fresh Drop</h2>\n\n        <p>\n          Meet the newest additions to our collection—fresh designs,\n          distinctive details, and beautiful pieces selected for your space.\n        </p>\n      </div>\n\n      <div class=\"dtn-new-products__controls\">\n        <button type=\"button\" class=\"dtn-new-products__arrow dtn-new-products__previous\" aria-label=\"View previous products\">\n          <svg viewbox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M15 18 9 12l6-6\"></path>\n          </svg>\n        </button>\n\n        <button type=\"button\" class=\"dtn-new-products__arrow dtn-new-products__next\" aria-label=\"View next products\">\n          <svg viewbox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"m9 18 6-6-6-6\"></path>\n          </svg>\n        </button>\n      </div>\n\n    </div>\n\n    <div class=\"dtn-new-products__loading\">\n      <span class=\"dtn-new-products__loader\"></span>\n      <span>Loading our newest arrivals...</span>\n    </div>\n\n    <div class=\"dtn-new-products__viewport\" aria-label=\"Newly added products\" hidden=\"\">\n      <div class=\"dtn-new-products__track\"></div>\n    </div>\n\n    <div class=\"dtn-new-products__empty\" hidden=\"\">\n      New products will appear here as soon as they are available.\n    </div>\n\n  </div>\n\n  <div class=\"dtn-new-products__toast\" role=\"status\" aria-live=\"polite\">\n    <span class=\"dtn-new-products__toast-message\">\n      Product added to your cart.\n    </span>\n\n    <a href=\"/cart\">View cart</a>\n  </div>\n\n</div>\n\n<style>\n  .dtn-new-products{\n    --dtn-primary:#de7e64;\n    --dtn-primary-dark:#b95843;\n    --dtn-primary-light:rgba(222,126,100,.12);\n    --dtn-heading:#281a16;\n    --dtn-text:rgba(40,26,22,.72);\n    --dtn-border:rgba(40,26,22,.10);\n    --dtn-card:#ffffff;\n    --dtn-gap:22px;\n\n    position:relative;\n    width:100%;\n    margin:30px 0;\n    padding:54px 0;\n    overflow:hidden;\n    background:\n      radial-gradient(\n        circle at 0% 0%,\n        rgba(222,126,100,.19),\n        transparent 32%\n      ),\n      radial-gradient(\n        circle at 100% 100%,\n        rgba(222,126,100,.10),\n        transparent 30%\n      ),\n      linear-gradient(\n        135deg,\n        #fff9f6 0%,\n        #ffffff 50%,\n        #fff8f4 100%\n      );\n    color:var(--dtn-heading);\n  }\n\n  .dtn-new-products *,\n  .dtn-new-products *::before,\n  .dtn-new-products *::after{\n    box-sizing:border-box;\n  }\n\n  .dtn-new-products__container{\n    width:min(1440px,calc(100% - 48px));\n    margin:0 auto;\n  }\n\n  .dtn-new-products__header{\n    display:flex;\n    align-items:flex-end;\n    justify-content:space-between;\n    gap:30px;\n    margin-bottom:30px;\n  }\n\n  .dtn-new-products__heading{\n    max-width:720px;\n  }\n\n  .dtn-new-products__eyebrow{\n    display:inline-flex;\n    align-items:center;\n    gap:9px;\n    margin-bottom:10px;\n    color:var(--dtn-primary-dark);\n    font-size:11px;\n    font-weight:750;\n    line-height:1.4;\n    letter-spacing:1.8px;\n    text-transform:uppercase;\n  }\n\n  .dtn-new-products__eyebrow::before{\n    content:\"\";\n    width:30px;\n    height:1px;\n    background:var(--dtn-primary);\n  }\n\n  .dtn-new-products__heading h2{\n    margin:0;\n    color:var(--dtn-heading);\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:clamp(30px,4vw,48px);\n    font-weight:500;\n    line-height:1.08;\n    letter-spacing:-.7px;\n  }\n\n  .dtn-new-products__heading p{\n    max-width:650px;\n    margin:12px 0 0;\n    color:var(--dtn-text);\n    font-size:15px;\n    line-height:1.7;\n  }\n\n  .dtn-new-products__controls{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    flex:0 0 auto;\n  }\n\n  .dtn-new-products__arrow{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    width:46px;\n    height:46px;\n    padding:0;\n    border:1px solid var(--dtn-border);\n    border-radius:50%;\n    background:#ffffff;\n    color:var(--dtn-heading);\n    box-shadow:0 8px 24px rgba(40,26,22,.08);\n    cursor:pointer;\n    transition:\n      transform .25s ease,\n      background .25s ease,\n      color .25s ease,\n      border-color .25s ease;\n  }\n\n  .dtn-new-products__arrow:hover{\n    transform:translateY(-2px);\n    border-color:var(--dtn-primary);\n    background:var(--dtn-primary);\n    color:#ffffff;\n  }\n\n  .dtn-new-products__arrow:focus-visible{\n    outline:2px solid var(--dtn-primary);\n    outline-offset:3px;\n  }\n\n  .dtn-new-products__arrow svg{\n    width:18px;\n    height:18px;\n    fill:none;\n    stroke:currentColor;\n    stroke-width:1.8;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n  }\n\n  .dtn-new-products__viewport{\n    width:100%;\n    overflow:hidden;\n    touch-action:pan-y;\n  }\n\n  .dtn-new-products__track{\n    display:flex;\n    align-items:stretch;\n    gap:var(--dtn-gap);\n    width:max-content;\n    will-change:transform;\n    transition:transform .55s cubic-bezier(.22,.61,.36,1);\n  }\n\n  .dtn-new-products__card{\n    position:relative;\n    flex:0 0 auto;\n    min-width:0;\n    overflow:hidden;\n    border:1px solid var(--dtn-border);\n    border-radius:20px;\n    background:var(--dtn-card);\n    box-shadow:0 13px 34px rgba(40,26,22,.07);\n    transition:\n      transform .3s ease,\n      box-shadow .3s ease,\n      border-color .3s ease;\n  }\n\n  .dtn-new-products__card:hover{\n    transform:translateY(-5px);\n    border-color:rgba(222,126,100,.38);\n    box-shadow:0 20px 46px rgba(40,26,22,.12);\n  }\n\n  .dtn-new-products__image-link{\n    position:relative;\n    display:block;\n    aspect-ratio:1 / 1.08;\n    overflow:hidden;\n    background:#f5f0ed;\n  }\n\n  .dtn-new-products__image{\n    display:block;\n    width:100%;\n    height:100%;\n    object-fit:cover;\n    transition:transform .65s cubic-bezier(.22,.61,.36,1);\n  }\n\n  .dtn-new-products__card:hover .dtn-new-products__image{\n    transform:scale(1.055);\n  }\n\n  .dtn-new-products__image-placeholder{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    width:100%;\n    height:100%;\n    padding:35px;\n    background:\n      linear-gradient(\n        135deg,\n        rgba(222,126,100,.18),\n        rgba(255,255,255,.9)\n      );\n    color:var(--dtn-primary-dark);\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:18px;\n    text-align:center;\n  }\n\n  .dtn-new-products__badge{\n    position:absolute;\n    top:14px;\n    left:14px;\n    z-index:2;\n    display:inline-flex;\n    align-items:center;\n    gap:7px;\n    min-height:29px;\n    padding:7px 11px;\n    border:1px solid rgba(255,255,255,.62);\n    border-radius:999px;\n    background:rgba(40,26,22,.89);\n    color:#ffffff;\n    box-shadow:0 8px 18px rgba(0,0,0,.16);\n    backdrop-filter:blur(8px);\n    -webkit-backdrop-filter:blur(8px);\n    font-size:10px;\n    font-weight:750;\n    line-height:1;\n    letter-spacing:1.15px;\n    text-transform:uppercase;\n  }\n\n  .dtn-new-products__badge::before{\n    content:\"\";\n    width:6px;\n    height:6px;\n    flex:0 0 6px;\n    border-radius:50%;\n    background:#f4aa97;\n    box-shadow:0 0 0 4px rgba(244,170,151,.18);\n  }\n\n  .dtn-new-products__content{\n    display:flex;\n    flex-direction:column;\n    min-height:190px;\n    padding:18px;\n  }\n\n  .dtn-new-products__vendor{\n    margin:0 0 6px;\n    overflow:hidden;\n    color:var(--dtn-primary-dark);\n    font-size:10px;\n    font-weight:750;\n    line-height:1.4;\n    letter-spacing:1.2px;\n    text-overflow:ellipsis;\n    text-transform:uppercase;\n    white-space:nowrap;\n  }\n\n  .dtn-new-products__product-title{\n    margin:0;\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:18px;\n    font-weight:500;\n    line-height:1.38;\n  }\n\n  .dtn-new-products__product-title a{\n    display:-webkit-box;\n    overflow:hidden;\n    color:var(--dtn-heading);\n    text-decoration:none;\n    -webkit-box-orient:vertical;\n    -webkit-line-clamp:2;\n  }\n\n  .dtn-new-products__product-title a:hover{\n    color:var(--dtn-primary-dark);\n  }\n\n  .dtn-new-products__bottom{\n    display:flex;\n    align-items:flex-end;\n    justify-content:space-between;\n    gap:12px;\n    margin-top:auto;\n    padding-top:18px;\n  }\n\n  .dtn-new-products__prices{\n    display:flex;\n    flex-wrap:wrap;\n    align-items:center;\n    gap:7px;\n    min-width:0;\n  }\n\n  .dtn-new-products__price{\n    color:var(--dtn-heading);\n    font-size:16px;\n    font-weight:750;\n    line-height:1.3;\n  }\n\n  .dtn-new-products__compare-price{\n    color:rgba(40,26,22,.45);\n    font-size:12px;\n    line-height:1.3;\n    text-decoration:line-through;\n  }\n\n  .dtn-new-products__add{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    gap:7px;\n    min-height:40px;\n    padding:10px 14px;\n    border:1px solid var(--dtn-primary);\n    border-radius:11px;\n    background:var(--dtn-primary);\n    color:#ffffff;\n    font-family:inherit;\n    font-size:12px;\n    font-weight:750;\n    line-height:1;\n    white-space:nowrap;\n    cursor:pointer;\n    transition:\n      transform .25s ease,\n      background .25s ease,\n      border-color .25s ease,\n      opacity .25s ease;\n  }\n\n  .dtn-new-products__add:hover{\n    transform:translateY(-2px);\n    border-color:var(--dtn-primary-dark);\n    background:var(--dtn-primary-dark);\n  }\n\n  .dtn-new-products__add:focus-visible{\n    outline:2px solid var(--dtn-primary);\n    outline-offset:3px;\n  }\n\n  .dtn-new-products__add svg{\n    width:15px;\n    height:15px;\n    flex:0 0 15px;\n    fill:none;\n    stroke:currentColor;\n    stroke-width:1.8;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n  }\n\n  .dtn-new-products__add.is-loading{\n    pointer-events:none;\n    opacity:.62;\n  }\n\n  .dtn-new-products__add.is-added{\n    border-color:#397253;\n    background:#397253;\n  }\n\n  .dtn-new-products__add:disabled{\n    transform:none;\n    border-color:#c9c0bc;\n    background:#c9c0bc;\n    cursor:not-allowed;\n    opacity:.85;\n  }\n\n  .dtn-new-products__loading{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:12px;\n    min-height:220px;\n    color:var(--dtn-text);\n    font-size:14px;\n  }\n\n  .dtn-new-products__loader{\n    width:25px;\n    height:25px;\n    border:3px solid rgba(222,126,100,.22);\n    border-top-color:var(--dtn-primary);\n    border-radius:50%;\n    animation:dtnNewProductsSpin .8s linear infinite;\n  }\n\n  @keyframes dtnNewProductsSpin{\n    to{\n      transform:rotate(360deg);\n    }\n  }\n\n  .dtn-new-products__empty{\n    padding:42px 25px;\n    border:1px solid var(--dtn-border);\n    border-radius:18px;\n    background:#ffffff;\n    color:var(--dtn-text);\n    text-align:center;\n  }\n\n  .dtn-new-products__toast{\n    position:fixed;\n    right:22px;\n    bottom:22px;\n    z-index:999999;\n    display:flex;\n    align-items:center;\n    gap:16px;\n    max-width:min(410px,calc(100vw - 30px));\n    padding:15px 17px;\n    border:1px solid rgba(255,255,255,.18);\n    border-radius:14px;\n    background:rgba(40,26,22,.96);\n    color:#ffffff;\n    box-shadow:0 18px 46px rgba(0,0,0,.22);\n    opacity:0;\n    visibility:hidden;\n    transform:translateY(15px);\n    transition:\n      opacity .3s ease,\n      visibility .3s ease,\n      transform .3s ease;\n  }\n\n  .dtn-new-products__toast.is-visible{\n    opacity:1;\n    visibility:visible;\n    transform:translateY(0);\n  }\n\n  .dtn-new-products__toast-message{\n    font-size:13px;\n    font-weight:650;\n    line-height:1.45;\n  }\n\n  .dtn-new-products__toast a{\n    color:#ffd7cd;\n    font-size:12px;\n    font-weight:750;\n    white-space:nowrap;\n    text-decoration:underline;\n    text-underline-offset:3px;\n  }\n\n  @media (max-width:820px){\n    .dtn-new-products{\n      padding:44px 0;\n    }\n\n    .dtn-new-products__header{\n      align-items:center;\n    }\n  }\n\n  @media (max-width:580px){\n    .dtn-new-products{\n      --dtn-gap:14px;\n\n      margin:20px 0;\n      padding:36px 0;\n    }\n\n    .dtn-new-products__container{\n      width:calc(100% - 28px);\n    }\n\n    .dtn-new-products__header{\n      align-items:flex-end;\n      gap:12px;\n      margin-bottom:22px;\n    }\n\n    .dtn-new-products__eyebrow{\n      margin-bottom:7px;\n      font-size:10px;\n      letter-spacing:1.4px;\n    }\n\n    .dtn-new-products__heading h2{\n      font-size:31px;\n    }\n\n    .dtn-new-products__heading p{\n      margin-top:8px;\n      font-size:13px;\n      line-height:1.6;\n    }\n\n    .dtn-new-products__controls{\n      gap:7px;\n    }\n\n    .dtn-new-products__arrow{\n      width:38px;\n      height:38px;\n    }\n\n    .dtn-new-products__content{\n      min-height:178px;\n      padding:15px;\n    }\n\n    .dtn-new-products__product-title{\n      font-size:17px;\n    }\n\n    .dtn-new-products__bottom{\n      gap:9px;\n    }\n\n    .dtn-new-products__add{\n      min-height:38px;\n      padding:9px 11px;\n      font-size:11px;\n    }\n\n    .dtn-new-products__toast{\n      right:15px;\n      bottom:15px;\n    }\n  }\n\n  @media (prefers-reduced-motion:reduce){\n    .dtn-new-products__track,\n    .dtn-new-products__card,\n    .dtn-new-products__image,\n    .dtn-new-products__arrow,\n    .dtn-new-products__add{\n      transition-duration:.01ms !important;\n    }\n\n    .dtn-new-products__loader{\n      animation:none;\n    }\n  }\n</style>\n\n<script>\n(function () {\n  \"use strict\";\n\n  function initialiseNewProductCarousel(root) {\n    if (!root || root.dataset.initialised === \"true\") {\n      return;\n    }\n\n    root.dataset.initialised = \"true\";\n\n    const track = root.querySelector(\".dtn-new-products__track\");\n    const viewport = root.querySelector(\".dtn-new-products__viewport\");\n    const loading = root.querySelector(\".dtn-new-products__loading\");\n    const emptyMessage = root.querySelector(\".dtn-new-products__empty\");\n    const previousButton = root.querySelector(\n      \".dtn-new-products__previous\"\n    );\n    const nextButton = root.querySelector(\n      \".dtn-new-products__next\"\n    );\n    const toast = root.querySelector(\".dtn-new-products__toast\");\n    const toastMessage = root.querySelector(\n      \".dtn-new-products__toast-message\"\n    );\n    const toastCartLink = root.querySelector(\n      \".dtn-new-products__toast a\"\n    );\n\n    const maximumProducts = Math.min(\n      Number(root.dataset.productLimit || 12),\n      12\n    );\n\n    const shopRoot =\n      window.Shopify &&\n      window.Shopify.routes &&\n      window.Shopify.routes.root\n        ? window.Shopify.routes.root\n        : \"/\";\n\n    const activeCurrency =\n      window.Shopify &&\n      window.Shopify.currency &&\n      window.Shopify.currency.active\n        ? window.Shopify.currency.active\n        : \"INR\";\n\n    const storeLanguage =\n      document.documentElement.lang || \"en-IN\";\n\n    const autoplayDelay = 3500;\n    const transitionDuration = 550;\n\n    let products = [];\n    let productCount = 0;\n    let currentIndex = 0;\n    let cardWidth = 0;\n    let cardGap = 22;\n    let autoplayTimer = null;\n    let resetTimer = null;\n    let toastTimer = null;\n    let touchStartX = 0;\n    let touchEndX = 0;\n    let carouselIsVisible = true;\n\n    function createStoreUrl(path) {\n      const cleanPath = String(path).replace(/^\\/+/, \"\");\n      return shopRoot + cleanPath;\n    }\n\n    function escapeHtml(value) {\n      return String(value || \"\")\n        .replace(/&/g, \"&amp;\")\n        .replace(/</g, \"&lt;\")\n        .replace(/>/g, \"&gt;\")\n        .replace(/\"/g, \"&quot;\")\n        .replace(/'/g, \"&#039;\");\n    }\n\n    function formatMoney(value) {\n      const amount = Number(value || 0);\n\n      try {\n        return new Intl.NumberFormat(storeLanguage, {\n          style: \"currency\",\n          currency: activeCurrency,\n          maximumFractionDigits:\n            amount % 1 === 0 ? 0 : 2\n        }).format(amount);\n      } catch (error) {\n        return activeCurrency + \" \" + amount.toFixed(2);\n      }\n    }\n\n    function getImageSource(product, variant) {\n      let image = \"\";\n\n      if (\n        variant &&\n        variant.featured_image &&\n        variant.featured_image.src\n      ) {\n        image = variant.featured_image.src;\n      } else if (\n        product.featured_image &&\n        typeof product.featured_image === \"string\"\n      ) {\n        image = product.featured_image;\n      } else if (\n        product.featured_image &&\n        product.featured_image.src\n      ) {\n        image = product.featured_image.src;\n      } else if (\n        product.images &&\n        product.images.length\n      ) {\n        image =\n          typeof product.images[0] === \"string\"\n            ? product.images[0]\n            : product.images[0].src;\n      }\n\n      return image || \"\";\n    }\n\n    function optimiseImageUrl(imageUrl) {\n      if (!imageUrl) {\n        return \"\";\n      }\n\n      if (imageUrl.indexOf(\"width=\") !== -1) {\n        return imageUrl;\n      }\n\n      return imageUrl +\n        (imageUrl.indexOf(\"?\") === -1 ? \"?\" : \"&\") +\n        \"width=750\";\n    }\n\n    function getAvailableVariant(product) {\n      if (!product.variants || !product.variants.length) {\n        return null;\n      }\n\n      return (\n        product.variants.find(function (variant) {\n          return variant.available === true;\n        }) ||\n        product.variants[0]\n      );\n    }\n\n    function createProductCard(product, isDuplicate) {\n      const variant = getAvailableVariant(product);\n      const productUrl =\n        createStoreUrl(\"products/\" + encodeURIComponent(product.handle));\n\n      const productTitle = escapeHtml(product.title);\n      const vendor = escapeHtml(product.vendor || \"\");\n      const imageSource = optimiseImageUrl(\n        getImageSource(product, variant)\n      );\n\n      const available =\n        variant && variant.available !== false;\n\n      const price = variant\n        ? formatMoney(variant.price)\n        : \"\";\n\n      const comparePrice =\n        variant &&\n        Number(variant.compare_at_price) >\n          Number(variant.price)\n          ? formatMoney(variant.compare_at_price)\n          : \"\";\n\n      const duplicateAttributes = isDuplicate\n        ? 'aria-hidden=\"true\"'\n        : \"\";\n\n      const duplicateTabIndex = isDuplicate\n        ? 'tabindex=\"-1\"'\n        : \"\";\n\n      let imageMarkup = \"\";\n\n      if (imageSource) {\n        imageMarkup =\n          '<img ' +\n            'class=\"dtn-new-products__image\" ' +\n            'src=\"' + escapeHtml(imageSource) + '\" ' +\n            'alt=\"' + productTitle + '\" ' +\n            'loading=\"lazy\" ' +\n            'width=\"750\" ' +\n            'height=\"810\"' +\n          \">\";\n      } else {\n        imageMarkup =\n          '<div class=\"dtn-new-products__image-placeholder\">' +\n            productTitle +\n          \"</div>\";\n      }\n\n      let comparePriceMarkup = \"\";\n\n      if (comparePrice) {\n        comparePriceMarkup =\n          '<span class=\"dtn-new-products__compare-price\">' +\n            comparePrice +\n          \"</span>\";\n      }\n\n      let addButtonMarkup = \"\";\n\n      if (variant && available) {\n        addButtonMarkup =\n          '<button ' +\n            'type=\"button\" ' +\n            'class=\"dtn-new-products__add\" ' +\n            'data-variant-id=\"' + escapeHtml(variant.id) + '\" ' +\n            'data-product-title=\"' + productTitle + '\" ' +\n            duplicateTabIndex +\n          \">\" +\n            '<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">' +\n              '<path d=\"M6 7h12l-1 13H7L6 7Z\"></path>' +\n              '<path d=\"M9 9V6a3 3 0 0 1 6 0v3\"></path>' +\n            \"</svg>\" +\n            \"<span>Add</span>\" +\n          \"</button>\";\n      } else {\n        addButtonMarkup =\n          '<button ' +\n            'type=\"button\" ' +\n            'class=\"dtn-new-products__add\" ' +\n            \"disabled \" +\n            duplicateTabIndex +\n          \">\" +\n            \"<span>Sold out</span>\" +\n          \"</button>\";\n      }\n\n      return (\n        '<article ' +\n          'class=\"dtn-new-products__card\" ' +\n          duplicateAttributes +\n        \">\" +\n\n          '<a ' +\n            'href=\"' + productUrl + '\" ' +\n            'class=\"dtn-new-products__image-link\" ' +\n            duplicateTabIndex +\n          \">\" +\n\n            '<span class=\"dtn-new-products__badge\">' +\n              \"Fresh Find\" +\n            \"</span>\" +\n\n            imageMarkup +\n\n          \"</a>\" +\n\n          '<div class=\"dtn-new-products__content\">' +\n\n            (\n              vendor\n                ? '<div class=\"dtn-new-products__vendor\">' +\n                    vendor +\n                  \"</div>\"\n                : \"\"\n            ) +\n\n            '<h3 class=\"dtn-new-products__product-title\">' +\n              '<a href=\"' + productUrl + '\" ' + duplicateTabIndex + \">\" +\n                productTitle +\n              \"</a>\" +\n            \"</h3>\" +\n\n            '<div class=\"dtn-new-products__bottom\">' +\n\n              '<div class=\"dtn-new-products__prices\">' +\n                '<span class=\"dtn-new-products__price\">' +\n                  price +\n                \"</span>\" +\n                comparePriceMarkup +\n              \"</div>\" +\n\n              addButtonMarkup +\n\n            \"</div>\" +\n\n          \"</div>\" +\n\n        \"</article>\"\n      );\n    }\n\n    async function fetchProducts() {\n      const productUrls = [\n        createStoreUrl(\"products.json?limit=50\"),\n        createStoreUrl(\"collections/all/products.json?limit=50\")\n      ];\n\n      let lastError = null;\n\n      for (const productUrl of productUrls) {\n        try {\n          const response = await fetch(productUrl, {\n            method: \"GET\",\n            headers: {\n              Accept: \"application/json\",\n              \"X-Requested-With\": \"XMLHttpRequest\"\n            }\n          });\n\n          if (!response.ok) {\n            throw new Error(\n              \"Product request failed with status \" +\n              response.status\n            );\n          }\n\n          const responseData = await response.json();\n\n          if (\n            responseData &&\n            Array.isArray(responseData.products)\n          ) {\n            return responseData.products;\n          }\n        } catch (error) {\n          lastError = error;\n        }\n      }\n\n      throw lastError || new Error(\"Products could not be loaded.\");\n    }\n\n    function sortNewestProducts(productList) {\n      return productList\n        .slice()\n        .sort(function (firstProduct, secondProduct) {\n          const firstDate = new Date(\n            firstProduct.published_at ||\n            firstProduct.created_at ||\n            0\n          ).getTime();\n\n          const secondDate = new Date(\n            secondProduct.published_at ||\n            secondProduct.created_at ||\n            0\n          ).getTime();\n\n          return secondDate - firstDate;\n        });\n    }\n\n    function renderProducts() {\n      const originalCards = products\n        .map(function (product) {\n          return createProductCard(product, false);\n        })\n        .join(\"\");\n\n      const duplicateCards =\n        productCount > 1\n          ? products\n              .map(function (product) {\n                return createProductCard(product, true);\n              })\n              .join(\"\")\n          : \"\";\n\n      track.innerHTML = originalCards + duplicateCards;\n\n      loading.hidden = true;\n      viewport.hidden = false;\n\n      if (productCount <= 1) {\n        previousButton.hidden = true;\n        nextButton.hidden = true;\n      }\n\n      updateCardSizes();\n      setCarouselPosition(false);\n      startAutoplay();\n    }\n\n    function getProductsPerView() {\n      const viewportWidth = viewport.clientWidth;\n\n      if (viewportWidth <= 580) {\n        return 1;\n      }\n\n      if (viewportWidth <= 820) {\n        return 2;\n      }\n\n      if (viewportWidth <= 1100) {\n        return 3;\n      }\n\n      return 4;\n    }\n\n    function updateCardSizes() {\n      if (!viewport || viewport.hidden) {\n        return;\n      }\n\n      const computedStyles = window.getComputedStyle(track);\n\n      cardGap =\n        parseFloat(\n          computedStyles.columnGap ||\n          computedStyles.gap ||\n          \"22\"\n        ) || 22;\n\n      const productsPerView = getProductsPerView();\n\n      cardWidth =\n        (\n          viewport.clientWidth -\n          cardGap * (productsPerView - 1)\n        ) /\n        productsPerView;\n\n      track\n        .querySelectorAll(\".dtn-new-products__card\")\n        .forEach(function (card) {\n          card.style.width = cardWidth + \"px\";\n        });\n\n      setCarouselPosition(false);\n    }\n\n    function setCarouselPosition(animate) {\n      track.style.transition = animate\n        ? \"transform .55s cubic-bezier(.22,.61,.36,1)\"\n        : \"none\";\n\n      track.style.transform =\n        \"translate3d(-\" +\n        currentIndex * (cardWidth + cardGap) +\n        \"px,0,0)\";\n    }\n\n    function moveToNextProduct() {\n      if (productCount <= 1) {\n        return;\n      }\n\n      window.clearTimeout(resetTimer);\n\n      currentIndex += 1;\n      setCarouselPosition(true);\n\n      if (currentIndex >= productCount) {\n        resetTimer = window.setTimeout(function () {\n          currentIndex = 0;\n          setCarouselPosition(false);\n\n          window.requestAnimationFrame(function () {\n            window.requestAnimationFrame(function () {\n              track.style.transition =\n                \"transform .55s cubic-bezier(.22,.61,.36,1)\";\n            });\n          });\n        }, transitionDuration + 40);\n      }\n    }\n\n    function moveToPreviousProduct() {\n      if (productCount <= 1) {\n        return;\n      }\n\n      window.clearTimeout(resetTimer);\n\n      if (currentIndex <= 0) {\n        currentIndex = productCount;\n        setCarouselPosition(false);\n\n        window.requestAnimationFrame(function () {\n          window.requestAnimationFrame(function () {\n            currentIndex = productCount - 1;\n            setCarouselPosition(true);\n          });\n        });\n      } else {\n        currentIndex -= 1;\n        setCarouselPosition(true);\n      }\n    }\n\n    function stopAutoplay() {\n      window.clearInterval(autoplayTimer);\n      autoplayTimer = null;\n    }\n\n    function startAutoplay() {\n      stopAutoplay();\n\n      if (\n        productCount <= 1 ||\n        !carouselIsVisible ||\n        document.hidden\n      ) {\n        return;\n      }\n\n      autoplayTimer = window.setInterval(\n        moveToNextProduct,\n        autoplayDelay\n      );\n    }\n\n    function showToast(message, isError) {\n      if (!toast) {\n        return;\n      }\n\n      toastMessage.textContent = message;\n\n      toast.style.background = isError\n        ? \"rgba(142,43,43,.97)\"\n        : \"rgba(40,26,22,.96)\";\n\n      toast.classList.add(\"is-visible\");\n\n      window.clearTimeout(toastTimer);\n\n      toastTimer = window.setTimeout(function () {\n        toast.classList.remove(\"is-visible\");\n      }, 3300);\n    }\n\n    function updateThemeCartCount(itemCount) {\n      const countSelectors = [\n        \"[data-cart-count]\",\n        \".cart-count-bubble span[aria-hidden='true']\",\n        \".cart-count-number\",\n        \".cart-count\",\n        \"#CartCount\"\n      ];\n\n      document\n        .querySelectorAll(countSelectors.join(\",\"))\n        .forEach(function (element) {\n          element.textContent = itemCount;\n          element.hidden = false;\n          element.removeAttribute(\"hidden\");\n        });\n\n      document\n        .querySelectorAll(\".cart-count-bubble\")\n        .forEach(function (bubble) {\n          bubble.hidden = false;\n          bubble.classList.remove(\"hidden\");\n          bubble.removeAttribute(\"hidden\");\n        });\n    }\n\n    async function fetchCurrentCart() {\n      try {\n        const response = await fetch(\n          createStoreUrl(\"cart.js\"),\n          {\n            method: \"GET\",\n            headers: {\n              Accept: \"application/json\",\n              \"X-Requested-With\": \"XMLHttpRequest\"\n            }\n          }\n        );\n\n        if (!response.ok) {\n          return null;\n        }\n\n        return await response.json();\n      } catch (error) {\n        return null;\n      }\n    }\n\n    function notifyThemeAboutCart(cart) {\n      const eventNames = [\n        \"cart:updated\",\n        \"cart:refresh\",\n        \"cart:change\"\n      ];\n\n      eventNames.forEach(function (eventName) {\n        document.dispatchEvent(\n          new CustomEvent(eventName, {\n            bubbles: true,\n            detail: {\n              cart: cart\n            }\n          })\n        );\n      });\n    }\n\n    async function addProductToCart(button) {\n      const variantId = Number(button.dataset.variantId);\n      const productTitle =\n        button.dataset.productTitle || \"Product\";\n\n      if (\n        !variantId ||\n        button.classList.contains(\"is-loading\")\n      ) {\n        return;\n      }\n\n      const buttonText = button.querySelector(\"span\");\n      const originalButtonText = buttonText\n        ? buttonText.textContent\n        : \"Add\";\n\n      button.classList.add(\"is-loading\");\n\n      if (buttonText) {\n        buttonText.textContent = \"Adding...\";\n      }\n\n      try {\n        const response = await fetch(\n          createStoreUrl(\"cart/add.js\"),\n          {\n            method: \"POST\",\n            headers: {\n              \"Content-Type\": \"application/json\",\n              Accept: \"application/json\",\n              \"X-Requested-With\": \"XMLHttpRequest\"\n            },\n            body: JSON.stringify({\n              items: [\n                {\n                  id: variantId,\n                  quantity: 1\n                }\n              ]\n            })\n          }\n        );\n\n        const responseData = await response.json();\n\n        if (!response.ok) {\n          throw new Error(\n            responseData.description ||\n            responseData.message ||\n            \"This product could not be added.\"\n          );\n        }\n\n        button.classList.remove(\"is-loading\");\n        button.classList.add(\"is-added\");\n\n        if (buttonText) {\n          buttonText.textContent = \"Added ✓\";\n        }\n\n        showToast(\n          productTitle + \" added to your cart.\",\n          false\n        );\n\n        window.setTimeout(async function () {\n          const cart = await fetchCurrentCart();\n\n          if (cart) {\n            updateThemeCartCount(cart.item_count);\n            notifyThemeAboutCart(cart);\n          }\n        }, 180);\n\n        window.setTimeout(function () {\n          button.classList.remove(\"is-added\");\n\n          if (buttonText) {\n            buttonText.textContent = originalButtonText;\n          }\n        }, 1900);\n\n      } catch (error) {\n        button.classList.remove(\"is-loading\");\n\n        if (buttonText) {\n          buttonText.textContent = originalButtonText;\n        }\n\n        showToast(\n          error.message ||\n          \"This product could not be added.\",\n          true\n        );\n      }\n    }\n\n    previousButton.addEventListener(\"click\", function () {\n      moveToPreviousProduct();\n      startAutoplay();\n    });\n\n    nextButton.addEventListener(\"click\", function () {\n      moveToNextProduct();\n      startAutoplay();\n    });\n\n    root.addEventListener(\"click\", function (event) {\n      const addButton = event.target.closest(\n        \".dtn-new-products__add\"\n      );\n\n      if (!addButton || addButton.disabled) {\n        return;\n      }\n\n      addProductToCart(addButton);\n    });\n\n    viewport.addEventListener(\n      \"mouseenter\",\n      stopAutoplay\n    );\n\n    viewport.addEventListener(\n      \"mouseleave\",\n      startAutoplay\n    );\n\n    viewport.addEventListener(\n      \"focusin\",\n      stopAutoplay\n    );\n\n    viewport.addEventListener(\n      \"focusout\",\n      startAutoplay\n    );\n\n    viewport.addEventListener(\n      \"touchstart\",\n      function (event) {\n        touchStartX =\n          event.changedTouches[0].screenX;\n\n        stopAutoplay();\n      },\n      {\n        passive: true\n      }\n    );\n\n    viewport.addEventListener(\n      \"touchend\",\n      function (event) {\n        touchEndX =\n          event.changedTouches[0].screenX;\n\n        const swipeDistance =\n          touchStartX - touchEndX;\n\n        if (Math.abs(swipeDistance) > 45) {\n          if (swipeDistance > 0) {\n            moveToNextProduct();\n          } else {\n            moveToPreviousProduct();\n          }\n        }\n\n        startAutoplay();\n      },\n      {\n        passive: true\n      }\n    );\n\n    window.addEventListener(\n      \"resize\",\n      function () {\n        updateCardSizes();\n      },\n      {\n        passive: true\n      }\n    );\n\n    document.addEventListener(\n      \"visibilitychange\",\n      function () {\n        if (document.hidden) {\n          stopAutoplay();\n        } else {\n          startAutoplay();\n        }\n      }\n    );\n\n    if (\"IntersectionObserver\" in window) {\n      const observer = new IntersectionObserver(\n        function (entries) {\n          entries.forEach(function (entry) {\n            carouselIsVisible = entry.isIntersecting;\n\n            if (carouselIsVisible) {\n              startAutoplay();\n            } else {\n              stopAutoplay();\n            }\n          });\n        },\n        {\n          threshold: 0.15\n        }\n      );\n\n      observer.observe(root);\n    }\n\n    toastCartLink.href = createStoreUrl(\"cart\");\n\n    fetchProducts()\n      .then(function (fetchedProducts) {\n        products = sortNewestProducts(\n          fetchedProducts\n        ).slice(0, maximumProducts);\n\n        productCount = products.length;\n\n        if (!productCount) {\n          loading.hidden = true;\n          emptyMessage.hidden = false;\n          previousButton.hidden = true;\n          nextButton.hidden = true;\n          return;\n        }\n\n        renderProducts();\n      })\n      .catch(function (error) {\n        console.error(\n          \"New product carousel error:\",\n          error\n        );\n\n        loading.hidden = true;\n        emptyMessage.hidden = false;\n        emptyMessage.textContent =\n          \"The newest products could not be loaded.\";\n        previousButton.hidden = true;\n        nextButton.hidden = true;\n      });\n  }\n\n  function startAllCarousels(scope) {\n    const searchArea = scope || document;\n\n    searchArea\n      .querySelectorAll(\".dtn-new-products\")\n      .forEach(function (carousel) {\n        initialiseNewProductCarousel(carousel);\n      });\n  }\n\n  startAllCarousels(document);\n\n  document.addEventListener(\n    \"shopify:section:load\",\n    function (event) {\n      startAllCarousels(event.target);\n    }\n  );\n})();\n</script>"
      }
    },
