        "container": "fluid",
        "section_title": "",
        "custom_html": "<!-- Hertha Nest: Full-Width Newly Added Product Carousel -->\n<div class=\"hn-fresh-carousel\" data-product-limit=\"12\">\n\n  <div class=\"hn-fresh-carousel__inner\">\n\n    <div class=\"hn-fresh-carousel__header\">\n\n      <span class=\"hn-fresh-carousel__eyebrow\">\n        New at Hertha Nest\n      </span>\n\n      <h2 class=\"hn-fresh-carousel__title\">\n        The New Décor Edit\n      </h2>\n\n      <p class=\"hn-fresh-carousel__description\">\n        Explore our latest handcrafted additions, thoughtfully selected to\n        bring fresh character, colour, and timeless charm into your home.\n      </p>\n\n      <div class=\"hn-fresh-carousel__controls\">\n\n        <button type=\"button\" class=\"hn-fresh-carousel__arrow hn-fresh-carousel__previous\" aria-label=\"View previous product\">\n          <svg viewbox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M15 18 9 12l6-6\"></path>\n          </svg>\n        </button>\n\n        <button type=\"button\" class=\"hn-fresh-carousel__arrow hn-fresh-carousel__next\" aria-label=\"View next product\">\n          <svg viewbox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"m9 18 6-6-6-6\"></path>\n          </svg>\n        </button>\n\n      </div>\n\n    </div>\n\n    <div class=\"hn-fresh-carousel__loading\">\n      <span class=\"hn-fresh-carousel__loader\"></span>\n      <span>Discovering our latest arrivals...</span>\n    </div>\n\n    <div class=\"hn-fresh-carousel__viewport\" aria-label=\"Newly added products\" hidden=\"\">\n      <div class=\"hn-fresh-carousel__track\"></div>\n    </div>\n\n    <div class=\"hn-fresh-carousel__empty\" hidden=\"\">\n      New products will appear here as soon as they are available.\n    </div>\n\n  </div>\n\n  <div class=\"hn-fresh-carousel__toast\" role=\"status\" aria-live=\"polite\">\n    <span class=\"hn-fresh-carousel__toast-icon\">\n      ✓\n    </span>\n\n    <span class=\"hn-fresh-carousel__toast-message\">\n      Product added to your cart.\n    </span>\n\n    <a href=\"/cart\">View cart</a>\n  </div>\n\n</div>\n\n<style>\n  /*\n   * Removes spacing added by the Shopify section wrapper.\n   * Supported by current modern browsers.\n   */\n  .shopify-section:has(.hn-fresh-carousel){\n    width:100% !important;\n    max-width:none !important;\n    margin-top:0 !important;\n    margin-bottom:0 !important;\n    padding-top:0 !important;\n    padding-bottom:0 !important;\n    overflow:visible !important;\n  }\n\n  .hn-fresh-carousel{\n    --hn-green:#315548;\n    --hn-green-dark:#203f35;\n    --hn-green-soft:rgba(49,85,72,.10);\n    --hn-gold:#bd9152;\n    --hn-gold-soft:rgba(189,145,82,.16);\n    --hn-cream:#f8f6ef;\n    --hn-cream-deep:#efebe0;\n    --hn-white:#ffffff;\n    --hn-heading:#29211c;\n    --hn-text:rgba(41,33,28,.70);\n    --hn-muted:rgba(41,33,28,.52);\n    --hn-border:rgba(49,85,72,.14);\n    --hn-gap:20px;\n\n    position:relative;\n    left:50%;\n    width:100vw;\n    max-width:100vw;\n    margin:0 0 30px -50vw;\n    padding:36px 0 42px;\n    overflow:hidden;\n\n    background:\n      radial-gradient(\n        circle at 5% 0%,\n        rgba(189,145,82,.14),\n        transparent 27%\n      ),\n      radial-gradient(\n        circle at 95% 100%,\n        rgba(49,85,72,.10),\n        transparent 28%\n      ),\n      linear-gradient(\n        135deg,\n        #f8f6ef 0%,\n        #fffdf8 48%,\n        #f4f3ec 100%\n      );\n\n    color:var(--hn-heading);\n  }\n\n  .hn-fresh-carousel *,\n  .hn-fresh-carousel *::before,\n  .hn-fresh-carousel *::after{\n    box-sizing:border-box;\n  }\n\n  .hn-fresh-carousel__inner{\n    width:100%;\n    max-width:1520px;\n    margin:0 auto;\n    padding:0 32px;\n  }\n\n  /* Header */\n\n  .hn-fresh-carousel__header{\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    max-width:850px;\n    margin:0 auto 24px;\n    text-align:center;\n  }\n\n  .hn-fresh-carousel__eyebrow{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    gap:9px;\n    margin:0 0 9px;\n\n    color:var(--hn-green);\n    font-size:11px;\n    font-weight:750;\n    line-height:1.3;\n    letter-spacing:1.8px;\n    text-transform:uppercase;\n  }\n\n  .hn-fresh-carousel__eyebrow::before,\n  .hn-fresh-carousel__eyebrow::after{\n    content:\"\";\n    width:28px;\n    height:1px;\n    background:var(--hn-gold);\n  }\n\n  .hn-fresh-carousel__title{\n    margin:0;\n\n    color:var(--hn-heading);\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:clamp(29px,3.5vw,44px);\n    font-weight:500;\n    line-height:1.12;\n    letter-spacing:-.5px;\n    text-align:center;\n  }\n\n  .hn-fresh-carousel__description{\n    max-width:720px;\n    margin:10px auto 0;\n\n    color:var(--hn-text);\n    font-size:14px;\n    line-height:1.65;\n    text-align:center;\n  }\n\n  /* Navigation */\n\n  .hn-fresh-carousel__controls{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:9px;\n    margin-top:17px;\n  }\n\n  .hn-fresh-carousel__arrow{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    width:41px;\n    height:41px;\n    padding:0;\n\n    border:1px solid var(--hn-border);\n    border-radius:50%;\n    background:rgba(255,255,255,.84);\n    color:var(--hn-green-dark);\n\n    box-shadow:\n      0 7px 18px rgba(32,63,53,.08),\n      inset 0 1px 0 rgba(255,255,255,.9);\n\n    cursor:pointer;\n\n    transition:\n      transform .25s ease,\n      border-color .25s ease,\n      background .25s ease,\n      color .25s ease,\n      box-shadow .25s ease;\n  }\n\n  .hn-fresh-carousel__arrow:hover{\n    transform:translateY(-2px);\n\n    border-color:var(--hn-green);\n    background:var(--hn-green);\n    color:#ffffff;\n\n    box-shadow:0 10px 22px rgba(32,63,53,.18);\n  }\n\n  .hn-fresh-carousel__arrow:focus-visible{\n    outline:2px solid var(--hn-gold);\n    outline-offset:3px;\n  }\n\n  .hn-fresh-carousel__arrow svg{\n    width:17px;\n    height:17px;\n\n    fill:none;\n    stroke:currentColor;\n    stroke-width:1.8;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n  }\n\n  /* Carousel */\n\n  .hn-fresh-carousel__viewport{\n    width:100%;\n    overflow:hidden;\n    touch-action:pan-y;\n  }\n\n  .hn-fresh-carousel__track{\n    display:flex;\n    align-items:stretch;\n    gap:var(--hn-gap);\n\n    width:max-content;\n\n    will-change:transform;\n\n    transition:\n      transform .55s cubic-bezier(.22,.61,.36,1);\n  }\n\n  /* Product Card */\n\n  .hn-fresh-carousel__card{\n    position:relative;\n    flex:0 0 auto;\n    min-width:0;\n    overflow:hidden;\n\n    border:1px solid var(--hn-border);\n    border-radius:18px;\n    background:var(--hn-white);\n\n    box-shadow:\n      0 10px 25px rgba(41,33,28,.06),\n      0 2px 5px rgba(41,33,28,.025);\n\n    transition:\n      transform .3s ease,\n      border-color .3s ease,\n      box-shadow .3s ease;\n  }\n\n  .hn-fresh-carousel__card:hover{\n    transform:translateY(-5px);\n\n    border-color:rgba(189,145,82,.38);\n\n    box-shadow:\n      0 18px 38px rgba(41,33,28,.11),\n      0 4px 10px rgba(41,33,28,.04);\n  }\n\n  /* Product Image */\n\n  .hn-fresh-carousel__image-link{\n    position:relative;\n    display:block;\n\n    width:100%;\n    aspect-ratio:1 / 1;\n\n    overflow:hidden;\n    background:#f0eee7;\n  }\n\n  .hn-fresh-carousel__image{\n    display:block;\n    width:100%;\n    height:100%;\n    object-fit:cover;\n\n    transition:\n      transform .65s cubic-bezier(.22,.61,.36,1);\n  }\n\n  .hn-fresh-carousel__card:hover\n  .hn-fresh-carousel__image{\n    transform:scale(1.05);\n  }\n\n  .hn-fresh-carousel__image-placeholder{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    width:100%;\n    height:100%;\n    padding:30px;\n\n    background:\n      linear-gradient(\n        135deg,\n        rgba(49,85,72,.12),\n        rgba(255,255,255,.90)\n      );\n\n    color:var(--hn-green);\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:17px;\n    line-height:1.4;\n    text-align:center;\n  }\n\n  /* New Product Badge */\n\n  .hn-fresh-carousel__badge{\n    position:absolute;\n    top:12px;\n    left:12px;\n    z-index:2;\n\n    display:inline-flex;\n    align-items:center;\n    gap:7px;\n\n    min-height:28px;\n    padding:7px 11px;\n\n    border:1px solid rgba(255,255,255,.32);\n    border-radius:999px;\n\n    background:rgba(35,72,59,.93);\n    color:#ffffff;\n\n    box-shadow:\n      0 7px 18px rgba(21,46,37,.20);\n\n    backdrop-filter:blur(9px);\n    -webkit-backdrop-filter:blur(9px);\n\n    font-size:9px;\n    font-weight:750;\n    line-height:1;\n    letter-spacing:1.05px;\n    text-transform:uppercase;\n  }\n\n  .hn-fresh-carousel__badge::before{\n    content:\"\";\n\n    width:6px;\n    height:6px;\n    flex:0 0 6px;\n\n    border-radius:50%;\n    background:#e8bd78;\n\n    box-shadow:\n      0 0 0 4px rgba(232,189,120,.16);\n  }\n\n  /* Compact Product Details */\n\n  .hn-fresh-carousel__content{\n    display:block;\n    padding:14px 15px 15px;\n  }\n\n  .hn-fresh-carousel__vendor{\n    margin:0 0 5px;\n    overflow:hidden;\n\n    color:var(--hn-green);\n    font-size:9px;\n    font-weight:750;\n    line-height:1.3;\n    letter-spacing:1.2px;\n    text-overflow:ellipsis;\n    text-transform:uppercase;\n    white-space:nowrap;\n  }\n\n  .hn-fresh-carousel__product-title{\n    min-height:44px;\n    margin:0;\n\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:17px;\n    font-weight:500;\n    line-height:1.32;\n  }\n\n  .hn-fresh-carousel__product-title a{\n    display:-webkit-box;\n    overflow:hidden;\n\n    color:var(--hn-heading);\n    text-decoration:none;\n\n    -webkit-box-orient:vertical;\n    -webkit-line-clamp:2;\n\n    transition:color .22s ease;\n  }\n\n  .hn-fresh-carousel__product-title a:hover{\n    color:var(--hn-green);\n  }\n\n  /* Price and Add Button */\n\n  .hn-fresh-carousel__bottom{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:10px;\n\n    margin-top:12px;\n    padding-top:12px;\n\n    border-top:1px solid rgba(49,85,72,.09);\n  }\n\n  .hn-fresh-carousel__prices{\n    display:flex;\n    flex-direction:column;\n    align-items:flex-start;\n    gap:1px;\n    min-width:0;\n  }\n\n  .hn-fresh-carousel__price{\n    color:var(--hn-heading);\n    font-size:17px;\n    font-weight:750;\n    line-height:1.25;\n  }\n\n  .hn-fresh-carousel__compare-price{\n    color:var(--hn-muted);\n    font-size:11px;\n    line-height:1.25;\n    text-decoration:line-through;\n  }\n\n  .hn-fresh-carousel__add{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    gap:8px;\n\n    min-width:118px;\n    min-height:42px;\n    padding:9px 15px;\n\n    border:1px solid var(--hn-green);\n    border-radius:999px;\n\n    background:\n      linear-gradient(\n        135deg,\n        var(--hn-green) 0%,\n        var(--hn-green-dark) 100%\n      );\n\n    color:#ffffff;\n\n    box-shadow:\n      0 7px 16px rgba(32,63,53,.18),\n      inset 0 1px 0 rgba(255,255,255,.13);\n\n    font-family:inherit;\n    font-size:11px;\n    font-weight:750;\n    line-height:1;\n    letter-spacing:.1px;\n    white-space:nowrap;\n\n    cursor:pointer;\n\n    transition:\n      transform .25s ease,\n      border-color .25s ease,\n      background .25s ease,\n      box-shadow .25s ease,\n      opacity .25s ease;\n  }\n\n  .hn-fresh-carousel__add:hover{\n    transform:translateY(-2px);\n\n    border-color:var(--hn-gold);\n\n    background:\n      linear-gradient(\n        135deg,\n        #c69a58 0%,\n        #a87738 100%\n      );\n\n    box-shadow:\n      0 9px 20px rgba(145,101,48,.23);\n  }\n\n  .hn-fresh-carousel__add:focus-visible{\n    outline:2px solid var(--hn-gold);\n    outline-offset:3px;\n  }\n\n  .hn-fresh-carousel__cart-symbol{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    width:20px;\n    height:20px;\n    flex:0 0 20px;\n\n    border-radius:50%;\n    background:rgba(255,255,255,.14);\n  }\n\n  .hn-fresh-carousel__cart-symbol svg{\n    width:12px;\n    height:12px;\n\n    fill:none;\n    stroke:currentColor;\n    stroke-width:1.8;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n  }\n\n  .hn-fresh-carousel__add.is-loading{\n    pointer-events:none;\n    opacity:.62;\n  }\n\n  .hn-fresh-carousel__add.is-added{\n    border-color:#4f8062;\n    background:#4f8062;\n  }\n\n  .hn-fresh-carousel__add:disabled{\n    transform:none;\n\n    min-width:105px;\n\n    border-color:#d2cec4;\n    background:#d2cec4;\n    color:#716e67;\n\n    box-shadow:none;\n    cursor:not-allowed;\n    opacity:.9;\n  }\n\n  /* Loading */\n\n  .hn-fresh-carousel__loading{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:11px;\n\n    min-height:140px;\n\n    color:var(--hn-text);\n    font-size:13px;\n  }\n\n  .hn-fresh-carousel__loader{\n    width:23px;\n    height:23px;\n\n    border:3px solid rgba(49,85,72,.16);\n    border-top-color:var(--hn-green);\n    border-radius:50%;\n\n    animation:hnFreshCarouselSpin .8s linear infinite;\n  }\n\n  @keyframes hnFreshCarouselSpin{\n    to{\n      transform:rotate(360deg);\n    }\n  }\n\n  .hn-fresh-carousel__empty{\n    padding:35px 20px;\n\n    border:1px solid var(--hn-border);\n    border-radius:16px;\n\n    background:#ffffff;\n    color:var(--hn-text);\n\n    text-align:center;\n  }\n\n  /* Add to Cart Confirmation */\n\n  .hn-fresh-carousel__toast{\n    position:fixed;\n    right:20px;\n    bottom:20px;\n    z-index:999999;\n\n    display:flex;\n    align-items:center;\n    gap:10px;\n\n    max-width:min(420px,calc(100vw - 30px));\n    padding:13px 15px;\n\n    border:1px solid rgba(255,255,255,.14);\n    border-radius:13px;\n\n    background:rgba(32,63,53,.97);\n    color:#ffffff;\n\n    box-shadow:0 17px 42px rgba(0,0,0,.22);\n\n    opacity:0;\n    visibility:hidden;\n    transform:translateY(14px);\n\n    transition:\n      opacity .3s ease,\n      visibility .3s ease,\n      transform .3s ease;\n  }\n\n  .hn-fresh-carousel__toast.is-visible{\n    opacity:1;\n    visibility:visible;\n    transform:translateY(0);\n  }\n\n  .hn-fresh-carousel__toast-icon{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    width:25px;\n    height:25px;\n    flex:0 0 25px;\n\n    border-radius:50%;\n\n    background:rgba(255,255,255,.14);\n    color:#f0cb8a;\n\n    font-size:13px;\n    font-weight:800;\n  }\n\n  .hn-fresh-carousel__toast-message{\n    font-size:12px;\n    font-weight:650;\n    line-height:1.4;\n  }\n\n  .hn-fresh-carousel__toast a{\n    margin-left:auto;\n\n    color:#f3ce8c;\n\n    font-size:11px;\n    font-weight:750;\n    white-space:nowrap;\n    text-decoration:underline;\n    text-underline-offset:3px;\n  }\n\n  /* Tablet */\n\n  @media (max-width:900px){\n    .hn-fresh-carousel{\n      padding:32px 0 38px;\n    }\n\n    .hn-fresh-carousel__inner{\n      padding:0 22px;\n    }\n\n    .hn-fresh-carousel__header{\n      margin-bottom:21px;\n    }\n  }\n\n  /* Mobile */\n\n  @media (max-width:580px){\n    .hn-fresh-carousel{\n      --hn-gap:14px;\n\n      margin-bottom:20px;\n      padding:28px 0 32px;\n    }\n\n    .hn-fresh-carousel__inner{\n      padding:0 14px;\n    }\n\n    .hn-fresh-carousel__header{\n      margin-bottom:19px;\n    }\n\n    .hn-fresh-carousel__eyebrow{\n      margin-bottom:7px;\n      font-size:9px;\n      letter-spacing:1.35px;\n    }\n\n    .hn-fresh-carousel__eyebrow::before,\n    .hn-fresh-carousel__eyebrow::after{\n      width:20px;\n    }\n\n    .hn-fresh-carousel__title{\n      font-size:29px;\n    }\n\n    .hn-fresh-carousel__description{\n      margin-top:8px;\n      font-size:12.5px;\n      line-height:1.55;\n    }\n\n    .hn-fresh-carousel__controls{\n      margin-top:14px;\n    }\n\n    .hn-fresh-carousel__arrow{\n      width:37px;\n      height:37px;\n    }\n\n    .hn-fresh-carousel__card{\n      border-radius:16px;\n    }\n\n    .hn-fresh-carousel__content{\n      padding:13px 13px 14px;\n    }\n\n    .hn-fresh-carousel__product-title{\n      min-height:42px;\n      font-size:16px;\n    }\n\n    .hn-fresh-carousel__bottom{\n      margin-top:10px;\n      padding-top:10px;\n    }\n\n    .hn-fresh-carousel__price{\n      font-size:16px;\n    }\n\n    .hn-fresh-carousel__add{\n      min-width:112px;\n      min-height:40px;\n      padding:8px 12px;\n      font-size:10.5px;\n    }\n\n    .hn-fresh-carousel__toast{\n      right:14px;\n      bottom:14px;\n    }\n  }\n\n  @media (max-width:370px){\n    .hn-fresh-carousel__add{\n      min-width:94px;\n      padding:8px 10px;\n    }\n\n    .hn-fresh-carousel__cart-symbol{\n      display:none;\n    }\n  }\n\n  @media (prefers-reduced-motion:reduce){\n    .hn-fresh-carousel__track,\n    .hn-fresh-carousel__card,\n    .hn-fresh-carousel__image,\n    .hn-fresh-carousel__arrow,\n    .hn-fresh-carousel__add{\n      transition-duration:.01ms !important;\n    }\n\n    .hn-fresh-carousel__loader{\n      animation:none;\n    }\n  }\n</style>\n\n<script>\n(function () {\n  \"use strict\";\n\n  function initialiseFreshCarousel(root) {\n    if (!root || root.dataset.initialised === \"true\") {\n      return;\n    }\n\n    root.dataset.initialised = \"true\";\n\n    const track = root.querySelector(\n      \".hn-fresh-carousel__track\"\n    );\n\n    const viewport = root.querySelector(\n      \".hn-fresh-carousel__viewport\"\n    );\n\n    const loading = root.querySelector(\n      \".hn-fresh-carousel__loading\"\n    );\n\n    const emptyMessage = root.querySelector(\n      \".hn-fresh-carousel__empty\"\n    );\n\n    const previousButton = root.querySelector(\n      \".hn-fresh-carousel__previous\"\n    );\n\n    const nextButton = root.querySelector(\n      \".hn-fresh-carousel__next\"\n    );\n\n    const controls = root.querySelector(\n      \".hn-fresh-carousel__controls\"\n    );\n\n    const toast = root.querySelector(\n      \".hn-fresh-carousel__toast\"\n    );\n\n    const toastMessage = root.querySelector(\n      \".hn-fresh-carousel__toast-message\"\n    );\n\n    const toastCartLink = root.querySelector(\n      \".hn-fresh-carousel__toast a\"\n    );\n\n    const maximumProducts = Math.min(\n      Number(root.dataset.productLimit || 12),\n      12\n    );\n\n    const shopRoot =\n      window.Shopify &&\n      window.Shopify.routes &&\n      window.Shopify.routes.root\n        ? window.Shopify.routes.root\n        : \"/\";\n\n    const activeCurrency =\n      window.Shopify &&\n      window.Shopify.currency &&\n      window.Shopify.currency.active\n        ? window.Shopify.currency.active\n        : \"INR\";\n\n    const storeLanguage =\n      document.documentElement.lang || \"en-IN\";\n\n    const autoplayDelay = 3400;\n    const transitionDuration = 550;\n\n    let products = [];\n    let productCount = 0;\n    let currentIndex = 0;\n    let cardWidth = 0;\n    let cardGap = 20;\n    let autoplayTimer = null;\n    let resetTimer = null;\n    let toastTimer = null;\n    let touchStartX = 0;\n    let touchEndX = 0;\n    let carouselIsVisible = true;\n    let resizeTimer = null;\n\n    function createStoreUrl(path) {\n      const cleanPath = String(path).replace(/^\\/+/, \"\");\n\n      return shopRoot + cleanPath;\n    }\n\n    function escapeHtml(value) {\n      return String(value || \"\")\n        .replace(/&/g, \"&amp;\")\n        .replace(/</g, \"&lt;\")\n        .replace(/>/g, \"&gt;\")\n        .replace(/\"/g, \"&quot;\")\n        .replace(/'/g, \"&#039;\");\n    }\n\n    function formatMoney(value) {\n      const amount = Number(value || 0);\n\n      try {\n        return new Intl.NumberFormat(storeLanguage, {\n          style:\"currency\",\n          currency:activeCurrency,\n          maximumFractionDigits:\n            amount % 1 === 0 ? 0 : 2\n        }).format(amount);\n      } catch (error) {\n        return activeCurrency + \" \" + amount.toFixed(2);\n      }\n    }\n\n    function getAvailableVariant(product) {\n      if (\n        !product.variants ||\n        !product.variants.length\n      ) {\n        return null;\n      }\n\n      return (\n        product.variants.find(function (variant) {\n          return variant.available === true;\n        }) ||\n        product.variants[0]\n      );\n    }\n\n    function getImageSource(product, variant) {\n      let image = \"\";\n\n      if (\n        variant &&\n        variant.featured_image &&\n        variant.featured_image.src\n      ) {\n        image = variant.featured_image.src;\n      } else if (\n        product.featured_image &&\n        typeof product.featured_image === \"string\"\n      ) {\n        image = product.featured_image;\n      } else if (\n        product.featured_image &&\n        product.featured_image.src\n      ) {\n        image = product.featured_image.src;\n      } else if (\n        product.images &&\n        product.images.length\n      ) {\n        image =\n          typeof product.images[0] === \"string\"\n            ? product.images[0]\n            : product.images[0].src;\n      }\n\n      return image || \"\";\n    }\n\n    function optimiseImageUrl(imageUrl) {\n      if (!imageUrl) {\n        return \"\";\n      }\n\n      if (imageUrl.indexOf(\"width=\") !== -1) {\n        return imageUrl;\n      }\n\n      return (\n        imageUrl +\n        (imageUrl.indexOf(\"?\") === -1 ? \"?\" : \"&\") +\n        \"width=800\"\n      );\n    }\n\n    function createProductCard(product, isDuplicate) {\n      const variant = getAvailableVariant(product);\n\n      const productUrl = createStoreUrl(\n        \"products/\" + encodeURIComponent(product.handle)\n      );\n\n      const productTitle = escapeHtml(product.title);\n      const vendor = escapeHtml(product.vendor || \"\");\n\n      const imageSource = optimiseImageUrl(\n        getImageSource(product, variant)\n      );\n\n      const available =\n        variant && variant.available !== false;\n\n      const price = variant\n        ? formatMoney(variant.price)\n        : \"\";\n\n      const comparePrice =\n        variant &&\n        Number(variant.compare_at_price) >\n        Number(variant.price)\n          ? formatMoney(variant.compare_at_price)\n          : \"\";\n\n      const duplicateAttributes = isDuplicate\n        ? 'aria-hidden=\"true\"'\n        : \"\";\n\n      const duplicateTabIndex = isDuplicate\n        ? 'tabindex=\"-1\"'\n        : \"\";\n\n      let imageMarkup = \"\";\n\n      if (imageSource) {\n        imageMarkup =\n          '<img ' +\n            'class=\"hn-fresh-carousel__image\" ' +\n            'src=\"' + escapeHtml(imageSource) + '\" ' +\n            'alt=\"' + productTitle + '\" ' +\n            'loading=\"lazy\" ' +\n            'width=\"800\" ' +\n            'height=\"800\"' +\n          \">\";\n      } else {\n        imageMarkup =\n          '<div class=\"hn-fresh-carousel__image-placeholder\">' +\n            productTitle +\n          \"</div>\";\n      }\n\n      let comparePriceMarkup = \"\";\n\n      if (comparePrice) {\n        comparePriceMarkup =\n          '<span class=\"hn-fresh-carousel__compare-price\">' +\n            comparePrice +\n          \"</span>\";\n      }\n\n      let addButtonMarkup = \"\";\n\n      if (variant && available) {\n        addButtonMarkup =\n          '<button ' +\n            'type=\"button\" ' +\n            'class=\"hn-fresh-carousel__add\" ' +\n            'data-variant-id=\"' +\n              escapeHtml(variant.id) +\n            '\" ' +\n            'data-product-title=\"' +\n              productTitle +\n            '\" ' +\n            duplicateTabIndex +\n          \">\" +\n\n            '<span class=\"hn-fresh-carousel__cart-symbol\">' +\n              '<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">' +\n                '<path d=\"M6 7h12l-1 13H7L6 7Z\"></path>' +\n                '<path d=\"M9 9V6a3 3 0 0 1 6 0v3\"></path>' +\n              \"</svg>\" +\n            \"</span>\" +\n\n            '<span class=\"hn-fresh-carousel__button-text\">' +\n              \"Add to cart\" +\n            \"</span>\" +\n\n          \"</button>\";\n      } else {\n        addButtonMarkup =\n          '<button ' +\n            'type=\"button\" ' +\n            'class=\"hn-fresh-carousel__add\" ' +\n            \"disabled \" +\n            duplicateTabIndex +\n          \">\" +\n            '<span class=\"hn-fresh-carousel__button-text\">' +\n              \"Sold out\" +\n            \"</span>\" +\n          \"</button>\";\n      }\n\n      return (\n        '<article ' +\n          'class=\"hn-fresh-carousel__card\" ' +\n          duplicateAttributes +\n        \">\" +\n\n          '<a ' +\n            'href=\"' + productUrl + '\" ' +\n            'class=\"hn-fresh-carousel__image-link\" ' +\n            duplicateTabIndex +\n          \">\" +\n\n            '<span class=\"hn-fresh-carousel__badge\">' +\n              \"Just Unveiled\" +\n            \"</span>\" +\n\n            imageMarkup +\n\n          \"</a>\" +\n\n          '<div class=\"hn-fresh-carousel__content\">' +\n\n            (\n              vendor\n                ? '<div class=\"hn-fresh-carousel__vendor\">' +\n                    vendor +\n                  \"</div>\"\n                : \"\"\n            ) +\n\n            '<h3 class=\"hn-fresh-carousel__product-title\">' +\n              '<a href=\"' +\n                productUrl +\n                '\" ' +\n                duplicateTabIndex +\n              \">\" +\n                productTitle +\n              \"</a>\" +\n            \"</h3>\" +\n\n            '<div class=\"hn-fresh-carousel__bottom\">' +\n\n              '<div class=\"hn-fresh-carousel__prices\">' +\n\n                '<span class=\"hn-fresh-carousel__price\">' +\n                  price +\n                \"</span>\" +\n\n                comparePriceMarkup +\n\n              \"</div>\" +\n\n              addButtonMarkup +\n\n            \"</div>\" +\n\n          \"</div>\" +\n\n        \"</article>\"\n      );\n    }\n\n    async function fetchProducts() {\n      const productUrls = [\n        createStoreUrl(\n          \"collections/all/products.json\" +\n          \"?limit=50&sort_by=created-descending\"\n        ),\n        createStoreUrl(\"products.json?limit=50\")\n      ];\n\n      let finalError = null;\n\n      for (const productUrl of productUrls) {\n        try {\n          const response = await fetch(productUrl, {\n            method:\"GET\",\n            headers:{\n              \"Accept\":\"application/json\",\n              \"X-Requested-With\":\"XMLHttpRequest\"\n            }\n          });\n\n          if (!response.ok) {\n            throw new Error(\n              \"Product request failed: \" +\n              response.status\n            );\n          }\n\n          const data = await response.json();\n\n          if (\n            data &&\n            Array.isArray(data.products)\n          ) {\n            return data.products;\n          }\n        } catch (error) {\n          finalError = error;\n        }\n      }\n\n      throw (\n        finalError ||\n        new Error(\"Products could not be loaded.\")\n      );\n    }\n\n    function sortNewestProducts(productList) {\n      return productList\n        .slice()\n        .sort(function (firstProduct, secondProduct) {\n          const firstDate = new Date(\n            firstProduct.published_at ||\n            firstProduct.created_at ||\n            0\n          ).getTime();\n\n          const secondDate = new Date(\n            secondProduct.published_at ||\n            secondProduct.created_at ||\n            0\n          ).getTime();\n\n          return secondDate - firstDate;\n        });\n    }\n\n    function renderProducts() {\n      const originalCards = products\n        .map(function (product) {\n          return createProductCard(product, false);\n        })\n        .join(\"\");\n\n      const duplicateCards =\n        productCount > 1\n          ? products\n              .map(function (product) {\n                return createProductCard(product, true);\n              })\n              .join(\"\")\n          : \"\";\n\n      track.innerHTML =\n        originalCards + duplicateCards;\n\n      loading.hidden = true;\n      viewport.hidden = false;\n\n      if (productCount <= 1) {\n        controls.hidden = true;\n      }\n\n      window.requestAnimationFrame(function () {\n        updateCardSizes();\n        setCarouselPosition(false);\n        startAutoplay();\n      });\n    }\n\n    function getProductsPerView() {\n      const viewportWidth = viewport.clientWidth;\n\n      if (viewportWidth <= 580) {\n        return 1;\n      }\n\n      if (viewportWidth <= 820) {\n        return 2;\n      }\n\n      if (viewportWidth <= 1120) {\n        return 3;\n      }\n\n      return 4;\n    }\n\n    function updateCardSizes() {\n      if (!viewport || viewport.hidden) {\n        return;\n      }\n\n      const computedStyles =\n        window.getComputedStyle(track);\n\n      cardGap =\n        parseFloat(\n          computedStyles.columnGap ||\n          computedStyles.gap ||\n          \"20\"\n        ) || 20;\n\n      const productsPerView =\n        getProductsPerView();\n\n      cardWidth =\n        (\n          viewport.clientWidth -\n          cardGap * (productsPerView - 1)\n        ) /\n        productsPerView;\n\n      track\n        .querySelectorAll(\n          \".hn-fresh-carousel__card\"\n        )\n        .forEach(function (card) {\n          card.style.width = cardWidth + \"px\";\n        });\n\n      setCarouselPosition(false);\n    }\n\n    function setCarouselPosition(animate) {\n      track.style.transition = animate\n        ? \"transform .55s cubic-bezier(.22,.61,.36,1)\"\n        : \"none\";\n\n      track.style.transform =\n        \"translate3d(-\" +\n        currentIndex * (cardWidth + cardGap) +\n        \"px,0,0)\";\n    }\n\n    function moveToNextProduct() {\n      if (productCount <= 1) {\n        return;\n      }\n\n      window.clearTimeout(resetTimer);\n\n      currentIndex += 1;\n      setCarouselPosition(true);\n\n      if (currentIndex >= productCount) {\n        resetTimer = window.setTimeout(function () {\n          currentIndex = 0;\n          setCarouselPosition(false);\n\n          window.requestAnimationFrame(function () {\n            window.requestAnimationFrame(function () {\n              track.style.transition =\n                \"transform .55s \" +\n                \"cubic-bezier(.22,.61,.36,1)\";\n            });\n          });\n        }, transitionDuration + 40);\n      }\n    }\n\n    function moveToPreviousProduct() {\n      if (productCount <= 1) {\n        return;\n      }\n\n      window.clearTimeout(resetTimer);\n\n      if (currentIndex <= 0) {\n        currentIndex = productCount;\n        setCarouselPosition(false);\n\n        window.requestAnimationFrame(function () {\n          window.requestAnimationFrame(function () {\n            currentIndex = productCount - 1;\n            setCarouselPosition(true);\n          });\n        });\n      } else {\n        currentIndex -= 1;\n        setCarouselPosition(true);\n      }\n    }\n\n    function stopAutoplay() {\n      window.clearInterval(autoplayTimer);\n      autoplayTimer = null;\n    }\n\n    function startAutoplay() {\n      stopAutoplay();\n\n      if (\n        productCount <= 1 ||\n        !carouselIsVisible ||\n        document.hidden\n      ) {\n        return;\n      }\n\n      autoplayTimer = window.setInterval(\n        moveToNextProduct,\n        autoplayDelay\n      );\n    }\n\n    function showToast(message, isError) {\n      if (!toast) {\n        return;\n      }\n\n      toastMessage.textContent = message;\n\n      toast.style.background = isError\n        ? \"rgba(132,48,48,.97)\"\n        : \"rgba(32,63,53,.97)\";\n\n      toast.classList.add(\"is-visible\");\n\n      window.clearTimeout(toastTimer);\n\n      toastTimer = window.setTimeout(function () {\n        toast.classList.remove(\"is-visible\");\n      }, 3200);\n    }\n\n    function updateThemeCartCount(itemCount) {\n      const countSelectors = [\n        \"[data-cart-count]\",\n        \".cart-count-bubble span[aria-hidden='true']\",\n        \".cart-count-number\",\n        \".cart-count\",\n        \"#CartCount\"\n      ];\n\n      document\n        .querySelectorAll(countSelectors.join(\",\"))\n        .forEach(function (element) {\n          element.textContent = itemCount;\n          element.hidden = false;\n          element.removeAttribute(\"hidden\");\n        });\n\n      document\n        .querySelectorAll(\".cart-count-bubble\")\n        .forEach(function (bubble) {\n          bubble.hidden = false;\n          bubble.classList.remove(\"hidden\");\n          bubble.removeAttribute(\"hidden\");\n        });\n    }\n\n    async function fetchCurrentCart() {\n      try {\n        const response = await fetch(\n          createStoreUrl(\"cart.js\"),\n          {\n            method:\"GET\",\n            headers:{\n              \"Accept\":\"application/json\",\n              \"X-Requested-With\":\"XMLHttpRequest\"\n            }\n          }\n        );\n\n        if (!response.ok) {\n          return null;\n        }\n\n        return await response.json();\n      } catch (error) {\n        return null;\n      }\n    }\n\n    function notifyThemeAboutCart(cart) {\n      [\n        \"cart:updated\",\n        \"cart:refresh\",\n        \"cart:change\"\n      ].forEach(function (eventName) {\n        document.dispatchEvent(\n          new CustomEvent(eventName, {\n            bubbles:true,\n            detail:{\n              cart:cart\n            }\n          })\n        );\n      });\n    }\n\n    async function addProductToCart(button) {\n      const variantId =\n        Number(button.dataset.variantId);\n\n      const productTitle =\n        button.dataset.productTitle ||\n        \"Product\";\n\n      if (\n        !variantId ||\n        button.classList.contains(\"is-loading\")\n      ) {\n        return;\n      }\n\n      const buttonText = button.querySelector(\n        \".hn-fresh-carousel__button-text\"\n      );\n\n      const originalText = buttonText\n        ? buttonText.textContent\n        : \"Add to cart\";\n\n      button.classList.add(\"is-loading\");\n\n      if (buttonText) {\n        buttonText.textContent = \"Adding...\";\n      }\n\n      try {\n        const response = await fetch(\n          createStoreUrl(\"cart/add.js\"),\n          {\n            method:\"POST\",\n            headers:{\n              \"Content-Type\":\"application/json\",\n              \"Accept\":\"application/json\",\n              \"X-Requested-With\":\"XMLHttpRequest\"\n            },\n            body:JSON.stringify({\n              items:[\n                {\n                  id:variantId,\n                  quantity:1\n                }\n              ]\n            })\n          }\n        );\n\n        const data = await response.json();\n\n        if (!response.ok) {\n          throw new Error(\n            data.description ||\n            data.message ||\n            \"This product could not be added.\"\n          );\n        }\n\n        button.classList.remove(\"is-loading\");\n        button.classList.add(\"is-added\");\n\n        if (buttonText) {\n          buttonText.textContent = \"Added\";\n        }\n\n        showToast(\n          productTitle + \" added to your cart.\",\n          false\n        );\n\n        window.setTimeout(async function () {\n          const cart = await fetchCurrentCart();\n\n          if (cart) {\n            updateThemeCartCount(cart.item_count);\n            notifyThemeAboutCart(cart);\n          }\n        }, 300);\n\n        window.setTimeout(function () {\n          button.classList.remove(\"is-added\");\n\n          if (buttonText) {\n            buttonText.textContent = originalText;\n          }\n        }, 1900);\n\n      } catch (error) {\n        button.classList.remove(\"is-loading\");\n\n        if (buttonText) {\n          buttonText.textContent = originalText;\n        }\n\n        showToast(\n          error.message ||\n          \"This product could not be added.\",\n          true\n        );\n      }\n    }\n\n    previousButton.addEventListener(\n      \"click\",\n      function () {\n        moveToPreviousProduct();\n        startAutoplay();\n      }\n    );\n\n    nextButton.addEventListener(\n      \"click\",\n      function () {\n        moveToNextProduct();\n        startAutoplay();\n      }\n    );\n\n    root.addEventListener(\n      \"click\",\n      function (event) {\n        const addButton = event.target.closest(\n          \".hn-fresh-carousel__add\"\n        );\n\n        if (\n          !addButton ||\n          addButton.disabled\n        ) {\n          return;\n        }\n\n        addProductToCart(addButton);\n      }\n    );\n\n    viewport.addEventListener(\n      \"mouseenter\",\n      stopAutoplay\n    );\n\n    viewport.addEventListener(\n      \"mouseleave\",\n      startAutoplay\n    );\n\n    viewport.addEventListener(\n      \"focusin\",\n      stopAutoplay\n    );\n\n    viewport.addEventListener(\n      \"focusout\",\n      startAutoplay\n    );\n\n    viewport.addEventListener(\n      \"touchstart\",\n      function (event) {\n        touchStartX =\n          event.changedTouches[0].screenX;\n\n        stopAutoplay();\n      },\n      {\n        passive:true\n      }\n    );\n\n    viewport.addEventListener(\n      \"touchend\",\n      function (event) {\n        touchEndX =\n          event.changedTouches[0].screenX;\n\n        const swipeDistance =\n          touchStartX - touchEndX;\n\n        if (Math.abs(swipeDistance) > 45) {\n          if (swipeDistance > 0) {\n            moveToNextProduct();\n          } else {\n            moveToPreviousProduct();\n          }\n        }\n\n        startAutoplay();\n      },\n      {\n        passive:true\n      }\n    );\n\n    window.addEventListener(\n      \"resize\",\n      function () {\n        window.clearTimeout(resizeTimer);\n\n        resizeTimer = window.setTimeout(\n          updateCardSizes,\n          120\n        );\n      },\n      {\n        passive:true\n      }\n    );\n\n    document.addEventListener(\n      \"visibilitychange\",\n      function () {\n        if (document.hidden) {\n          stopAutoplay();\n        } else {\n          startAutoplay();\n        }\n      }\n    );\n\n    if (\"IntersectionObserver\" in window) {\n      const observer = new IntersectionObserver(\n        function (entries) {\n          entries.forEach(function (entry) {\n            carouselIsVisible =\n              entry.isIntersecting;\n\n            if (carouselIsVisible) {\n              startAutoplay();\n            } else {\n              stopAutoplay();\n            }\n          });\n        },\n        {\n          threshold:.12\n        }\n      );\n\n      observer.observe(root);\n    }\n\n    toastCartLink.href =\n      createStoreUrl(\"cart\");\n\n    fetchProducts()\n      .then(function (fetchedProducts) {\n        products = sortNewestProducts(\n          fetchedProducts\n        ).slice(0, maximumProducts);\n\n        productCount = products.length;\n\n        if (!productCount) {\n          loading.hidden = true;\n          emptyMessage.hidden = false;\n          controls.hidden = true;\n          return;\n        }\n\n        renderProducts();\n      })\n      .catch(function (error) {\n        console.error(\n          \"Hertha Nest carousel error:\",\n          error\n        );\n\n        loading.hidden = true;\n        emptyMessage.hidden = false;\n        controls.hidden = true;\n\n        emptyMessage.textContent =\n          \"The newest products could not be loaded.\";\n      });\n  }\n\n  function initialiseAllFreshCarousels(scope) {\n    const searchArea = scope || document;\n\n    searchArea\n      .querySelectorAll(\".hn-fresh-carousel\")\n      .forEach(function (carousel) {\n        initialiseFreshCarousel(carousel);\n      });\n  }\n\n  initialiseAllFreshCarousels(document);\n\n  document.addEventListener(\n    \"shopify:section:load\",\n    function (event) {\n      initialiseAllFreshCarousels(event.target);\n    }\n  );\n})();\n</script>"
      }
    },
