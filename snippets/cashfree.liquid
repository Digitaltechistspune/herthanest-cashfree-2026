<script>
  window.storeShopifyDomain = {{ shop.permanent_domain | json }};
  window.Shopify = {
    ...window.Shopify,
    shop: window.storeShopifyDomain,
  };
</script>

<script>
  (() => {
    try {
      "use strict";

      const cfButtonUniqueClass = "cf-occ-btn";
      const cfHiddenClass = "cf-buy-now-hidden";
      const revertLoaderTime = 6500;

      const ctaButtonAllowedTypes = ["BUTTON", "A", "INPUT"];
      const checkoutButtonAllowedText = ["checkout", "placeorder"];
      const buyNowButtonAllowedText = ["buynow", "buyitnow"];

      const cfProductContext = {
        isProductPage: {% if request.page_type == 'product' and product %}true{% else %}false{% endif %},
        fallbackAvailable: {% if request.page_type == 'product' and product %}{{ product.available | json }}{% else %}true{% endif %},
        selectedVariantId: {% if request.page_type == 'product' and product %}{{ product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %},
        variants: {
          {% if request.page_type == 'product' and product %}
            {% for variant in product.variants %}
              "{{ variant.id }}": {{ variant.available | json }}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          {% endif %}
        }
      };

      let cfOneClickThemeSetupDone = false;
      let cfThemeScriptPromise = null;
      let refreshQueued = false;

      const normalizeText = (text) => {
        return text ? text.replace(/\s/g, "").toLowerCase() : "";
      };

      const getCurrentVariantId = () => {
        try {
          const productFormInput = document.querySelector('form[action*="/cart/add"] [name="id"]');

          if (productFormInput && productFormInput.value) {
            return String(productFormInput.value);
          }

          const urlVariant = new URLSearchParams(window.location.search).get("variant");

          if (urlVariant) {
            return String(urlVariant);
          }

          if (cfProductContext.selectedVariantId) {
            return String(cfProductContext.selectedVariantId);
          }

          return null;
        } catch (err) {
          return null;
        }
      };

      const isCurrentProductAvailable = () => {
        if (!cfProductContext.isProductPage) {
          return true;
        }

        const variantId = getCurrentVariantId();

        if (
          variantId &&
          Object.prototype.hasOwnProperty.call(cfProductContext.variants, variantId)
        ) {
          return cfProductContext.variants[variantId] === true;
        }

        return cfProductContext.fallbackAvailable === true;
      };

      const isBuyNowButton = (button) => {
        return button && button.dataset && button.dataset.function === "initBuyNow";
      };

      const hideBuyNowButton = (button) => {
        if (!button) return;

        button.classList.add(cfHiddenClass);
        button.setAttribute("aria-hidden", "true");
        button.setAttribute("tabindex", "-1");

        if ("disabled" in button) {
          button.disabled = true;
        }
      };

      const showBuyNowButton = (button) => {
        if (!button) return;

        button.classList.remove(cfHiddenClass);
        button.removeAttribute("aria-hidden");
        button.removeAttribute("tabindex");

        if ("disabled" in button) {
          button.disabled = false;
        }
      };

      const refreshBuyNowButtons = () => {
        if (!cfProductContext.isProductPage) {
          return;
        }

        const isAvailable = isCurrentProductAvailable();
        const buyNowButtons = document.querySelectorAll(
          "." + cfButtonUniqueClass + '[data-function="initBuyNow"]'
        );

        buyNowButtons.forEach((button) => {
          if (isAvailable) {
            showBuyNowButton(button);
          } else {
            hideBuyNowButton(button);
          }
        });
      };

      const queueRefreshBuyNowButtons = () => {
        if (refreshQueued) return;

        refreshQueued = true;

        window.requestAnimationFrame(() => {
          refreshQueued = false;
          refreshBuyNowButtons();
        });
      };

      const displayLoader = (button) => {
        if (!button) return;

        if (button.nodeName === "INPUT") {
          button.dataset.originalText = button.value;
          button.value = "";
        } else {
          button.dataset.originalText = button.innerHTML;
          button.innerHTML = `<div id="cf-loader-ring"><div>&nbsp;</div><div>&nbsp;</div><div>&nbsp;</div><div>&nbsp;</div></div>`;
        }

        button.classList.add("cf-loader");

        if ("disabled" in button) {
          button.disabled = true;
        }
      };

      const revertLoader = (button) => {
        if (!button) return;

        if (button.nodeName === "INPUT") {
          button.value = button.dataset.originalText || button.value;
        } else {
          button.innerHTML = button.dataset.originalText || button.innerHTML;
        }

        button.classList.remove("cf-loader");

        if ("disabled" in button) {
          button.disabled = false;
        }

        queueRefreshBuyNowButtons();
      };

      const loadCfThemeScript = () => {
        if (window.CashfreeOcc) {
          return Promise.resolve();
        }

        if (cfThemeScriptPromise) {
          return cfThemeScriptPromise;
        }

        cfThemeScriptPromise = new Promise((resolve, reject) => {
          const existingScript = document.getElementById("zecpe-theme-script");

          if (existingScript) {
            existingScript.addEventListener("load", resolve);
            existingScript.addEventListener("error", reject);
            return;
          }

          const script = document.createElement("script");
          script.type = "text/javascript";
          script.src = "https://shopify-checkout.cashfree.com/bundle.js";
          script.id = "zecpe-theme-script";
          script.async = true;

          script.onload = resolve;
          script.onerror = reject;

          document.head.appendChild(script);
        });

        return cfThemeScriptPromise;
      };

      const checkButtonMatch = (node, allowedText) => {
        if (!node || !ctaButtonAllowedTypes.includes(node.nodeName)) {
          return false;
        }

        const nodeText = normalizeText(node.textContent);
        const nodeValue = normalizeText(node.value);

        return allowedText.some((text) => {
          return nodeText.includes(text) || nodeValue.includes(text);
        });
      };

      const setupButton = (button) => {
        if (!button || button.classList.contains(cfButtonUniqueClass)) {
          return;
        }

        if (checkButtonMatch(button, checkoutButtonAllowedText)) {
          button.classList.add(cfButtonUniqueClass);
          button.setAttribute("data-function", "initCheckout");
          return;
        }

        if (checkButtonMatch(button, buyNowButtonAllowedText)) {
          button.classList.add(cfButtonUniqueClass);
          button.setAttribute("data-function", "initBuyNow");

          if (cfProductContext.isProductPage && !isCurrentProductAvailable()) {
            hideBuyNowButton(button);
          }
        }
      };

      const scanButtons = (root = document) => {
        const buttons = [];

        if (
          root instanceof Element &&
          ctaButtonAllowedTypes.includes(root.nodeName)
        ) {
          buttons.push(root);
        }

        if (root.querySelectorAll) {
          buttons.push(...root.querySelectorAll("button, a, input"));
        }

        buttons.forEach(setupButton);
        queueRefreshBuyNowButtons();
      };

      const initEventListeners = () => {
        document.addEventListener(
          "click",
          async (event) => {
            const button = event.target.closest(
              "." + cfButtonUniqueClass + "[data-function]"
            );

            if (!button) return;

            if (
              cfProductContext.isProductPage &&
              isBuyNowButton(button) &&
              !isCurrentProductAvailable()
            ) {
              event.preventDefault();
              event.stopPropagation();
              event.stopImmediatePropagation();
              hideBuyNowButton(button);
              return;
            }

            event.preventDefault();
            event.stopPropagation();
            event.stopImmediatePropagation();

            displayLoader(button);

            setTimeout(() => {
              revertLoader(button);
            }, revertLoaderTime);

            try {
              await loadCfThemeScript();

              if (!window.CashfreeOcc) {
                revertLoader(button);
                return;
              }

              if (button.dataset.function === "initCheckout") {
                window.CashfreeOcc.initCheckout(button);
              }

              if (button.dataset.function === "initBuyNow") {
                window.CashfreeOcc.initBuyItNow(button);
              }
            } catch (err) {
              revertLoader(button);
              console.error("Cashfree script loading failed:", err);
            }
          },
          true
        );

        if (cfProductContext.isProductPage) {
          document.addEventListener(
            "change",
            (event) => {
              if (
                event.target.matches("select, input") ||
                event.target.closest('form[action*="/cart/add"]')
              ) {
                setTimeout(queueRefreshBuyNowButtons, 120);
              }
            },
            true
          );

          document.addEventListener(
            "click",
            (event) => {
              if (
                event.target.closest("variant-selects") ||
                event.target.closest(".product-form") ||
                event.target.closest('form[action*="/cart/add"]') ||
                event.target.closest("[data-option-position]")
              ) {
                setTimeout(queueRefreshBuyNowButtons, 120);
              }
            },
            true
          );
        }
      };

      const automateThemeSetup = () => {
        if (cfOneClickThemeSetupDone) return;

        cfOneClickThemeSetupDone = true;

        scanButtons(document);

        const targetNode = document.body;

        if (!targetNode) return;

        const observer = new MutationObserver((mutationsList) => {
          mutationsList.forEach((mutation) => {
            if (mutation.type !== "childList") return;

            mutation.addedNodes.forEach((node) => {
              if (node instanceof Element) {
                scanButtons(node);
              }
            });
          });
        });

        observer.observe(targetNode, {
          childList: true,
          subtree: true
        });
      };

      window.addEventListener("DOMContentLoaded", () => {
        automateThemeSetup();
        initEventListeners();
        queueRefreshBuyNowButtons();
      });

      document.addEventListener("shopify:section:load", () => {
        setTimeout(() => {
          scanButtons(document);
          queueRefreshBuyNowButtons();
        }, 150);
      });
    } catch (err) {
      console.error("Cashfree theme setup error:", err);
    }
  })();
</script>

<style>
  .cf-buy-now-hidden {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    width: 0 !important;
    min-width: 0 !important;
    max-width: 0 !important;
    height: 0 !important;
    min-height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
    outline: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  #cf-loader-ring {
    position: relative;
    width: 24px;
    height: 30px;
    place-items: center;
    text-align: center;
    max-height: 100%;
    margin: 0 auto;
  }

  #cf-loader-ring div {
    box-sizing: border-box;
    display: block;
    width: 24px;
    position: absolute;
    height: 24px;
    margin: 3px;
    border: 3px solid #fff;
    border-radius: 50%;
    animation: cf-loader-ring 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
    border-color: #fff transparent transparent transparent;
  }

  #cf-loader-ring div:nth-child(1) {
    animation-delay: -0.45s;
  }

  #cf-loader-ring div:nth-child(2) {
    animation-delay: -0.3s;
  }

  #cf-loader-ring div:nth-child(3) {
    animation-delay: -0.15s;
  }

  @keyframes cf-loader-ring {
    0% {
      transform: rotate(0deg);
    }

    100% {
      transform: rotate(360deg);
    }
  }
</style>