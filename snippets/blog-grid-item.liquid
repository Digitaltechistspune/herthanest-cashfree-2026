{%- liquid
  assign ratio = 1
  if article.image and settings.blog_image_ratio == 'portrait'
    assign ratio = 1.34
  elsif article.image and settings.blog_image_ratio == 'adapt'
    assign ratio = article.image.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
-%}
<div class="blog-block">
  <div class="blog-post-image">
    <a href="{{ article.url }}" class="blog-img ratio" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
      {%- if article.image -%}
      <img
      srcset="
        {%- if article.image.src.width >= 165 -%}{{ article.image.src | image_url: width: 165 }} 165w,{%- endif -%}
        {%- if article.image.src.width >= 360 -%}{{ article.image.src | image_url: width: 360 }} 360w,{%- endif -%}
        {%- if article.image.src.width >= 533 -%}{{ article.image.src | image_url: width: 533 }} 533w,{%- endif -%}
        {%- if article.image.src.width >= 720 -%}{{ article.image.src | image_url: width: 720 }} 720w,{%- endif -%}
        {{ article.image.src | image_url }} {{ article.image.src.width }}w
      "
      src="{{ article.image.src | image_url: width: 720 }}"
      data-src="{{ article.image.src | image_url: width: 720 }}"
      alt="{{ article.image.src.alt | escape }}"
      class="img-fluid lazyload"
      width="{{ article.image.src.width }}"
      height="{{ article.image.src.width | divided_by: article.image.src.aspect_ratio }}"
      decoding="async"
      loading="lazy"
      sizes="(min-width: 1920px) {{ '1920' | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)">
      {%- else -%}
      {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
      {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
      {%- endif -%}
    </a>
    <div class="title-wrap">
      <a href="{{ article.url }}" class="blog-title">{{ article.title | truncate: 21 }}</a>
    </div>
  </div>
  <div class="blog-post-content">
    <div class="tag-block">
      <ul class="post-tag">
        {% for tag in article.tags %}
        <li><span>{{ tag }}</span></li>
        {% break %}
        {% endfor %}
      </ul>
    </div>
    <div class="content-wrap">
      <a href="{{ article.url }}" class="blog-title">{{ article.title | truncate: 21 }}</a>
      <p class="blog-desc">{{ article.content | strip_html | strip | truncate: 35 }}</p>
    </div>
    <div class="post-btn">
      <a class="read-more" href="{{ article.url }}"><span class="icon"><i class="feather-arrow-right"></i></span></a>
    </div>
  </div>
</div>