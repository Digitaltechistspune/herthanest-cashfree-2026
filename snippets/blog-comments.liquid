<div class="review_comment">
  <div class="cmt-tit-count">
    <h6 class="comment-title">
      <span class="cmt-title">{{ section.settings.article_cmt }}</span>
      <span class="cmt-count">({{ article.comments_count }})</span>
    </h2>
  </div>
  <div class="cmt-info-wrap">
    {% for comment in article.comments %}
    <div class="comment-info">
      <div class="comment-avtar">
        <div class="review-name">
          <span class="avtar-cmt">
            {% if section.settings.article_avtar_enable %}
            <i class="fa fa-user"></i>
            {% else %}
            <span class="cmt-auth">{{ comment.author | slice: 0, 2 }}</span>
            {% endif %}
          </span>
        </div>
        <div class="review-info">
          <span class="cmt-authr">{{ comment.author }}</span>
          <span class="time">{{ comment.created_at | date: "%b %d, %Y" }}</span>
        </div>
      </div>
      <div class="comment-content">
        <div class="comment-desc">
          {{ comment.content }}
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
<style>
  .cmt-tit-count h6 {
    font-size: 18px;
    position: relative;
  }
  .cmt-info-wrap .comment-info {
    margin-top: 23px;
  }
  .cmt-info-wrap .comment-info:first-child {
    margin-top: 30px;
  }
  .cmt-info-wrap .comment-info .comment-avtar {
    display: flex;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt,
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt .cmt-auth {
    height: 45px;
    width: 45px;
    background-color: var(--font-color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt {
    font-size: 20px;
    color: var(--font-color-header);
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-name .avtar-cmt .cmt-auth {
    font-size: var(--font-size-body);
    font-weight: 600;
    text-transform: uppercase;
    color: #fff;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info {
    {% if settings.enable_rtl %}
    margin-right: 15px;
    {% else %}
    margin-left: 15px;
    {% endif %}
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info span {
    display: block;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info span.cmt-authr {
    color: var(--font-color-header);
    font-size: var(--font-size-body);
    font-weight: 600;
  }
  .cmt-info-wrap .comment-info .comment-avtar .review-info span.time {
    margin-top: 6px;
  }
  .cmt-info-wrap .comment-info .comment-content {
    margin-top: 7px;
  }
</style>