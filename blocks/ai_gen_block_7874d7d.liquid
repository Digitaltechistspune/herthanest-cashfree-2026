<script>
  (function() {
    class ProductTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tabButtons = this.querySelectorAll('.ai-product-tab-button-{{ ai_gen_id }}');
        this.tabPanels = this.querySelectorAll('.ai-product-tab-panel-{{ ai_gen_id }}');
        this.heading = this.querySelector('#ai-tabs-heading-{{ ai_gen_id }}');
        this.addToCartButtons = this.querySelectorAll('.ai-add-to-cart-btn-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupTabs();
        this.setupAddToCart();
      }

      setupTabs() {
        this.tabButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            const tabId = button.getAttribute('data-tab');
            const tabTitle = button.getAttribute('data-title');
            this.switchTab(tabId, tabTitle);
          });
        });
      }

      switchTab(tabId, tabTitle) {
        this.tabButtons.forEach((btn) => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        });

        this.tabPanels.forEach((panel) => {
          panel.classList.remove('active');
        });

        const activeButton = this.querySelector(`[data-tab="${tabId}"]`);
        const activePanel = this.querySelector(`#ai-tab-panel-${tabId}-{{ ai_gen_id }}`);

        if (activeButton && activePanel) {
          activeButton.classList.add('active');
          activeButton.setAttribute('aria-selected', 'true');
          activePanel.classList.add('active');
          
          if (this.heading && tabTitle) {
            this.heading.textContent = tabTitle;
          }
        }
      }

      setupAddToCart() {
        this.addToCartButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const variantId = button.getAttribute('data-product-id');
            
            {% if block.settings.add_to_cart_style == 'popup' %}
              this.addToCartPopup(variantId, button);
            {% else %}
              this.addToCart(variantId, button);
            {% endif %}
          });
        });
      }

      addToCart(variantId, button) {
        const originalText = button.textContent;
        button.textContent = 'Adding...';
        button.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          button.textContent = 'Added!';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
          
          if (window.theme && window.theme.cart) {
            window.theme.cart.refresh();
          }
        })
        .catch(error => {
          button.textContent = 'Error';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        });
      }

      addToCartPopup(variantId, button) {
        const originalText = button.textContent;
        button.textContent = 'Adding...';
        button.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          button.textContent = originalText;
          button.disabled = false;
          
          if (window.theme && window.theme.cart) {
            window.theme.cart.refresh();
          }
          
          alert('Product added to cart!');
        })
        .catch(error => {
          button.textContent = originalText;
          button.disabled = false;
          alert('Error adding product to cart');
        });
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id }});
  })();
</script>

