{% doc %}
  @prompt
    Create a product tabs section for my Shopify theme with these features:
    
    Tabs & Headings
    
    3–6 tabs, each with its own title.
    
    Section heading updates to match the active tab.
    
    Desktop: tabs look like normal/static tabs.
    
    Tab & Product Settings
    
    Add/remove tabs (minimum 3, maximum 6).
    
    Select a collection for each tab.
    
    Set products per tab (e.g. 4, 6, 8, 10).
    
    Set desktop columns per row (3, 4, or 5).
    
    Desktop & Mobile Layout
    
    Desktop: products are shown in a normal grid under the active tab.
    
    Mobile: do NOT use a slider or carousel.
    
    Show all products from the active tab in a vertical scrolling layout, like a standard product listing on most websites.
    
    Products should appear as full, uncropped cards in a clean vertical grid/list (no half-cut products).
    
    Product Card Controls
    
    Toggle “Add to Cart” button on/off.
    
    “Add to Cart” style options: normal, hover effect, or popup.
    
    Card hover/tap animations: none, zoom, or shadow.
    
    Control spacing/gap between product cards.
    
    Section Design & Visibility
    
    Padding and margin controls for the whole section.
    
    Text alignment controls for section heading and tab titles.
    
    Background options: solid color, gradient, or image.
    
    Show/hide this section separately on desktop, tablet, and mobile.
    
    Animation & Basics
    
    Optional animation when switching tabs (fade or slide).
    
    Fully responsive with basic accessible tab titles and clear active tab state.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    {% if block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% elsif block.settings.background_type == 'gradient' %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% elsif block.settings.background_type == 'image' and block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .ai-product-tabs-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-tabs-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-product-tabs-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.tabs_alignment }};
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
    border-bottom: 2px solid {{ block.settings.tab_border_color }};
    padding-bottom: 0;
  }

  .ai-product-tab-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 15px 25px;
    cursor: pointer;
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    transition: all 0.3s ease;
    position: relative;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
  }

  .ai-product-tab-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
  }

  .ai-product-tab-button-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
    border-bottom-color: {{ block.settings.tab_active_border_color }};
  }

  .ai-product-tabs-content-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-tab-panel-{{ ai_gen_id }} {
    display: none;
    {% if block.settings.tab_animation == 'fade' %}
      opacity: 0;
      transition: opacity 0.3s ease;
    {% elsif block.settings.tab_animation == 'slide' %}
      transform: translateX(20px);
      opacity: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
    {% endif %}
  }

  .ai-product-tab-panel-{{ ai_gen_id }}.active {
    display: block;
    {% if block.settings.tab_animation == 'fade' %}
      opacity: 1;
    {% elsif block.settings.tab_animation == 'slide' %}
      transform: translateX(0);
      opacity: 1;
    {% endif %}
  }

  .ai-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    transition: all 0.3s ease;
  }

  {% if block.settings.card_hover_effect == 'zoom' %}
    .ai-product-card-{{ ai_gen_id }}:hover {
      transform: scale(1.05);
    }
  {% elsif block.settings.card_hover_effect == 'shadow' %}
    .ai-product-card-{{ ai_gen_id }}:hover {
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }
  {% endif %}

  .ai-product-card-image-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 15px;
    background-color: #f5f5f5;
  }

  .ai-product-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    padding: 10px 0;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: 16px;
    margin: 0 0 8px;
    color: {{ block.settings.product_title_color }};
  }

  .ai-product-card-title-{{ ai_gen_id }} a {
    text-decoration: none;
    color: inherit;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.product_price_color }};
    margin-bottom: 10px;
  }

  .ai-product-card-actions-{{ ai_gen_id }} {
    {% if block.settings.add_to_cart_style == 'hover' %}
      opacity: 0;
      transition: opacity 0.3s ease;
    {% endif %}
  }

  {% if block.settings.add_to_cart_style == 'hover' %}
    .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card-actions-{{ ai_gen_id }} {
      opacity: 1;
    }
  {% endif %}

  .ai-add-to-cart-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .ai-add-to-cart-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 1024px) {
    .ai-product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }

    .ai-product-tabs-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_tablet }}px;
      padding-bottom: {{ block.settings.padding_bottom_tablet }}px;
    }

    {% if block.settings.hide_on_tablet %}
      .ai-product-tabs-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }

  @media screen and (max-width: 768px) {
    .ai-product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
    }

    .ai-product-tabs-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-product-tabs-nav-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-product-tab-button-{{ ai_gen_id }} {
      padding: 12px 15px;
      font-size: 14px;
    }

    .ai-product-tabs-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    {% if block.settings.hide_on_mobile %}
      .ai-product-tabs-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }

  .ai-product-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }
{% endstyle %}

