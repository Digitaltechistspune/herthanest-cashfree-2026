{% doc %}
  @prompt
    Create a fully customizable Shopify section that displays up to five videos in a horizontal grid row, designed to look like Instagram Reels.
    Each video should appear in a tall-vertical 9:16 reel format, with rounded corners and clean spacing.
    
    Layout Requirements
    
    The layout must support: 5 videos, 4 videos, or 3 videos (user-selectable in the editor).
    
    Videos should appear side-by-side in a single horizontal row on desktop.
    
    On mobile, the section must automatically convert into an Instagram-style swipeable carousel.
    
    Videos must autoplay (if enabled), mute by default, loop (if enabled), and stop on hover (if enabled).
    
    Each video block should support the following upload types:
    
    MP4 upload
    
    Shopify-hosted video
    
    External URL (optional)
    
    Editor Customization Controls
    
    For each individual video item, provide these settings:
    
    Video Settings
    
    Upload video
    
    Toggle autoplay (on/off)
    
    Toggle loop (on/off)
    
    Toggle mute (on/off)
    
    Toggle "pause on hover" (on/off)
    
    Add poster image / thumbnail
    
    Toggle "show play icon"
    
    Link Controls
    
    A field to add a clickable link to the entire video (go to product, collection, or external page).
    
    A toggle to enable/disable a button below the video, with:
    
    Button text
    
    Button link
    
    Button style options (primary/secondary)
    
    Design Controls
    
    Adjust video corner radius
    
    Adjust spacing between videos
    
    Adjust section padding top/bottom
    
    Option to enable a section heading + subheading
    
    Option to enable light/dark background style
    
    Mobile: enable swipe, drag speed, autoplay (for carousel)
    
    Behavior Requirements
    
    Smooth autoplay
    
    Lightweight, optimized video rendering
    
    Pause video when out of viewport
    
    Fully responsive for all screen sizes
    
    Clean, minimal grid look similar to Instagram Reels
    
    Should not break layout if fewer than 5 videos are added
    
    Output Requirements
    
    Generate a liquid section with schema so the user can:
    
    Add/remove video blocks
    
    Choose number of videos to display
    
    Rearrange video order
    
    Edit all settings from theme editor
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reels-block-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-reels-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.videos_per_row }}, 1fr);
    gap: {{ block.settings.video_spacing }}px;
    max-width: 100%;
  }

  .ai-reel-item-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: {{ block.settings.corner_radius }}px;
    overflow: hidden;
    background-color: #000;
  }

  .ai-reel-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-reel-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-reel-link-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .ai-reel-play-icon-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.3s ease;
  }

  .ai-reel-play-icon-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: #000;
    margin-left: 3px;
  }

  .ai-reel-item-{{ ai_gen_id }}:hover .ai-reel-play-icon-{{ ai_gen_id }} {
    opacity: 0.8;
  }

  .ai-reel-button-wrapper-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    width: calc(100% - 40px);
  }

  .ai-reel-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    width: 100%;
    transition: background-color 0.3s ease;
  }

  .ai-reel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-reel-button-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    border: 2px solid {{ block.settings.button_text_color }};
  }

  .ai-reel-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_text_color }};
    color: {{ block.settings.button_bg_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-reels-grid-{{ ai_gen_id }} {
      display: none;
    }

    .ai-reels-carousel-{{ ai_gen_id }} {
      display: block;
      position: relative;
      overflow: hidden;
    }

    .ai-reels-carousel-track-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.video_spacing }}px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 20px;
    }

    .ai-reels-carousel-track-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-reel-item-{{ ai_gen_id }} {
      flex: 0 0 280px;
      scroll-snap-align: center;
    }
  }

  @media screen and (min-width: 990px) {
    .ai-reels-carousel-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-reel-item-{{ ai_gen_id }} {
      flex: 0 0 240px;
    }
  }
{% endstyle %}

