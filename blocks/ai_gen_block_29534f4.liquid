<script>
  (function() {
    class VideoReels{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.videos = [];
        this.observer = null;
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-reel-video-{{ ai_gen_id }}');
        this.setupVideoControls();
        this.setupIntersectionObserver();
      }

      setupVideoControls() {
        this.videos.forEach((video) => {
          const pauseOnHover = video.dataset.pauseOnHover === 'true';

          if (pauseOnHover) {
            video.addEventListener('mouseenter', () => {
              video.pause();
            });

            video.addEventListener('mouseleave', () => {
              video.play();
            });
          }

          video.addEventListener('click', (e) => {
            if (video.paused) {
              video.play();
            } else {
              video.pause();
            }
          });
        });
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const video = entry.target;
            if (entry.isIntersecting) {
              if (video.hasAttribute('autoplay')) {
                video.play().catch(() => {});
              }
            } else {
              video.pause();
            }
          });
        }, options);

        this.videos.forEach((video) => {
          this.observer.observe(video);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('video-reels-{{ ai_gen_id }}', VideoReels{{ ai_gen_id }});

    const block = document.querySelector('.ai-reels-block-{{ ai_gen_id }}');
    if (block && !block.closest('video-reels-{{ ai_gen_id }}')) {
      const wrapper = document.createElement('video-reels-{{ ai_gen_id }}');
      block.parentNode.insertBefore(wrapper, block);
      wrapper.appendChild(block);
    }
  })();
</script>

