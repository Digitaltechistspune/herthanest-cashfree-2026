{% doc %}
  @prompt
    Create a product tabs section for my Shopify theme with these features:
    
    Tabs & Headings
    
    3–6 tabs, each with its own title.
    
    Section heading updates to match the active tab.
    
    Desktop: tabs look like normal/static tabs.
    
    Tab & Product Settings
    
    Add/remove tabs (3–6).
    
    Select a collection for each tab.
    
    Set products per tab (e.g. 4, 6, 8, 10).
    
    Set desktop columns per row (3, 4, or 5).
    
    Desktop & Mobile Layout
    
    Desktop: products shown in a normal grid under the active tab.
    
    Mobile: products inside the active tab are shown in a horizontal slider.
    
    Setting to control mobile products per view: 1 or 2 full cards (no half-cut products).
    
    Product Card Controls
    
    Toggle “Add to Cart” button on/off.
    
    Add to Cart style options: normal, hover effect, or popup.
    
    Card hover/tap animations: none, zoom, or shadow.
    
    Control spacing/gap between product cards.
    
    Section Design & Visibility
    
    Padding and margin controls for the whole section.
    
    Text alignment controls for section heading and tab titles.
    
    Background options: solid color, gradient, or image.
    
    Show/hide this section separately on desktop, tablet, and mobile.
    
    Animation & Basics
    
    Optional animation when switching tabs (fade or slide).
    
    Fully responsive with basic accessible tab titles and active tab state., mobile product per view is not working rest of thinsg are fine 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    {% if block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% elsif block.settings.background_type == 'gradient' %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% elsif block.settings.background_type == 'image' and block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  @media (max-width: 1024px) {
    .ai-product-tabs-{{ ai_gen_id }} {
      {% if block.settings.hide_tablet %}
        display: none !important;
      {% endif %}
    }
  }

  @media (max-width: 768px) {
    .ai-product-tabs-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.6 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.6 }}px;
      {% if block.settings.hide_mobile %}
        display: none !important;
      {% endif %}
    }
  }

  @media (min-width: 1025px) {
    .ai-product-tabs-{{ ai_gen_id }} {
      {% if block.settings.hide_desktop %}
        display: none !important;
      {% endif %}
    }
  }

  .ai-product-tabs-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-tabs-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
    font-size: 32px;
    color: {{ block.settings.heading_color }};
    transition: opacity 0.3s ease;
  }

  @media (max-width: 768px) {
    .ai-product-tabs-heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 20px;
    }
  }

  .ai-product-tabs-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.tabs_alignment }};
    gap: 10px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .ai-product-tabs-nav-{{ ai_gen_id }} {
      margin-bottom: 30px;
      gap: 8px;
    }
  }

  .ai-product-tabs-tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.tab_bg_color }};
    color: {{ block.settings.tab_text_color }};
    border: 2px solid {{ block.settings.tab_border_color }};
    border-radius: {{ block.settings.tab_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 16px;
    font-weight: 500;
  }

  .ai-product-tabs-tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_bg_color }};
    color: {{ block.settings.tab_hover_text_color }};
    border-color: {{ block.settings.tab_hover_border_color }};
  }

  .ai-product-tabs-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg_color }};
    color: {{ block.settings.tab_active_text_color }};
    border-color: {{ block.settings.tab_active_border_color }};
  }

  @media (max-width: 768px) {
    .ai-product-tabs-tab-{{ ai_gen_id }} {
      padding: 10px 18px;
      font-size: 14px;
    }
  }

  .ai-product-tabs-content-{{ ai_gen_id }} {
    display: none;
    {% if block.settings.tab_animation == 'fade' %}
      opacity: 0;
      transition: opacity 0.4s ease;
    {% elsif block.settings.tab_animation == 'slide' %}
      transform: translateX(20px);
      opacity: 0;
      transition: transform 0.4s ease, opacity 0.4s ease;
    {% endif %}
  }

  .ai-product-tabs-content-{{ ai_gen_id }}.active {
    display: block;
    {% if block.settings.tab_animation == 'fade' %}
      opacity: 1;
    {% elsif block.settings.tab_animation == 'slide' %}
      transform: translateX(0);
      opacity: 1;
    {% endif %}
  }

  .ai-product-tabs-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  @media (max-width: 1024px) {
    .ai-product-tabs-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .ai-product-tabs-grid-{{ ai_gen_id }} {
      display: none;
    }
  }

  .ai-product-tabs-mobile-slider-{{ ai_gen_id }} {
    display: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: {{ block.settings.card_gap }}px;
    padding-bottom: 10px;
  }

  .ai-product-tabs-mobile-slider-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  @media (max-width: 768px) {
    .ai-product-tabs-mobile-slider-{{ ai_gen_id }} {
      display: flex;
    }
  }

  .ai-product-tabs-mobile-slide-{{ ai_gen_id }} {
    {% if block.settings.mobile_products_per_view == '1' %}
      flex: 0 0 calc(100% - 20px);
      max-width: calc(100% - 20px);
    {% else %}
      flex: 0 0 calc(50% - {{ block.settings.card_gap | divided_by: 2.0 }}px);
      max-width: calc(50% - {{ block.settings.card_gap | divided_by: 2.0 }}px);
    {% endif %}
    scroll-snap-align: start;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
  }

  {% if block.settings.card_hover_effect == 'zoom' %}
    .ai-product-card-{{ ai_gen_id }}:hover {
      transform: scale(1.05);
    }
  {% elsif block.settings.card_hover_effect == 'shadow' %}
    .ai-product-card-{{ ai_gen_id }}:hover {
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }
  {% endif %}

  .ai-product-card-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 125%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-card-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    padding: 15px;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.card_title_color }};
  }

  .ai-product-card-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 700;
    color: {{ block.settings.card_price_color }};
    margin-bottom: 12px;
  }

  .ai-product-card-price-{{ ai_gen_id }} .compare-price {
    text-decoration: line-through;
    opacity: 0.6;
    font-size: 14px;
    margin-left: 8px;
  }

  .ai-product-card-atc-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px;
    background-color: {{ block.settings.atc_bg_color }};
    color: {{ block.settings.atc_text_color }};
    border: none;
    border-radius: {{ block.settings.atc_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    transition: all 0.3s ease;
    {% if block.settings.atc_style == 'hover' %}
      opacity: 0;
      transform: translateY(10px);
    {% elsif block.settings.atc_style == 'popup' %}
      position: absolute;
      bottom: 15px;
      left: 15px;
      right: 15px;
      opacity: 0;
      transform: translateY(10px);
    {% endif %}
  }

  {% if block.settings.show_add_to_cart == false %}
    .ai-product-card-atc-{{ ai_gen_id }} {
      display: none;
    }
  {% endif %}

  .ai-product-card-atc-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.atc_hover_bg_color }};
    color: {{ block.settings.atc_hover_text_color }};
  }

  {% if block.settings.atc_style == 'hover' or block.settings.atc_style == 'popup' %}
    .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card-atc-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateY(0);
    }
  {% endif %}

  .ai-product-card-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-product-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-tabs-container-{{ ai_gen_id }}">
    <h2 class="ai-product-tabs-heading-{{ ai_gen_id }}" data-heading>
      {% if block.settings.tab_1_enabled %}
        {{ block.settings.tab_1_title }}
      {% elsif block.settings.tab_2_enabled %}
        {{ block.settings.tab_2_title }}
      {% elsif block.settings.tab_3_enabled %}
        {{ block.settings.tab_3_title }}
      {% elsif block.settings.tab_4_enabled %}
        {{ block.settings.tab_4_title }}
      {% elsif block.settings.tab_5_enabled %}
        {{ block.settings.tab_5_title }}
      {% elsif block.settings.tab_6_enabled %}
        {{ block.settings.tab_6_title }}
      {% endif %}
    </h2>

    <div class="ai-product-tabs-nav-{{ ai_gen_id }}">
      {% if block.settings.tab_1_enabled %}
        <button class="ai-product-tabs-tab-{{ ai_gen_id }} active" data-tab="1" data-title="{{ block.settings.tab_1_title }}">
          {{ block.settings.tab_1_title }}
        </button>
      {% endif %}
      {% if block.settings.tab_2_enabled %}
        <button class="ai-product-tabs-tab-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled %}active{% endunless %}" data-tab="2" data-title="{{ block.settings.tab_2_title }}">
          {{ block.settings.tab_2_title }}
        </button>
      {% endif %}
      {% if block.settings.tab_3_enabled %}
        <button class="ai-product-tabs-tab-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled or block.settings.tab_2_enabled %}active{% endunless %}" data-tab="3" data-title="{{ block.settings.tab_3_title }}">
          {{ block.settings.tab_3_title }}
        </button>
      {% endif %}
      {% if block.settings.tab_4_enabled %}
        <button class="ai-product-tabs-tab-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled or block.settings.tab_2_enabled or block.settings.tab_3_enabled %}active{% endunless %}" data-tab="4" data-title="{{ block.settings.tab_4_title }}">
          {{ block.settings.tab_4_title }}
        </button>
      {% endif %}
      {% if block.settings.tab_5_enabled %}
        <button class="ai-product-tabs-tab-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled or block.settings.tab_2_enabled or block.settings.tab_3_enabled or block.settings.tab_4_enabled %}active{% endunless %}" data-tab="5" data-title="{{ block.settings.tab_5_title }}">
          {{ block.settings.tab_5_title }}
        </button>
      {% endif %}
      {% if block.settings.tab_6_enabled %}
        <button class="ai-product-tabs-tab-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled or block.settings.tab_2_enabled or block.settings.tab_3_enabled or block.settings.tab_4_enabled or block.settings.tab_5_enabled %}active{% endunless %}" data-tab="6" data-title="{{ block.settings.tab_6_title }}">
          {{ block.settings.tab_6_title }}
        </button>
      {% endif %}
    </div>

    {% if block.settings.tab_1_enabled %}
      <div class="ai-product-tabs-content-{{ ai_gen_id }} active" data-content="1">
        {% if block.settings.tab_1_collection != blank %}
          <div class="ai-product-tabs-grid-{{ ai_gen_id }}">
            {% for product in block.settings.tab_1_collection.products limit: block.settings.products_per_tab %}
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-card-image-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="600"
                      height="750"
                    >
                  {% else %}
                    <div style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-product-card-info-{{ ai_gen_id }}">
                  <h3 class="ai-product-card-title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>
                  <div class="ai-product-card-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <span class="compare-price">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                  {% if block.settings.show_add_to_cart %}
                    <button class="ai-product-card-atc-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">
                      Add to Cart
                    </button>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
          <div class="ai-product-tabs-mobile-slider-{{ ai_gen_id }}">
            {% for product in block.settings.tab_1_collection.products limit: block.settings.products_per_tab %}
              <div class="ai-product-tabs-mobile-slide-{{ ai_gen_id }}">
                <div class="ai-product-card-{{ ai_gen_id }}">
                  <div class="ai-product-card-image-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="600"
                        height="750"
                      >
                    {% else %}
                      <div style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-product-card-info-{{ ai_gen_id }}">
                    <h3 class="ai-product-card-title-{{ ai_gen_id }}">
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </h3>
                    <div class="ai-product-card-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                      {% if product.compare_at_price > product.price %}
                        <span class="compare-price">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                    </div>
                    {% if block.settings.show_add_to_cart %}
                      <button class="ai-product-card-atc-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">
                        Add to Cart
                      </button>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="ai-product-card-empty-{{ ai_gen_id }}">
            Select a collection for this tab
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.tab_2_enabled %}
      <div class="ai-product-tabs-content-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled %}active{% endunless %}" data-content="2">
        {% if block.settings.tab_2_collection != blank %}
          <div class="ai-product-tabs-grid-{{ ai_gen_id }}">
            {% for product in block.settings.tab_2_collection.products limit: block.settings.products_per_tab %}
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-card-image-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="750">
                  {% else %}
                    <div style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {% endif %}
                </div>
                <div class="ai-product-card-info-{{ ai_gen_id }}">
                  <h3 class="ai-product-card-title-{{ ai_gen_id }}"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                  <div class="ai-product-card-price-{{ ai_gen_id }}">{{ product.price | money }}{% if product.compare_at_price > product.price %}<span class="compare-price">{{ product.compare_at_price | money }}</span>{% endif %}</div>
                  {% if block.settings.show_add_to_cart %}<button class="ai-product-card-atc-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">Add to Cart</button>{% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
          <div class="ai-product-tabs-mobile-slider-{{ ai_gen_id }}">
            {% for product in block.settings.tab_2_collection.products limit: block.settings.products_per_tab %}
              <div class="ai-product-tabs-mobile-slide-{{ ai_gen_id }}">
                <div class="ai-product-card-{{ ai_gen_id }}">
                  <div class="ai-product-card-image-{{ ai_gen_id }}">{% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="750">{% else %}<div style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">{{ 'product-1' | placeholder_svg_tag }}</div>{% endif %}</div>
                  <div class="ai-product-card-info-{{ ai_gen_id }}"><h3 class="ai-product-card-title-{{ ai_gen_id }}"><a href="{{ product.url }}">{{ product.title }}</a></h3><div class="ai-product-card-price-{{ ai_gen_id }}">{{ product.price | money }}{% if product.compare_at_price > product.price %}<span class="compare-price">{{ product.compare_at_price | money }}</span>{% endif %}</div>{% if block.settings.show_add_to_cart %}<button class="ai-product-card-atc-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">Add to Cart</button>{% endif %}</div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="ai-product-card-empty-{{ ai_gen_id }}">Select a collection for this tab</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.tab_3_enabled %}
      <div class="ai-product-tabs-content-{{ ai_gen_id }} {% unless block.settings.tab_1_enabled or block.settings.tab_2_enabled %}active{% endunless %}" data-content="3">
        {% if block.settings.tab_3_collection != blank %}
          <div class="ai-product-tabs-grid-{{ ai_gen_id }}">{% for product in block.settings.tab_3_collection.products limit: block.settings.products_per_tab %}<div class="ai-product-card-{{ ai_gen_id }}"><div class="ai-product-card-image-{{ ai_gen_id }}">{% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="750">{% else %}<div style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">{{ 'product-1' | placeholder_svg_tag }}</div>{% endif %}</div><div class="ai-product-card-info-{{ ai_gen_id }}"><h3 class="ai-product-card-title-{{ ai_gen_id }}"><a href="{{ product.url }}">{{ product.title }}</a></h3><div class="ai-product-card-price-{{ ai_gen_id }}">{{ product.price | money }}{% if product.compare_at_price > product.price %}<span class="compare-price">{{ product.compare_at_price | money }}</span>{% endif %}</div>{% if block.settings.show_add_to_cart %}<button class="ai-product-card-atc-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">Add to Cart</button>{% endif %}</div></div>{% endfor %}</div>
          <div class="ai-product-tabs-mobile-slider-{{ ai_gen_id }}">{% for product in block.settings.tab_3_collection.products limit: block.settings.products_per_tab %}<div class="ai-product-tabs-mobile-slide-{{ ai_gen_id }}"><div class="ai-product-card-{{ ai_gen_id }}"><div class="ai-product-card-image-{{ ai_gen_id }}">{% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="750">{% else %}<div style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">{{ 'product-1' | placeholder_svg_tag }}</div>{% endif %}</div><div class="ai-product-card-info-{{ ai_gen_id }}"><h3 class="ai-product-card-title-{{ ai_gen_id }}"><a href="{{ product.url }}">{{ product.title }}</a></h3><div class="ai-product-card-price-{{ ai_gen_id }}">{{ product.price | money }}{% if product.compare_at_price > product.price %}<span class="compare-price">{{ product.compare_at_price | money }}</span>{% endif %}</div>{% if block.settings.show_add_to_cart %}<button class="ai-product-card-atc-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">Add to Cart</button>{% endif %}</div></div></div>{% endfor %}</div>
        {% else %}
          <div class="ai-product-card-empty-{{ ai_gen_id }}">Select a collection for this tab</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.tab_4_enabled %}
