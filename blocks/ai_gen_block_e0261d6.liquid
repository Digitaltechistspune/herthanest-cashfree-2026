<script>
  (function() {
    class ProductTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('.ai-product-tabs-tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-product-tabs-content-{{ ai_gen_id }}');
        this.heading = this.querySelector('[data-heading]');
      }

      connectedCallback() {
        this.setupTabs();
        this.setupAddToCart();
      }

      setupTabs() {
        this.tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            const tabTitle = tab.getAttribute('data-title');
            
            this.tabs.forEach(t => t.classList.remove('active'));
            this.contents.forEach(c => c.classList.remove('active'));
            
            tab.classList.add('active');
            const content = this.querySelector(`[data-content="${tabId}"]`);
            if (content) {
              setTimeout(() => {
                content.classList.add('active');
              }, 10);
            }
            
            if (this.heading && tabTitle) {
              this.heading.textContent = tabTitle;
            }
          });
        });
      }

      setupAddToCart() {
        const buttons = this.querySelectorAll('.ai-product-card-atc-{{ ai_gen_id }}');
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const productId = button.getAttribute('data-product-id');
            
            if (!productId) return;
            
            const formData = {
              items: [{
                id: productId,
                quantity: 1
              }]
            };
            
            button.textContent = 'Adding...';
            button.disabled = true;
            
            fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
              button.textContent = 'Added!';
              setTimeout(() => {
                button.textContent = 'Add to Cart';
                button.disabled = false;
              }, 2000);
              
              if (window.theme && window.theme.cart) {
                window.theme.cart.refresh();
              }
              
              document.dispatchEvent(new CustomEvent('cart:updated'));
            })
            .catch(error => {
              console.error('Error:', error);
              button.textContent = 'Error';
              setTimeout(() => {
                button.textContent = 'Add to Cart';
                button.disabled = false;
              }, 2000);
            });
          });
        });
      }
    }

    customElements.define('product-tabs-{{ ai_gen_id }}', ProductTabs{{ ai_gen_id }});
  })();
</script>

