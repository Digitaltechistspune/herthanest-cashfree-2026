                  {% if block.settings[video_autoplay_key] %}autoplay{% endif %}
                  {% if block.settings[video_loop_key] %}loop{% endif %}
                  {% if block.settings[video_mute_key] %}muted{% endif %}
                  playsinline
                  {% if block.settings[video_poster_key] != blank %}
                    poster="{{ block.settings[video_poster_key] | image_url: width: 600 }}"
                  {% endif %}
                  data-pause-hover="{{ block.settings[video_pause_hover_key] }}"
                >
                  <source src="{{ block.settings[video_url_key] }}" type="video/mp4">
                </video>
              {% endif %}

              {% if block.settings[video_link_key] != blank %}
                <a href="{{ block.settings[video_link_key] }}" class="ai-reel-link-{{ ai_gen_id }}" aria-label="View video"></a>
              {% endif %}

              {% if block.settings[video_show_play_key] %}
                <div class="ai-reel-play-icon-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              {% endif %}

              {% if block.settings[video_button_text_key] != blank %}
                <a href="{{ block.settings[video_button_link_key] }}" class="ai-reel-button-{{ ai_gen_id }}">
                  {{ block.settings[video_button_text_key] }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</reels-block-{{ ai_gen_id }}>

<script>
  (function() {
    class ReelsBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.videos = this.querySelectorAll('.ai-reel-video-{{ ai_gen_id }}');
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
        this.setupHoverPause();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const video = entry.target;
            if (entry.isIntersecting) {
              if (video.hasAttribute('autoplay')) {
                video.play().catch(() => {});
              }
            } else {
              video.pause();
            }
          });
        }, options);

        this.videos.forEach(video => {
          this.observer.observe(video);
        });
      }

      setupHoverPause() {
        this.videos.forEach(video => {
          const pauseOnHover = video.dataset.pauseHover === 'true';
          if (pauseOnHover) {
            const container = video.closest('.ai-reel-item-{{ ai_gen_id }}');
            if (container) {
              container.addEventListener('mouseenter', () => {
                video.pause();
              });
              container.addEventListener('mouseleave', () => {
                if (video.hasAttribute('autoplay')) {
                  video.play().catch(() => {});
                }
              });
            }
          }
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('reels-block-{{ ai_gen_id }}', ReelsBlock{{ ai_gen_id }});
  })();
</script>

