{% doc %}
  @prompt
    Create a fully customizable Shopify section that shows up to 5 vertical videos in a row, styled like Instagram Reels.
    
    Layout & Behavior
    
    Support 3, 4, or 5 videos (selectable in editor).
    
    Desktop: videos in one horizontal row.
    
    Mobile: swipeable carousel (Instagram-style).
    
    Each video is 9:16 vertical, with rounded corners and clean spacing.
    
    Videos support: autoplay (optional), mute by default, loop (optional), pause on hover (optional).
    
    Pause videos when out of viewport.
    
    Fully responsive and clean, minimal design.
    
    Layout must not break if fewer than 5 videos are added.
    
    Video Source Options per Block
    
    MP4 upload
    
    Shopify-hosted video
    
    External URL (optional)
    
    Optional poster/thumbnail
    
    Toggle “show play icon”
    
    Per-Block Controls
    
    Toggle: autoplay, loop, mute, pause on hover
    
    Clickable link for the whole video (product/collection/external).
    
    Optional button under video with: enable/disable, text, link, style (primary/secondary).
    
    Section Design Controls
    
    Adjust: video corner radius, spacing between videos, padding top/bottom.
    
    Optional section heading + subheading.
    
    Light or dark background style.
    
    Mobile carousel options: enable swipe, drag speed, autoplay.
    
    Device Visibility
    
    Add toggles to show/hide the section on desktop, tablet, and mobile.
    
    Technical
    
    Output as a Liquid section with schema so the merchant can:
    
    Add/remove video blocks
    
    Reorder blocks
    
    Choose video count
    
    Control all settings from the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reels-block-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: #ffffff;
  }

  .ai-reels-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-reels-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-reels-heading-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    margin: 0 0 10px;
    color: #333333;
  }

  .ai-reels-subheading-{{ ai_gen_id }} {
    font-size: 16px;
    color: #666666;
    margin: 0;
  }

  .ai-reels-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 15px;
    margin: 0 auto;
  }

  .ai-reel-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: 12px;
    overflow: hidden;
    background-color: #000000;
  }

  .ai-reel-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-reel-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .ai-reel-play-icon-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.3s ease;
  }

  .ai-reel-play-icon-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: #000000;
    margin-left: 3px;
  }

  .ai-reel-item-{{ ai_gen_id }}:hover .ai-reel-play-icon-{{ ai_gen_id }} {
    opacity: 0.8;
  }

  .ai-reel-button-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    border-radius: 25px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    z-index: 4;
    transition: all 0.3s ease;
    white-space: nowrap;
    background-color: #ffffff;
    color: #000000;
  }

  .ai-reel-button-{{ ai_gen_id }}:hover {
    background-color: #f0f0f0;
  }

  .ai-reel-empty-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  .ai-reel-empty-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    margin-bottom: 12px;
    opacity: 0.8;
  }

  @media screen and (max-width: 1024px) {
    .ai-reels-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .ai-reels-block-{{ ai_gen_id }} {
      padding: 30px 0;
    }

    .ai-reels-heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-reels-subheading-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-reels-grid-{{ ai_gen_id }} {
      display: none;
    }

    .ai-reels-carousel-{{ ai_gen_id }} {
      display: block;
      position: relative;
      overflow: hidden;
    }

    .ai-reels-carousel-wrapper-{{ ai_gen_id }} {
      display: flex;
      gap: 15px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 20px;
    }

    .ai-reels-carousel-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-reels-carousel-wrapper-{{ ai_gen_id }} .ai-reel-item-{{ ai_gen_id }} {
      flex: 0 0 70%;
      scroll-snap-align: center;
    }

    .ai-reel-play-icon-{{ ai_gen_id }} {
      width: 50px;
      height: 50px;
    }

    .ai-reel-play-icon-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }

    .ai-reel-button-{{ ai_gen_id }} {
      padding: 10px 20px;
      font-size: 13px;
    }
  }

  .ai-reels-carousel-{{ ai_gen_id }} {
    display: none;
  }
{% endstyle %}

