            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</video-reels-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoReels{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.videos = [];
        this.observer = null;
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-reel-video-{{ ai_gen_id }}');
        this.setupHoverPause();
        this.setupIntersectionObserver();
      }

      setupHoverPause() {
        this.videos.forEach(video => {
          const pauseOnHover = video.dataset.pauseHover === 'true';
          
          if (pauseOnHover) {
            video.addEventListener('mouseenter', () => {
              video.pause();
            });

            video.addEventListener('mouseleave', () => {
              video.play();
            });
          }
        });
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const video = entry.target;
            
            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        }, options);

        this.videos.forEach(video => {
          this.observer.observe(video);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('video-reels-{{ ai_gen_id }}', VideoReels{{ ai_gen_id }});
  })();
</script>

