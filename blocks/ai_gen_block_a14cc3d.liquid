{% doc %}
  @prompt
    Create a fully customizable Shopify section that displays up to five videos in a horizontal row, styled like Instagram Reels. Each video must use a tall 9:16 aspect ratio with rounded corners and clean spacing.
    
    Layout Requirements
    
    Support 5, 4, or 3 videos (selectable in the editor).
    
    Desktop: videos appear side-by-side in one row.
    
    Mobile: convert into a swipeable Reels-style carousel.
    
    Each video supports MP4 upload, Shopify-hosted video, or external URL.
    
    Videos can autoplay, be muted by default, loop, and pause on hover (all toggles).
    
    Editor Controls (per video block)
    
    Upload/select video.
    
    Toggles: autoplay, loop, mute, pause on hover, show play icon.
    
    Add poster/thumbnail.
    
    Link field for making the entire video clickable (product, collection, or external).
    
    Optional button below video with: enable/disable, button text, button link, and style (primary/secondary).
    
    Design & Section Controls
    
    Adjust video corner radius.
    
    Adjust spacing between videos.
    
    Padding top/bottom for the section.
    
    Optional section heading and subheading.
    
    Light or dark background style.
    
    Mobile carousel settings: enable swipe, drag speed, autoplay.
    
    Device Visibility Controls
    
    Toggles to show/hide the section on Desktop, Tablet, and Mobile.
    
    Behavior & Output
    
    Smooth autoplay, optimized and lightweight.
    
    Pause videos when out of viewport.
    
    Fully responsive and clean grid even with fewer than 5 videos.
    
    Generate a Liquid section with schema so the merchant can add/remove video blocks, choose number of videos, rearrange order, edit all settings, and control visibility per device from the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reels-section-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    background-color: {% if block.settings.background_style == 'dark' %}#1a1a1a{% else %}#ffffff{% endif %};
  }

  .ai-reels-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-reels-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-reels-heading-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    margin: 0 0 10px;
    color: {% if block.settings.background_style == 'dark' %}#ffffff{% else %}#333333{% endif %};
  }

  .ai-reels-subheading-{{ ai_gen_id }} {
    font-size: 16px;
    color: {% if block.settings.background_style == 'dark' %}#cccccc{% else %}#808080{% endif %};
    margin: 0;
  }

  .ai-reels-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.videos_count }}, 1fr);
    gap: {{ block.settings.video_spacing }}px;
    margin-bottom: 0;
  }

  .ai-reels-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 9 / 16;
    border-radius: {{ block.settings.corner_radius }}px;
    overflow: hidden;
    background-color: #000000;
  }

  .ai-reels-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-reels-video-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-reels-play-icon-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-reels-video-wrapper-{{ ai_gen_id }}:hover .ai-reels-play-icon-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-reels-play-icon-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: #333333;
    margin-left: 3px;
  }

  .ai-reels-button-wrapper-{{ ai_gen_id }} {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 30px);
    text-align: center;
  }

  .ai-reels-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 20px;
    text-decoration: none;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .ai-reels-button-primary-{{ ai_gen_id }} {
    background-color: #de7f65;
    color: #ffffff;
  }

  .ai-reels-button-primary-{{ ai_gen_id }}:hover {
    background-color: #333333;
  }

  .ai-reels-button-secondary-{{ ai_gen_id }} {
    background-color: #333333;
    color: #ffffff;
  }

  .ai-reels-button-secondary-{{ ai_gen_id }}:hover {
    background-color: #de7f65;
  }

  @media screen and (max-width: 1024px) {
    .ai-reels-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .ai-reels-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.6 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-reels-heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-reels-subheading-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-reels-grid-{{ ai_gen_id }} {
      display: none;
    }

    .ai-reels-carousel-{{ ai_gen_id }} {
      display: block;
      position: relative;
      overflow: hidden;
    }

    .ai-reels-carousel-track-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.video_spacing }}px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 20px;
    }

    .ai-reels-carousel-track-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-reels-carousel-item-{{ ai_gen_id }} {
      flex: 0 0 280px;
      scroll-snap-align: center;
    }

    .ai-reels-play-icon-{{ ai_gen_id }} {
      opacity: 1;
    }
  }

  @media screen and (min-width: 769px) {
    .ai-reels-carousel-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media screen and (min-width: 1025px) {
    .ai-reels-section-{{ ai_gen_id }}.hide-desktop {
      display: none;
    }
  }

  @media screen and (min-width: 769px) and (max-width: 1024px) {
    .ai-reels-section-{{ ai_gen_id }}.hide-tablet {
      display: none;
    }
  }

  @media screen and (max-width: 768px) {
    .ai-reels-section-{{ ai_gen_id }}.hide-mobile {
      display: none;
    }
  }
{% endstyle %}

