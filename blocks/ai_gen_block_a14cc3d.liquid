<script>
  (function() {
    class VideoReels{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.videos = [];
        this.observer = null;
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-reels-video-{{ ai_gen_id }}');
        this.setupIntersectionObserver();
        this.setupHoverPause();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const video = entry.target;
            if (entry.isIntersecting) {
              if (video.hasAttribute('autoplay') || video.closest('.ai-reels-carousel-{{ ai_gen_id }}')) {
                video.play().catch(() => {});
              }
            } else {
              video.pause();
            }
          });
        }, options);

        this.videos.forEach(video => {
          this.observer.observe(video);
        });
      }

      setupHoverPause() {
        this.videos.forEach(video => {
          if (video.dataset.pauseHover === 'true') {
            const wrapper = video.closest('.ai-reels-video-wrapper-{{ ai_gen_id }}');
            
            wrapper.addEventListener('mouseenter', () => {
              video.pause();
            });

            wrapper.addEventListener('mouseleave', () => {
              video.play().catch(() => {});
            });
          }
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('video-reels-{{ ai_gen_id }}', VideoReels{{ ai_gen_id }});
  })();
</script>

