      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "Ipad pro / Ipad"
    },
    {
      "type": "range",
      "id": "section_padding_top_ipad",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom_ipad",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Backgorund Color"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background color",
      "default": "transparent"
    },
    {
      "type": "checkbox",
      "id": "section_bg_color_enable",
      "label": "Show Backgorund Color",
      "default": true
    },
    {
      "type": "text",
      "id": "section_sub_title",
      "label": "Section sub title",
      "default": "Since 1987 about us"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Choose your own "
    },
    {
      "type": "select",
      "id": "product_views",
      "label": "Slides per view desktop",
      "options": [
        {
          "label": "3 Products",
          "value": "3"
        },
        {
          "label": "4 Products",
          "value": "4"
        },
        {
          "label": "5 Products",
          "value": "5"
        }
      ],
      "default": "5"
    },
    {
      "type": "select",
      "id": "product_views_lg",
      "label": "Slides per view ipad",
      "options": [
        {
          "label": "2 Products",
          "value": "2"
        },
        {
          "label": "3 Products",
          "value": "3"
        },
        {
          "label": "4 Products",
          "value": "4"
        }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "product_views_sm",
      "label": "Slides per view mobile",
      "options": [
        {
          "label": "1 Products",
          "value": "1"
        },
        {
          "label": "2 Products",
          "value": "2"
        }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "collection_category",
      "name": "Category block",
      "settings": [
        {
          "type": "header",
          "content": "Category"
        },
        {
          "type": "collection",
          "id": "slider_category_handle",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "category_img",
          "label": "Category image",
          "info": "Recommended Size: 360x430px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection category"
    }
  ]
}
{% endschema %}
<style>
.collection-cat {
  position: relative;
  overflow: hidden;
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
  {%- if section.settings.section_bg_color_enable -%}
  background-color: {{ section.settings.section_bg_color }};
  {%- endif -%}
}
@media (max-width: 1199px) {
  .collection-cat {
    padding-top: {{ section.settings.section_padding_top_ipad }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_ipad }}px;
  }
}
@media (max-width: 767px) {
  .collection-cat {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}
.collection-cat a.cat-img svg,
.collection-cat a.cat-img img{
  width: 100%;
}
.collection-cat a.cat-img {
  display: flex;
  align-items: center;
  justify-content: center;
}
.collection-cat a.cat-img .text-content {
  text-align: center;
  position: absolute;
  bottom: 25px;
  margin: 0 auto;
  background-color: #fff;
  box-shadow: 0px 0px 15px rgba(51, 51, 51, 0.15);
  padding: 10px 15px;
  min-width: 140px;
}
.collection-cat a.cat-img .text-content h6{
  font-size: var(--font-size-body);
}
@media(max-width: 1199px){
  .collection-cat a.cat-img .text-content h6{
    font-size: var(--font-size-body);
  }
}
@media(max-width: 479px){
  .collection-cat a.cat-img .text-content {
    bottom: 15px;
    right: 15px;
    left: 15px;
  }
}
</style>