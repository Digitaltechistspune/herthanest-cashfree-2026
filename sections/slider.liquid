<section class="slider-content">
  <div class="home-slider swiper" id="home-slider-{{ section.id }}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
      <div class="swiper-slide">
        <div class="slide-image image-{{ block.id }}">
          <div class="container">
            <div class="row">
              <div class="col">
                <div class="slider-info-content">
                  <div class="slider-text-info {% if block.settings.mobile_text_enable %} sm-dnone{% endif %}">
                    {% if block.settings.slider_subtitle != '' %}
                    <span class="sub-title" style="color:{{ block.settings.slider_subtitle_color }};">{{ block.settings.slider_subtitle }}</span>
                    {% endif %}
                    {% if block.settings.slider_title != '' %}
                    <h2 class="title" style="color:{{ block.settings.slider_title_color }};">
                      {{ block.settings.slider_title }}
                    </h2>
                    {% endif %}
                    {% if block.settings.slider_desc != '' %}
                    <p class="desc" style="color:{{ block.settings.slider_desc_color }};">{{ block.settings.slider_desc }}</p>
                    {% endif %}
                    {% if block.settings.slider_button != '' %}
                    <div class="text-btn">
                      <a href="{{ block.settings.slider_button_url }}" class="{% if block.settings.slider_button_style == 'btn-style1' %}btn-style{% elsif block.settings.slider_button_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}">{{ block.settings.slider_button }}</a>
                    </div>
                    {% endif %}
                  </div>
                  <div class="slider-img-info">
                    <div class="img-info">
                      {%- if block.settings.slider_image -%}
                      {{
                        block.settings.slider_image
                        | image_url: width: 1920
                        | image_tag:
                          loading: 'lazy',
                          width: block.settings.slider_image.width,
                          height: block.settings.slider_image.height,
                          class: 'img-fluid lazyload',
                          alt: block.settings.slider_image.alt
                        | escape
                      }}
                      {%- else -%}
                      {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                      {%- endif -%}

                      {% if block.settings.hotspot1_enable %}
                      <div class="st-hotspot s-pro-1" style="top: {{ block.settings.hotspot1_top }}%;left: {{ block.settings.hotspot1_left }}%;">
                        <div class="st-btn"><span class="tag-under"></span></div>
                        <div class="st-content-parent">
                          <div class="tt-hotspot-content">
                            {% assign product = all_products[block.settings.select_pro_1] %}
                            {% if block.settings.select_pro_1 %}
                            {%- liquid
                              if block.settings.select_pro_1_product_view == 'grid'
                                render 'product-grid-item', product: product
                              elsif block.settings.select_pro_1_product_view == 'list'
                                render 'product-grid-list', product: product
                              endif
                            -%}
                            {% else %}
                            {% if block.settings.select_pro_1_product_view == 'list' %}
                            <div class="product-grid-list">
                            {% endif %}
                            <div class="single-product-wrap">
                              <div class="product-image">
                                {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                                {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                              </div>
                              <div class="product-content">
                                <div class="product-title">
                                  <h6>
                                    <a>{{ 'homepage.sections.product_title' | t }}</a>
                                  </h6>
                                </div>
                                <div class="price-box">
                                  <span class="new-price">{{ 'homepage.sections.product_price' | t }}</span>
                                </div>
                              </div>
                            </div>
                            {% if block.settings.select_pro_1_product_view == 'list' %}
                            </div>
                            {% endif %}
                            {% endif %}
                          </div>
                        </div>
                      </div>
                      {% endif %}
                      {% if block.settings.hotspot2_enable %}
                      <div class="st-hotspot s-pro-2" style="top: {{ block.settings.hotspot2_top }}%;left: {{ block.settings.hotspot2_left }}%;">
                        <div class="st-btn"><span class="tag-under"></span></div>
                        <div class="st-content-parent">
                          <div class="tt-hotspot-content">
                            {% assign product = all_products[block.settings.select_pro_2] %}
                            {% if block.settings.select_pro_2 %}
                            {%- liquid
                              if block.settings.select_pro_2_product_view == 'grid'
                                render 'product-grid-item', product: product
                              elsif block.settings.select_pro_2_product_view == 'list'
                                render 'product-grid-list', product: product
                              endif
                            -%}
                            {% else %}
                            {% if block.settings.select_pro_2_product_view == 'list' %}
                            <div class="product-grid-list">
                            {% endif %}
                            <div class="single-product-wrap">
                              <div class="product-image">
                                {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                                {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                              </div>
                              <div class="product-content">
                                <div class="product-title">
                                  <h6>
                                    <a>{{ 'homepage.sections.product_title' | t }}</a>
                                  </h6>
                                </div>
                                <div class="price-box">
                                  <span class="new-price">{{ 'homepage.sections.product_price' | t }}</span>
                                </div>
                              </div>
                            </div>
                            {% if block.settings.select_pro_2_product_view == 'list' %}
                            </div>
                            {% endif %}
                            {% endif %}
                          </div>
                        </div>
                      </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% if section.settings.arrow_enable %}
    <div class="slider-arrow"> 
      <button class="arrow-prev" aria-label="Slider arrow"><i class="feather-arrow-left"></i></button>
      <button class="arrow-next" aria-label="Slider arrow"><i class="feather-arrow-right"></i></button>
    </div>
    {% endif %}
    {% if section.settings.counter_enable %}
    <div class="container slider-info-count"></div>
    {% endif %}
  </div>
</section>

<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#home-slider-{{ section.id }}', {
      slidesPerView: 1,
      loop: false,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      spaceBetween: 0,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {% if section.settings.slider_autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.slider_autoplay_timeout }},
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      {% if section.settings.arrow_enable %}
      navigation: {
        nextEl: ".arrow-next",
        prevEl: ".arrow-prev",
      },
      {% endif %}
      {% if section.settings.counter_enable %}
      pagination: {
        el: ".slider-info-count",
        type: "fraction",
      },
      {% endif %}
    });

    $('.st-btn').on('click', function(){
      $(this).parent('.st-hotspot').toggleClass("open").siblings().removeClass("open");
    });
  });
</script>
