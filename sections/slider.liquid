<style>
.slider-content {
  position: relative;
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
  {% if section.settings.slider_bgimg_enable %}
  background-image: url('{% if section.settings.slider_bgimg %}{{ section.settings.slider_bgimg | image_url }}{% else %}https://dummyimage.com/1920x1080/f7f7f7/999999{% endif %}');
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  {% endif %}
  {% if section.settings.slider_bg_color_enable %}
  background-color: {{ section.settings.slider_bg_color }};
  {% endif %}
}
@media (max-width: 1199px) {
  .slider-content {
    padding-top: {{ section.settings.section_padding_top_ip }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_ip }}px;
  }
}
@media (max-width: 767px) {
  .slider-content {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}
@media (max-width: 600px) {
  .slider-content {
    {% if section.settings.slider_bgimg_enable %}
    background-image: url('{% if section.settings.mobile_slider_bgimg %}{{ section.settings.mobile_slider_bgimg | image_url }}{% else %}https://dummyimage.com/600x970/f7f7f7/999999{% endif %}');
    {% endif %}
  }
}

/* slider text-info css */
.slider-content .home-slider .slide-image .slider-info-content {
  display: flex;
  flex-wrap: wrap;
  margin-top: -50px;
  margin-inline-start: -30px;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-text-info {
  width: calc(41.67% - 30px);
  margin-top: 50px;
  margin-inline-start: 30px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info {
  width: calc(58.33% - 30px);
  margin-top: 50px;
  margin-inline-start: 30px;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info {
  position: relative;
  {%- if settings.enable_rtl -%}
  margin-right: auto;
  {%- else -%}
  margin-left: auto;
  {%- endif -%}
  width: fit-content;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot{
  position: absolute;
  color: #FFFFFF;
  line-height: 1;
  cursor: pointer;
  width: 60px;
  height: 60px;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-btn {
  width: 60px;
  height: 60px;
  font-size: 18px;
  position: absolute;
  top: 0;
  {%- if settings.enable_rtl -%}
  right: 0px;
  {%- else -%}
  left: 0px;
  {%- endif -%}
  z-index: 2;
  background-color: rgb(255 255 255 / 40%);
  display: flex;
  -moz-transition: padding 0.2s linear;
  -o-transition: padding 0.2s linear;
  -webkit-transition: padding 0.2s linear;
  transition: padding 0.2s linear;
  border-radius: 100%;
  justify-content: center;
  align-items: center;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-btn span.tag-under {
  background-color: #FFFFFF;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100%;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-content-parent{
  background-color: #FFFFFF;
  position: absolute;
  top: calc(100% + 30px);
  {%- if settings.enable_rtl -%}
  left: -120px;
  {%- else -%}
  right: -120px;
  {%- endif -%}
  z-index: 3;
  width: 300px;
  border-radius: var(--sti-border-radius);
  box-shadow: 0 0 10px rgb(0 0 0 / 8%);
  opacity: 0;
  visibility: hidden;
  -webkit-transition: opacity .3s ease-in-out, visibility .3s ease-in-out;
  -o-transition: opacity .3s ease-in-out, visibility .3s ease-in-out;
  transition: opacity .3s ease-in-out, visibility .3s ease-in-out;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot.open .st-content-parent {
  opacity: 1;
  visibility: visible;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-content-parent .tt-hotspot-content {
  position: relative;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-content-parent .tt-hotspot-content::before {
  content: '';
  position: absolute;
  top: -40px;
  inset-inline-start: 0;
  inset-inline-end: 0;
  width: 40px;
  margin: 0 auto;
  border-top: 20px solid transparent;
  border-right: 20px solid transparent;
  border-bottom: 20px solid #FFFFFF;
  border-left: 20px solid transparent;
}
.slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-content-parent .tt-hotspot-content .single-product-wrap .product-content .price-box span {
  font-size: 16px;
}
@media(max-width: 1399px) {
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot.s-pro-1 .st-content-parent {
    top: -33px;
    left: -340px;
  }
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot.s-pro-1 .st-content-parent .tt-hotspot-content::before {
    top: unset;
    bottom: 50%;
    transform: translateY(50%);
    inset-inline-start: auto;
    inset-inline-end: -40px;
    border-top: 20px solid transparent;
    border-right: 20px solid transparent;
    border-bottom: 20px solid transparent;
    border-left: 20px solid #FFFFFF;
    height: 40px;
  }
}
@media(max-width: 1199px) {
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot.s-pro-1 {
    top: 15%;
    {%- if settings.enable_rtl -%}
    right: 75%;
    {%- else -%}
    left: 75%;
    {%- endif -%}
  }
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot.s-pro-2 {
    top: 48%;
    {%- if settings.enable_rtl -%}
    right: -2%;
    {%- else -%}
    left: -2%;
    {%- endif -%}
  }
}
@media(max-width: 767px) {
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot,
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-btn {
    width: 40px;
    height: 40px;
  }
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot .st-btn span.tag-under {
    width: 15px;
    height: 15px;
  }
  .slider-content .home-slider .slide-image .slider-info-content .slider-img-info .img-info .st-hotspot.s-pro-1 .st-content-parent {
    top: -40px;
    {%- if settings.enable_rtl -%}
