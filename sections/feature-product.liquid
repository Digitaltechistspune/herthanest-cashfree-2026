{% assign featured_tab_enable = section.settings.featured_tab_enable %}
<section class="feature-product feature-product-{{ section.id }}">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="section-capture tab">
          <div class="section-title">
            {% if section.settings.section_sub_title != '' %}
            <span data-fade-in class="sub-title">{{ section.settings.section_sub_title }}</span>
            {% endif %}
            {% if section.settings.section_title != '' %}
            <h2 data-fade-in>{{ section.settings.section_title }}</h2>
            {% endif %}
          </div>
          {%- if featured_tab_enable -%}
          <ul class="nav nav-tabs" role="tablist">
            {% for block in section.blocks %}
            {% case block.type %}
            {% when 'product_tab' %}
            {% assign category_product = collections[block.settings.tab_product] %}
            <li role="presentation">
              <a data-fade-in class="{% if forloop.first == true %}active show{% endif %}" role="tab" data-bs-toggle="tab" href="#tab-{{ block.id }}">{{ category_product.title | default: 'Collection' }}</a>
            </li>
            {% endcase %}
            {% endfor %}
          </ul>
          {% endif %}
        </div>
        <div class="collection-wrap">
          {%- if featured_tab_enable -%}
          <div class="tab-content tabs">
          {% endif %}
            {% for block in section.blocks %}
            {% case block.type %}
            {% when 'product_tab' %}
            {% assign category_product = collections[block.settings.tab_product] %}
            {%- if featured_tab_enable -%}
            <div class="tab-pane fade{% if forloop.first == true %} active show{% endif %}" id="tab-{{ block.id }}" role="tabpanel">
            {%- endif -%}
              <div class="special-slider swiper" id="pro-{{ block.id }}" data-slides-per-view="{{ section.settings.product_view }}">
                <div class="swiper-wrapper">
                  {% assign product_limit = section.settings.product_limit %}
                  {% for product in category_product.products limit: product_limit %}
                  <div class="swiper-slide">
                    {%- liquid
                      if section.settings.category_special_product_view == 'grid'
                      render 'product-grid-item', product: product
                      elsif section.settings.category_special_product_view == 'list'
                      render 'product-grid-list', product: product
                      endif
                    -%}
                  </div>
                  {% else %}
                  {% for i in (1..product_limit) %}
                  <div class="swiper-slide">
                    <div class="single-product-wrap">
                      <div class="product-image">
                      {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                      </div>
                      <div class="product-content">
                        <div class="product-title">
                          <h6><a >{{ 'homepage.sections.product_title' | t }}</a></h6>
                        </div>
                        <div class="price-box">
                          <span class="new-price">{{ 'homepage.sections.product_price' | t }}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                  {% endfor %}
                  {% endfor %}
                </div>
                {% if section.settings.category_special_button_enable %}
                <div data-fade-in class="collection-button">
                  <a href="{{ category_product.url }}" class="btn {% if section.settings.category_special_button_style == 'btn-style1' %}btn-style{% elsif section.settings.category_special_button_style == 'btn-style2' %}btn-style{% else %}btn-style3{% endif %}">{{ section.settings.category_special_button_text }}</a>
                </div>
                {% endif %}
              </div>
            {%- if featured_tab_enable -%}
            </div>
            {% endif %}
            {% endcase %}
            <div class="swiper-buttons">
              <button class="swiper-prev swiper-prev-{{ section.id }}"><i class="fa fa-angle-left"></i></button>
              <button class="swiper-next swiper-next-{{ section.id }}"><i class="fa fa-angle-right"></i></button>
            </div>
            <div class="swiper-dots">
              <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
            </div>
            <script type="text/javascript">
            addEventListener('DOMContentLoaded', (event) => {
              var swiper = new Swiper('#pro-{{ block.id }}', {
                slidesPerView: {{ section.settings.product_view }},
                grid: {
                  rows: {{ section.settings.category_special_product_col }},
                  fill: 'row' | 'column',
                },
                spaceBetween: 30,
                observer: true,
                observeParents: true,
                watchSlidesProgress: true,
                {%- if settings.enable_rtl -%}
                rtl: true,
                {%- endif -%}
                navigation: {
                  nextEl: '.swiper-next-{{ section.id }}',
                  prevEl: '.swiper-prev-{{ section.id }}',
                },
                pagination: {
                  el: ".swiper-pagination-{{ section.id }}",
                  clickable: true
                },
                autoplay: {
                  delay: 5000,
                  disableOnInteraction: false,
                  pauseOnMouseEnter: true
                },
                speed: 1000,
                breakpoints: {
                  0: {
                    slidesPerView: 1,
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  320: {
                    slidesPerView: 1,
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  360: {
                    slidesPerView: {{ section.settings.product_view_sm }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  540: {
                    slidesPerView: {{ section.settings.product_view_sm }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  640: {
                    slidesPerView: {{ section.settings.product_view_lg }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 12
                  },
                  768: {
                    slidesPerView: {{ section.settings.product_view_lg }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30,
                  },
                  1024: {
                    slidesPerView: {{ section.settings.product_view_lg }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30,
                  },
                  1199: {
                    slidesPerView: {{ section.settings.product_view }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30,
                  },
                  1499: {
                    slidesPerView: {{ section.settings.product_view }},
                    grid: {
                      rows: {{ section.settings.category_special_product_col }},
                      fill: 'row' | 'column',
                    },
                    spaceBetween: 30,
                  }
                }
              });
            });
          </script>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
