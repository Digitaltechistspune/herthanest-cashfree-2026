<style>
.feature-product{
  position: relative;
  overflow: hidden;
}
.feature-product-{{ section.id }} {
  padding-top: {{ section.settings.category_special_padding_top }}px;
  padding-bottom: {{ section.settings.category_special_padding_bottom }}px;
  {% if section.settings.section_bgcolor_enable %}
  background-color: {{ section.settings.section_bgcolor }};
  {% endif %}
}
@media (max-width: 1199px) {
  .feature-product-{{ section.id }} {
    padding-top: {{ section.settings.category_special_padding_top_ip }}px;
    padding-bottom: {{ section.settings.category_special_padding_bottom_ip }}px;
  }
}
@media (max-width: 767px) {
  .feature-product-{{ section.id }} {
    padding-top: {{ section.settings.category_special_padding_top_xs }}px;
    padding-bottom: {{ section.settings.category_special_padding_bottom_xs }}px;
  }
}

.feature-product .tab {
    position: relative;
    display: flex;
    justify-content: space-between;
}
.feature-product .tab ul.nav-tabs {
  display: flex;
  justify-content: center;
  position: relative;
  border-bottom: none;
  margin: 0 0 -15px -15px;
}
.feature-product .tab ul.nav-tabs li {
  margin: 0 0 15px 15px;
}
.feature-product .tab ul.nav-tabs li a{
    color: var(--font-color-header);
    font-size: 16px;
    font-weight: 700;
    position: relative;
    padding: 15px 30px;
    border: var(--sti-border);
    line-height: 1;
    background-color: transparent;
    border-radius: var(--sti-border-radius);
}
.feature-product .tab ul.nav-tabs li a.active{
    background-color: #fff;
}

@media (max-width: 1199px) {
  .feature-product .tab {
    flex-direction: column;
  }
  .feature-product .tab ul.nav-tabs {
    margin: 30px 0 -15px -15px;
  }
  .feature-product .tab ul.nav-tabs li a {
    font-size: var(--font-size-body);
    padding: 13px 20px;
  }
}

{% if section.settings.category_special_button_enable %}
.feature-product-{{ section.id }} .collection-wrap .collection-button {
  margin-top: 100px;
  text-align: center;
}
@media (max-width: 1199px) {
  .feature-product-{{ section.id }} .collection-wrap .collection-button {
    margin-top: 80px;
  }
}
@media (max-width: 767px) {
  .feature-product-{{ section.id }} .collection-wrap .collection-button {
    margin-top: 60px;
  }
}
{% endif %}

/* tab swiper margin css */
{% if section.settings.category_special_product_view == 'grid' %}
.feature-product .collection-wrap {
  margin-top: -15px;
}
.feature-product .collection-wrap .single-product-wrap {
  margin-top: 15px;
}
{% endif %}
.feature-product .collection-wrap .special-slider {
  padding: 15px;
  margin: -15px;
}

/* slider dot css */
.feature-product-{{ section.id }} .collection-wrap .swiper-buttons{
  display: none;
}
.feature-product-{{ section.id }} .collection-wrap .swiper-dots {
  display: none;
  margin-top: 100px;
  line-height: 0;
}
.feature-product-{{ section.id }} .collection-wrap .swiper-dots .swiper-pagination.swiper-pagination-bullets {
  width: unset;
  position: unset;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  {% if settings.enable_rtl %}
  margin: -5px -5px 0px 0px;
  {% else %}
  margin: -5px 0px 0px -5px;
  {% endif %}
}
.feature-product-{{ section.id }} .collection-wrap .swiper-dots .swiper-pagination.swiper-pagination-bullets span {
  width: 10px;
  height: 10px;
  {% if settings.enable_rtl %}
  margin: 5px 5px 0px 0px;
  {% else %}
  margin: 5px 0px 0px 5px;
  {% endif %}
  background-color: transparent;
  border: 1px solid var(--font-color-header);
  border-radius: 100%;
  opacity: 1;
}
.feature-product-{{ section.id }} .collection-wrap .swiper-dots .swiper-pagination.swiper-pagination-bullets span.swiper-pagination-bullet-active {
  background-color: var(--font-color-header);
  border: 1px solid var(--font-color-header);
}
@media (max-width: 1199px) {
  .feature-product-{{ section.id }} .collection-wrap .swiper-dots {
    margin-top: 80px;
  }
}
@media (max-width: 767px) {
  .feature-product-{{ section.id }} .collection-wrap .swiper-dots {
    margin-top: 60px;
  }
}
</style>