{% if template == 'index' %}
<div class="newspopup3 modal fade" id="news-modal3">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body">
        <button type="button" class="close-btn" aria-label="Close btn" data-bs-dismiss="modal"><i class="feather-x"></i></button>
        <div class="newsletter-info">
          <div class="news-banner">
            <a href="{{ section.settings.button_text_url }}">
            {%- if section.settings.news_banner -%}
            {{ section.settings.news_banner | image_url: width: 900, height: 500 | image_tag:
             loading: 'lazy',
             width: section.settings.news_banner.width,
             height: section.settings.news_banner.height,
             class: "img-fluid lazyload desk-img",
             alt: section.settings.news_banner.alt | escape }}
            {%- else -%}
            {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
            {%- endif -%}
            </a>
          </div>
          <div class="subscribe_area">
            <div class="subscribe-content">
              {% if section.settings.news_sub_title != '' %}
              <span class="sub-title" data-fade-in style="color: {{ section.settings.news_sub_title_color }};">{{ section.settings.news_sub_title }}</span>
              {% endif %}
              {% if section.settings.news_title != '' %}
              <div class="big-title">
                <h2 data-fade-in style="color: {{ section.settings.news_title_color }};">{{ section.settings.news_title }}</h2>
                <span data-fade-in style="color: {{ section.settings.news_title_sub_color }};">{{ section.settings.news_title_sub }}</span>
              </div>
              {% endif %}
            </div>
            {% if section.settings.button_enable %}
            <div class="collection-button" data-fade-in>
              <a href="{{ section.settings.button_text_url }}" class="btn {% if section.settings.button_style == 'btn-style1' %}btn-style{% elsif section.settings.button_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}">{{- section.settings.button_text }}</a>
            </div>
            {% endif %}
            <div class="dont-show" data-fade-in>
              <label>
                <input type="checkbox" id="1" class="box3">
                <span class="cust-check"></span>
                <span>{{ section.settings.dont_show_text }}</span>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
  let boxes3 = document.getElementsByClassName('box3').length;
  function save3() {
    for(let i = 1; i <= boxes3; i++){
      var checkbox3 = document.getElementById(String(i));
      localStorage.setItem("news_popup3", checkbox3.checked); 
    }
  }
  for(let i = 1; i <= boxes3; i++){
    if(localStorage.length > 0){
      var checked = JSON.parse(localStorage.getItem("news_popup3"));
      document.getElementById(String(i)).checked = checked;
    }
  }
  window.addEventListener('change', save3);
  addEventListener('DOMContentLoaded', (event) => {
    $(window).on('load',function(){
      setTimeout(function () {
        var popup = localStorage.getItem('news_popup3');
        if(popup == null | popup == "false"){
          $('#news-modal3').modal('show');
        }
      },{{ section.settings.timeout }});
    });
  });
</script>
<style>
   .newspopup3 .modal-dialog {
    max-width: 950px;
  }
   .newspopup3 .modal-content {
    border: none;
    border-radius: 0;
    overflow: hidden;
    background-color: {{ section.settings.modal_bg_color }};
  }
   .newspopup3 .modal-body {
    padding: 0px;
  }
  @media (max-width: 600px) {
     .newspopup3 .modal-dialog {
      max-width: 100%;
      margin: 0px;
      padding: 12px;
    }
  }
  @media (max-width: 479px) {
     .newspopup3 .newsletter-info {
      padding: 0;
    }
  }
  /* newsletter close button css */
  .newspopup3 .modal-body button.close-btn {
    font-size: 20px;
    position: absolute;
    top: 20px;
    {% if settings.enable_rtl %}
    left: 20px;
    {% else %}
    right: 20px;
    {% endif %}
    line-height: 1;
  }
  .newspopup3 .modal-body button.close-btn:hover {
    opacity: 1;
    color: var(--font-color-primary);
  }
  /* Subscribe content css */
  .newspopup3 .newsletter-info {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .newspopup3 .newsletter-info .subscribe_area {
    padding: 30px;
    margin: 0 auto;
    text-align: center;
    width: 50%;
  }
  .newspopup3 .newsletter-info .news-banner {
    width: 50%;
  }
  .newspopup3 .newsletter-info .news-banner a {
    display: block;
  }
  .newspopup3 .newsletter-info .news-banner a svg {
    width: 100%;
  }
  .newspopup3 .newsletter-info .subscribe_area .subscribe-content span.sub-title {
    font-size: 20px;
    font-weight: 400;
    max-width: 58.33%;
    display: block;
    margin: 0 auto;
    margin-bottom: 25px;
   }
   .newspopup3 .newsletter-info .subscribe_area .subscribe-content .big-title{
    padding: 15px 0;
    border-bottom: var(--sti-border);
    border-top: var(--sti-border);
    display: inline-grid;
   }
   .newspopup3 .newsletter-info .subscribe_area .subscribe-content .big-title h2 {
    font-size: 80px;
    line-height: 1;
  }
   .newspopup3 .newsletter-info .subscribe_area .subscribe-content .big-title span {
    font-size: 18px;
    text-transform: uppercase;
    padding-top: 5px;
   }
  .newspopup3 .newsletter-info .subscribe_area .collection-button {
    margin-top: 30px;
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show {
    margin-top: 30px;
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show label {
    position: relative;
    margin-bottom: 0;
    cursor: pointer;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show label span {
    font-size: var(--font-size-body);
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show label input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show label .cust-check {
    width: 17px;
    height: 17px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    border: var(--sti-border);
    overflow: hidden;
    background-color: #fff;
    margin-inline-end: 10px;
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show label .cust-check:after {
    display: none;
    content: "\e92b";
    font-family: feather!important;
    color: #666;
    font-size: 16px;
  }
  .newspopup3 .newsletter-info .subscribe_area .dont-show label input:checked~span.cust-check:after {
    display: block;
  }
  @media (max-width: 1199px) {
    .newspopup3 .modal-dialog {
      max-width: 700px;
    }
    .newspopup3 .newsletter-info .subscribe_area .subscribe-content span.sub-title {
      font-size: 16px;
      max-width: 100%;
      margin-bottom: 15px;
    }
    .newspopup3 .newsletter-info .subscribe_area .subscribe-content .big-title h2 {
      font-size: 40px;
    }
    .newspopup3 .newsletter-info .subscribe_area .subscribe-content .big-title span {
      font-size: var(--font-size-body);
    }
    .newspopup3 .newsletter-info .subscribe_area .collection-button {
      margin-top: 20px;
    }
    .newspopup3 .newsletter-info .subscribe_area .dont-show {
      margin-top: 20px;
    }
  }
  @media (max-width: 600px) {
    .newspopup3 .newsletter-info .subscribe_area,
    .newspopup3 .newsletter-info .news-banner {
      width: 100%;
    }
    .newspopup3 .newsletter-info .subscribe_area {
      padding: 30px 12px;
    }
  }
  @media (max-width: 479px) {
    .newspopup3 .modal-body button.close-btn {
      top: 10px;
      {% if settings.enable_rtl %}
      left: 10px;
      {% else %}
      right: 10px;
      {% endif %}
    }
    .newspopup3 .newsletter-info .subscribe_area .subscribe-content span {
      font-size: 16px;
    }
    .newspopup3 .newsletter-info .subscribe_area .subscribe-content h2 {
      font-size: 20px;
    }
  }
  @media (max-width: 320px) {
  }
</style>
{% endif %}
{% schema %}
{
  "name": "Newsletter popup3",
  "settings": [
    {
      "type": "number",
      "id": "timeout",
      "label": "How many seconds to show when the website is opened",
      "default": 3000,
      "info": "NOTE: 1000 count euqal to (1 second)"
    },
    {
      "type": "color",
      "id": "modal_bg_color",
      "label": "Modal background color",
      "default": "#fff"
    },
    {
      "type": "text",
      "id": "news_sub_title",
      "label": "Newsletter sub title",
      "default": "Gift bundles for every type of person"
    },
    {
      "type": "color",
      "id": "news_sub_title_color",
      "label": "Sub title color",
      "default": "#676767"
    },
    {
      "type": "text",
      "id": "news_title",
      "label": "Newsletter title",
      "default": "40% OFF"
    },
    {
      "type": "color",
      "id": "news_title_color",
      "label": "Title color",
      "default": "#2c2c32"
    },
    {
      "type": "text",
      "id": "news_title_sub",
      "label": "Newsletter title sub",
      "default": "Limited time offers!"
    },
    {
      "type": "color",
      "id": "news_title_sub_color",
      "label": "Newsletter title sub color",
      "default": "#ea8190"
    },
    {
      "type": "text",
      "id": "dont_show_text",
      "label": "Dont show text",
      "default": "Don’t show this popup again"
    },
    {
      "type": "image_picker",
      "id": "news_banner",
      "label": "Newsletter banner",
      "info": "Recommended Size: 715x730px"
    },
    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "button_text_url",
      "label": "Button url"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        {
          "label": "Button Style1",
          "value": "btn-style1"
        },
        {
          "label": "Button Style2",
          "value": "btn-style2"
        },
        {
          "label": "Button Style3",
          "value": "btn-style3"
        }
      ],
      "default": "btn-style2"
    },
    {
      "type": "checkbox",
      "id": "button_enable",
      "label": "Show Collection Button",
      "default": true
    }
  ]
}
{% endschema %}