{%- if section.settings.breadcrumb_enable -%}
{% render 'product-template-breadcrumb', product: product %}
{%- endif -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
<section class="product-details-page" id="MainProduct-{{ section.id }}" data-section="{{ section.id }}" style="--padding-top: {{ section.settings.pro_detail_padding_top }}px;--padding-bottom: {{ section.settings.pro_detail_padding_bottom }}px; --padding-top-lg: {{ section.settings.pro_detail_padding_top_ip }}px;--padding-bottom-lg: {{ section.settings.pro_detail_padding_bottom_ip }}px; --padding-top-xs: {{ section.settings.pro_detail_padding_top_xs }}px;--padding-bottom-xs: {{ section.settings.pro_detail_padding_bottom_xs }}px;">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="pro_details_pos template-1 {% if section.settings.product_pos == 'left' %}pro_details_left_pos{% elsif section.settings.product_pos == 'right' %}pro_details_right_pos{% endif %}">
          <div class="product_detail_slider {% if section.settings.product_img_pos == 'top' or section.settings.product_img_pos == 'bottom' %}product_details_tb{% elsif section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}product_details_lr{% endif %} product_details{% if section.settings.product_pos_sticky_enable %} product_details_sticky{% endif %}">
            <div class="product_detail_img{% if section.settings.product_img_pos == 'top' %} product_detail_img_top{% elsif section.settings.product_img_pos == 'bottom' %} product_detail_img_bottom{% elsif section.settings.product_img_pos == 'left' %} product_detail_img_left{% elsif section.settings.product_img_pos == 'right' %} product_detail_img_right{% endif %}">
              <div class="pro-slider">
                <div class="slider-small swiper slider-small-{{ product.id }}" id="slider-small-{{ product.id }}" {% if settings.enable_rtl %}dir="rtl"{% endif %} data-slides-per-view="5">
                  <div class="swiper-wrapper">
                    {% for media in product.media %}
                    {% assign i = forloop.index %}
                    {%- liquid
                      assign img_url = media | image_url
                      assign ratio = 1
                      if media.preview_image and section.settings.image_ratio == 'portrait'
                        assign ratio = 0.8
                      elsif media.preview_image and section.settings.image_ratio == 'adapt'
                        assign ratio = img_url.aspect_ratio
                      endif
                      if ratio == 0 or ratio == null
                        assign ratio = 1
                      endif
                    -%}
                    <div class="swiper-slide" data-layout="thumb-slider" data-image="{{ media.src | image_url }}" data-image-id="{{ media.id }}" data-index="{{ i }}" {% if section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %} data-slide="vertical" {% else %} data-slide="horizontal"{% endif %}>
  <span class="product-thumb" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
    <img
      src="{{ media.preview_image | image_url: width: 360 }}"
      srcset="
        {% if media.preview_image.width >= 165 %}
          {{ media.preview_image | image_url: width: 165 }} 165w,
        {% endif %}
        {% if media.preview_image.width >= 360 %}
          {{ media.preview_image | image_url: width: 360 }} 360w
        {% endif %}
      "
      sizes="(max-width: 768px) 50vw, 33vw"
      alt="{{ media.alt | escape }}"
      loading="lazy"
      class="product-image"
    />
    {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
      <span class="icon-play"><i class="bi bi-play"></i></span>
    {%- endif -%}
    {%- if media.media_type == 'model' -%}
      <span class="icon-modal"><i class="bi bi-box"></i></span>
    {%- endif -%}
  </span>
</div>

                    {% endfor %}
                  </div>
                </div>
              </div>
              <div class="product_img_top">
                <div class="slider-big swiper slider-big-{{ product.id }}" id="slider-big-{{ product.id }}" {% if settings.enable_rtl %}dir="rtl"{% endif %} data-slides-per-view="1">
                  <div class="swiper-wrapper">
                    {%- for media in product.media -%}
                    {% assign i = forloop.index %}
                    <div class="swiper-slide" data-layout="thumb-slider" data-image="{{ media.src | image_url }}" data-image-id="{{ media.id }}" data-index="{{ i }}">
                      {% render 'media', media: media, section: section %}
                    </div>
                    {%- endfor -%}
                  </div>
                  <div class="big-button button-next"><i class="feather-arrow-right"></i></div>
                  <div class="big-button button-prev"><i class="feather-arrow-left"></i></div>
                </div>
              </div>
            </div>
          </div>
          <div class="product_details_wrap {% if section.settings.product_img_pos == 'top' or section.settings.product_img_pos == 'bottom' %}product_details_tb{% elsif section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}product_details_lr{% endif %} product_details">
            <div class="product_details_info">
              <div class="pro-nprist">
                <div id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}" class="product__info-container">
                  {%- assign product_form_id = 'product-form-' | append: section.id -%}
                  {%- liquid
                    for block in section.blocks
                    case block.type
                    when 'accordion_trust'
  render 'product-accordion-trust', product: product, block: block

                    when 'coupon_copy'
  render 'coupon-copy', product: product

                    when '@app'
                    render 'product-template-app', product: product, block: block
                    when 'custom_html'
                    render 'product-template-custom-html', product: product, block: block
                    when 'product_review'
                    render 'product-template-review', product: product, block: block
                    when 'product_title'
                    render 'product-template-title', product: product, block: block
                    when 'product_price'
                    render 'product-template-price', product: product, block: block, current_variant: current_variant
                    when 'short_description'
                    render 'product-template-short-description', product: product, block: block
                    when 'product_countdown'
                    render 'product-template-countdown', product: product, block: block
                    when 'product_stock_inventory'
                    render 'product-template-stock', product: product, block: block, section: section, current_variant: current_variant
                    when 'product_variant_picker'
                    render 'product-template-variant', product: product, block: block, product_form_id: product_form_id
                    when 'product_buy_buttons'
                    render 'product-template-button', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true
                    when 'product_sku'
                    render 'product-template-sku', product: product, block: block, current_variant: current_variant
                    when 'product_payment'
                    render 'product-template-payment', product: product, block: block
                    when 'product_modal'
                    render 'product-template-modal', product: product, block: block
                    when 'product_delivery_date'
                    render 'product-template-delivery-date', product: product, block: block
                    endcase
                    endfor
                  -%}

                

<!-- Start of Judge.me code -->
<div style='clear:both'></div>
<div id='judgeme_product_reviews'></div>
<!-- End of Judge.me code -->


                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<script>
(function () {
  function initProductSwiper() {
    // ✅ wait only for Swiper (NOT jQuery)
    if (typeof Swiper === 'undefined') {
      return setTimeout(initProductSwiper, 80);
    }

    const thumbsEl = document.getElementById('slider-small-{{ product.id }}');
    const mainEl   = document.getElementById('slider-big-{{ product.id }}');
    if (!thumbsEl || !mainEl) return;

    // ✅ prevent double init
    if (thumbsEl.swiper) thumbsEl.swiper.destroy(true, true);
    if (mainEl.swiper)   mainEl.swiper.destroy(true, true);

    const isVertical = {% if section.settings.product_img_pos == 'left' or section.settings.product_img_pos == 'right' %}true{% else %}false{% endif %};


    // ✅ Thumbs slider
    const thumbsSwiper = new Swiper(thumbsEl, {
      spaceBetween: 15,
      direction: isVertical ? 'vertical' : 'horizontal',
      slidesPerView: isVertical ? 'auto' : 5,

      // ✅ THIS is required for thumb click → main image
      watchSlidesProgress: true,
      slideToClickedSlide: true,
      freeMode: true,

      mousewheel: isVertical,

      breakpoints: {
        0:   { slidesPerView: 3, direction: 'horizontal' },
        480: isVertical
          ? { slidesPerView: 'auto', direction: 'vertical' }
          : { slidesPerView: 5, direction: 'horizontal' }
      }
    });

    // ✅ Main slider
    new Swiper(mainEl, {
      slidesPerView: 1,
      spaceBetween: 0,
      autoHeight: true,
      navigation: {
        nextEl: mainEl.querySelector('.button-next'),
        prevEl: mainEl.querySelector('.button-prev')
      },
      thumbs: { swiper: thumbsSwiper },

      // helps when layout loads late / theme editor
      observer: true,
      observeParents: true
    });

    // ✅ run your jQuery code ONLY if jQuery exists
    if (window.jQuery) {
      window.jQuery(function ($) {
        $(".option-block .op-lb")
          .off("click.product")
          .on("click.product", function () {
            var op_select = $(this).text();
            $(this).parents('.variant-option-block').find('.current-option').html(op_select);
          });
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductSwiper);
  } else {
    initProductSwiper();
  }

  // ✅ important for Shopify theme editor / dynamic reloads
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') initProductSwiper();
  });
})();
</script>

</section>





