<style id="critical-header2-css">
.header2 {
    position: relative;
}
.header2 .header-area .header-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.header2 .header-area .header-main.logo-center .header-element.logo {
    width: 8.33%;
    text-align: center;
}
.header2 .header-area .header-main.logo-center .header-element.megamenu-content,
.header2 .header-area .header-main.logo-center .header-element.right-block-box {
    width: 41.33%;
}
.header2 .header-area .header-main.logo-center .header-element.logo a {
    margin: 0 auto;
}
.header2 .header-area .header-main.logo-left .header-element.megamenu-content {
    width: 50%;
}
.header2 .header-area .header-main.logo-left .header-element.logo,
.header2 .header-area .header-main.logo-left .header-element.right-block-box {
    width: 25%;
}
.header2 .header-area .header-main .header-element.toggle-content {
    display: none;
}
.header2 .header-area .header-main.logo-left .header-element.logo {
    order: -1;
}
@media (max-width: 1199px) {
    .header2 .header-area .header-main {
        padding: 20px 0;
    }
    .header2 .header-area .header-main.logo-center .header-element.right-block-box,
    .header2 .header-area .header-main.logo-left .header-element.right-block-box,
    .header2 .header-area .header-main .header-element.toggle-content,
    .header2 .header-area .header-main.logo-left .header-element.logo,
    .header2 .header-area .header-main.logo-center .header-element.logo {
        width: 33.33%;
    }
    .header2 .header-area .header-element.megamenu-content {
        display: none;
    }
    .header2 .header-area .header-element.logo a {
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .header2 .header-area .header-main.logo-left .header-element.logo {
        order: 0;
    }
    .header2 .header-area .header-main .header-element.toggle-content {
        display: flex;
        color: var(--font-color-header);
        font-size: 18px;
        line-height: 1;
    }
}

/*header top*/
.header2 .header-top {
    border-bottom: 1px solid var(--theme-border-color);
}
.header2 .header-top ul.top-wrap{
    display: flex;
    align-items: center;
}
.header2 .header-top ul.top-wrap li.top-wrapper{
    width: 50%;
}
.header2 .header-top .text-box-left{
    display: flex;
    align-items: center;
}
.header2 .header-top .text-box-right{
    display: flex;
    align-items: center;
    justify-content: flex-end;
}
.header2 .header-top .richtext {
    padding: 8px 0;
    margin-inline-start: 30px;
    padding-inline-start: 30px;
    border-inline-start: 1px solid var(--theme-border-color);
}
.header2 .header-top .richtext:first-child{
    margin-inline-start: 0px;
    padding-inline-start: 0px;
    border-inline-start: none;
}
.header2 .header-top .richtext p,
.header2 .header-top .richtext a{
    font-size: 14px;
    font-weight: 600;
}
.header2 .header-top .search-rap{
    display: none;
}
.header2 .header-top .search-rap-desktop{
    display: block;
    border-inline-start: 1px solid rgba(0,0,0,10%);
    border-inline-end: 1px solid rgba(0,0,0,10%);
}
/* right-block css */
.header2 .right-block-box {
    display: flex;
    justify-content: flex-end;
}
.header2 .right-block-box ul.shop-element {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
}
.header2 .right-block-box ul.shop-element li.side-wrap {
    display: block;
    position: relative;
    padding: 0 15px;
    line-height: 1;
}
.header2 .right-block-box ul.shop-element li.side-wrap.search-wrap .search-rap-desktop2 {
    display: none;
}
.header2 .right-block-box ul.shop-element li.side-wrap.user-wrap,
.header2 .right-block-box ul.shop-element li.side-wrap.wishlist-wrap {
    display: none;
}
.header2 .right-block-box ul.shop-element li.side-wrap:first-child {
    padding-inline-start: 0;
}
.header2 .right-block-box ul.shop-element li.side-wrap:last-child {
    padding-inline-end: 0;
}
.header2 .right-block-box ul.shop-element li.side-wrap a.header-icon,
.header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.cart-icon-wrap {
    position: relative;
    cursor: pointer;
    display: flex;
    align-items: center;
}
.header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.icon {
    font-size: 16px;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--theme-border-color);
    border-radius: 100%;
    font-weight: var(--font-custom-weight-header);
}
.header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.title {
    margin-inline-start: 10px;
    text-transform: uppercase;
}
.header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.wishlist-counter,
.header2 .right-block-box ul.shop-element li.side-wrap a.cart-count .bigcounter {
    position: relative;
    margin-inline-start: 10px;
    padding-inline-start: 10px;
}
.header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.wishlist-counter::before,
.header2 .right-block-box ul.shop-element li.side-wrap a.cart-count .bigcounter::before {
    content: '/';
    position: absolute;
    bottom: 50%;
    transform: translateY(50%);
    inset-inline-start: -5px;
}
.header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.total-price {
    display: none;
}
@media (max-width: 1199px) {
    .header2 .right-block-box ul.shop-element li.side-wrap {
        padding: 0 10px;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap.toggle-wrap {
        display: block;
        line-height: 1;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap.toggle-wrap button {
        font-size: 17px;
        line-height: 1;
    }
    .header2 .header-top .richtext p,
    .header2 .header-top .richtext a {
        font-size: var(--font-size-body);
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.icon {
        width: unset;
        height: unset;
        border: none;
        border-radius: 0px;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.icon,
    .header2 .right-block-box ul.shop-element li.side-wrap a.cart-count span.icon {
        margin-inline-end: 8px;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.wishlist-counter::before,
    .header2 .right-block-box ul.shop-element li.side-wrap a.cart-count .bigcounter::before {
        display: none;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.wishlist-counter,
    .header2 .right-block-box ul.shop-element li.side-wrap a.cart-count .bigcounter {
        margin-inline-start: 0px;
        padding-inline-start: 0px;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.wishlist-counter,
    .header2 .right-block-box ul.shop-element li.side-wrap a.cart-count .bigcounter span {
        background-color: var(--font-color-primary);
        font-size: 10px;
        color: #FFFFFF;
        height: 16px;
        width: 16px;
        position: absolute;
        top: -7px;
        right: 0px;
        margin: 0;
        border-radius: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.cart-icon-wrap {
        align-items: flex-start;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-icon span.title {
        display: none;
        margin-inline-start: 0px;
    }
}
@media (max-width: 991px) {
    .header2 .header-top {
        display: none;
    }
}
@media (max-width: 600px) {
    .header2 .right-block-box ul.shop-element li.side-wrap.search-wrap,
    .header2 .right-block-box ul.shop-element li.side-wrap {
        display: none;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap.cart-wrap {
        display: block;
    }
    .header2 .right-block-box ul.shop-element li.side-wrap a.header-wishlist-btn span.wishlist-counter,
    .header2 .right-block-box ul.shop-element li.side-wrap a.cart-count .bigcounter span {
        top: -5px;
    }
}
</style>
<header class="header header2">
  <!-- headert-top start -->
  <div class="header-area">
    {% if section.settings.header_top_enable %}
    <div class="header-top">
      <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
        <div class="row">
          <div class="col">
            <ul class="top-wrap">
              <li class="top-wrapper">
                <div class="text-box-left">
                  {% if section.settings.richtext1 != '' %}
                    <div class="richtext">
                      {{ section.settings.richtext1 }}
                    </div>
                  {% endif %}
                  {% if section.settings.richtext2 != '' %}
                    <div class="richtext">
                      {{ section.settings.richtext2 }}
                    </div>
                  {% endif %}
                  {% if section.settings.richtext3 != '' %}
                    <div class="richtext">
                      {{ section.settings.richtext3 }}
                    </div>
                  {% endif %}
                </div>
              </li>
              {%- if settings.search_enable -%}
              <li class="top-wrapper">
                <div class="text-box-right search-wrap">
                  {%- render 'search-bar' -%}
                </div>
              </li>
              {%- endif -%}
            </ul>
          </div>
        </div>
      </div>
    </div>
    {%- endif -%}
    <div class="header-main-area">
      <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
        <div class="row">
          <div class="col">
            <div class="header-main {% if section.settings.logo_alignment == 'center' %}logo-center{% else %}logo-left{% endif %}">
              <div class="header-element toggle-content">
                <button class="navbar-toggle" aria-label="Navbar icon" type="button">
                  <i class="feather-menu"></i>
                </button>
              </div>
              <div class="header-element megamenu-content">
                <div class="mainwrap">
                  <ul class="main-menu {% if section.settings.menu_alignment == 'center' %}menu-center{% elsif section.settings.menu_alignment == 'left' %}menu-left{% else %}menu-right{% endif %}">
                    {%- liquid
                      for block in section.blocks
                      case block.type
                      when 'menu_link'
                      render 'menu-link', block: block
                      when 'menu_single'
                      render 'menu-single', block: block
                      when 'menu_sub'
                      render 'menu-sub', block: block
                      when 'menu_shop'
                      render 'menu-shop' block: block
                      when 'menu_collection'
                      render 'menu-collection', block: block
                      when 'menu_product'
                      render 'menu-product', block: block
                      when 'menu_product2'
                      render 'menu-product2', block: block
                      when 'menu_category'
                      render 'menu-category', block: block
                      when 'company_logo'
                      render 'company-logo', block: block
                      when 'menu_shop_banner'
                      render 'menu-shop-banner' block: block
                      endcase
                    endfor 
                    -%}
                  </ul>
                </div>
              </div>
              <div class="header-element logo">
                {%- render 'company-logo' -%}
              </div>
              <div class="header-element right-block-box">
                <div class="header-element right-block-box">


{%- if settings.search_enable -%}
  <button type="button" class="mobile-search-trigger mobile-search-icon" aria-label="Search">
    <i class="feather-search"></i>
  </button>
{%- endif -%}


  {%- render 'header-icon', section: section -%}
</div>

              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- headert-top end -->
  <!-- headert-bottom start -->
  <div class="header-bottom-area">
    <div class="container header-bottom-container">
      <div class="row">
        <div class="col">
          <div class="main-menu-area">
            <div class="box-header">
              <button class="close-box" type="button"><i class="feather-x"></i></button>
            </div>
            <div class="main-menu-wrap">
              <div class="megamenu-content">
                <a href="#" class="browse-cat">
                  <span class="menu-title">{{ section.settings.header_main_menu_title }}</span>
                </a>
                <div class="mainwrap">
                  <ul class="main-menu">
                    {%- liquid
                      for block in section.blocks
                      case block.type
                      when 'menu_link'
                      render 'menu-link', block: block
                      when 'menu_single'
                      render 'menu-single', block: block
                      when 'menu_sub'
                      render 'menu-sub', block: block
                      when 'menu_shop'
                      render 'menu-shop' block: block
                      when 'menu_collection'
                      render 'menu-collection', block: block
                      when 'menu_product'
                      render 'menu-product', block: block
                      when 'menu_product2'
                      render 'menu-product2', block: block
                      when 'menu_category'
                      render 'menu-category', block: block
                      when 'company_logo'
                      render 'company-logo', block: block
                      when 'menu_shop_banner'
                      render 'menu-shop-banner' block: block
                      endcase
                    endfor 
                    -%}
                  </ul>
                </div>
                <div class="locali-block">
                  {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                  <div class="locali-box">
                    <noscript>
                      {%- form 'localization', id: 'HeaderCountryMobileFormNoScript', class: 'localization-form' -%}
                      <select name="country_code" aria-labelledby="HeaderCountryMobileLabelNoScript">
                        {%- for country in localization.available_countries -%}
                        <option value="{{ country.iso_code }}" {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                          {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                        </option>
                        {%- endfor -%}
                      </select>
                      {%- endform -%}
                    </noscript>
                    <localization-form>
                      {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
                      {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
                      {%- endform -%}
                    </localization-form>
                  </div>
                  {% endif %}
                  {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                  <div class="locali-box">
                    <noscript>
                      {%- form 'localization', id: 'HeaderLanguageMobileFormNoScript', class: 'localization-form' -%}
                      <select name="locale_code" aria-labelledby="HeaderLanguageMobileLabelNoScript">
                        {%- for language in localization.available_languages -%}
                        <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {%- if language.iso_code == localization.language.iso_code %} selected{% endif %}>
                          {{ language.endonym_name | capitalize }}
                        </option>
                        {%- endfor -%}
                      </select>
                      {%- endform -%}
                    </noscript>
                    <localization-form>
                      {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
                      {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
                      {%- endform -%}
                    </localization-form>
                  </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- headert-bottom end -->
</header>
{%- render 'search-popup' -%}

<script>
document.addEventListener('click', function (e) {
  const btn = e.target.closest('.mobile-search-trigger');
  if (!btn) return;

  e.preventDefault();

  /* Close mobile menu if it is open */
  const closeBtn = document.querySelector('.header2 .close-box');
  if (closeBtn) closeBtn.click();

  /* Click the ORIGINAL theme search trigger (from header-icon snippet) */
  const triggers = document.querySelectorAll('.header2 a.search-popup, .header2 button.search-popup');
  let originalTrigger = null;

  triggers.forEach((t) => {
    // ignore our mobile button (it does not have search-popup now, but still safe)
    if (t.classList.contains('mobile-search-trigger') || t.classList.contains('mobile-search-icon')) return;
    if (!originalTrigger) originalTrigger = t;
  });

  if (originalTrigger) {
    originalTrigger.click();
    return;
  }

  /* fallback */
  window.location.href = '/search';
});
</script>




{% if settings.account_popup_enable %}
{%- render 'account-modal' -%}
