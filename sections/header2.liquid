<style>
  .header2 .header-area{
    {% if template == 'index' and section.settings.header_transparent_enable %}
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: transparent;
    z-index: 2;
    {% else %}
    {% if section.settings.header_bgcolor_enable %}
    background-color: {{ section.settings.header_bgcolor }};
    {% endif %}
    {% endif %}
  }
  {% if template == 'index' %}
  @media (max-width: 1199px) {
    .header2 .header-area{
      {% if section.settings.header_transparent_enable %}
      position: unset;
      {% if section.settings.header_bgcolor_enable %}
      background-color: {{ section.settings.header_bgcolor }};
      {% endif %}
      {% endif %}
      {% unless section.settings.header_transparent_enable %}
      {% endunless %}
    }
  }
  {% endif %}
  /* sticky menu css */
  {% if section.settings.header_sticky_enable %}
  .header2 .header-area.sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: #FFFFFF;
    z-index: 3;
    box-shadow: 0px 0px 15px rgba(51, 51, 51, 0.15);
  }
  .header2 .header-area.sticky-down {
    transform: translateY(-100%);
  }
  .header2 .header-area.sticky-up {
    transform: translateY(0);
  }
  .header2 .header-area.sticky,
  .header2 .header-area.sticky-down,
  .header2 .header-area.sticky-up {
    -webkit-transition: all 0.3s ease-in-out 0s;
    -o-transition: all 0.3s ease-in-out 0s;
    transition: all 0.3s ease-in-out 0s;
  }
  {% endif %}
  /*=====================================
    menu-text color css
  ======================================*/
  .header2 .search-rap-desktop form input,
  .header2 .search-rap-desktop form input::placeholder,
  .header2 .search-rap-desktop form button,
  .header2 .header-top .richtext p, .header2 .header-top .richtext a {
    {% if template == 'index' %}
    color: {{ section.settings.header_menutext_color }};
    {% else %}
    color: var(--font-color-header);
    {% endif %}
  }
  .header2 .megamenu-content .mainwrap ul.main-menu li.menu-link a.link-title {
    {% if template == 'index' %}
    color: {{ section.settings.header_menutext_color }};
    {% else %}
    color: var(--font-color-header);
    {% endif %}
  }
