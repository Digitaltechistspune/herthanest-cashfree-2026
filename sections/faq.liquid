<section class="faq-page">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="content-qa-banner">
          <div class="faq-sidebar">
            <div class="main-title">
              {% if section.settings.list_sub_title != '' %}
              <span data-fade-in class="sub-title">{{ section.settings.list_sub_title }}</span>
              {% endif %}
              {% if section.settings.list_title != '' %}
              <h2 data-fade-in>{{ section.settings.list_title }}</h2>
              {% endif %}
            </div>
            <div class="contact-text">
              <div class="contact-wrap">
                {% if section.settings.contact_title != '' %}
                <h2 data-fade-in>{{ section.settings.contact_title }}</h2>
                {% endif %}
                <div class="contact-block" data-fade-in>
                  <span class="con-icon"><i class="feather-phone-call"></i></span>
                  <a href="tel:{{ settings.contact }}" class="con-add">{{ settings.contact }}</a>
                </div>
                <div class="contact-block" data-fade-in>
                  <span class="con-icon"><i class="feather-mail"></i></span>
                  <a href="mailto:{{ settings.email }}" class="con-add">{{ settings.email }}</a>
                </div>
              </div>
            </div>
            <div class="faq-link">
              <ul class="link-page" role="tablist">
                {% if section.settings.page_title != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url }}" class="link-other">{{ section.settings.page_title }}</a>
                </li>
                {% endif %}
                {% if section.settings.page_title1 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url1 }}" class="link-other">{{ section.settings.page_title1 }}</a>
                </li>
                {% endif %}
                {% if section.settings.page_title2 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url2 }}" class="link-other">{{ section.settings.page_title2 }}</a>
                </li>
                {% endif %}
                {% if section.settings.page_title3 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url3 }}" class="link-other">{{ section.settings.page_title3 }}</a>
                </li>
                {% endif %}
                {% if section.settings.page_title4 != '' %}
                <li class="presentation">
                  <a data-fade-in href="{{ section.settings.page_title_url4 }}" class="link-other">{{ section.settings.page_title4 }}</a>
                </li>
                {% endif %}
              </ul>
            </div>
          </div>
          <div class="que-ans">
            <div class="accordian-block">
              <div class="main-title">
                {% if section.settings.accordian_title1 != '' %}
                <h2 data-fade-in>{{ section.settings.accordian_title1 }}</h2>
                {% endif %}
              </div>
              <ul id="collapse-faq1">
                {% liquid assign i = 0 %}
                {% for block in section.blocks %}
                {%- case block.type -%}
                {%- when 'accordian1' -%}
                {% assign i = i | plus: 1 %}
                {% if block.settings.accordion_title != '' %}
                  <li data-fade-in>
                    <a href="#collapse-{{ section.id }}-{{ block.id }}-{{ i }}" class="question" data-bs-toggle="collapse" {% if forloop.first %}aria-expanded="true"{% else %}aria-expanded="false"{% endif %}>
                      <h6 class="que">{{ block.settings.accordion_title }}</h6>
                      <span class="que-accordian"><i class="feather-plus"></i></span>
                    </a>
                    <div class="ans-accordian collapse{% if forloop.first %} show{% endif %}" id="collapse-{{ section.id }}-{{ block.id }}-{{ i }}" data-bs-parent="#collapse-faq1">
                      {% if block.settings.accordion_ans1 != '' %}
                      <p>{{ block.settings.accordion_ans1 }}</p>
                      {% endif %}
                      {% if block.settings.accordion_ans2 != '' %}
                      <p>{{ block.settings.accordion_ans2 }}</p>
                      {% endif %}
                    </div>
                  </li>
                  {% endif %}
                {% endcase %}
                {% endfor %}
              </ul>
            </div>
            <div class="accordian-block">
              <div class="main-title">
                {% if section.settings.accordian_title2 != '' %}
                <h2 data-fade-in>{{ section.settings.accordian_title2 }}</h2>
                {% endif %}
              </div>
              <ul id="collapse-faq2">
                {% liquid assign i = 0 %}
