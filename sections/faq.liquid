<style>
.faq-page {
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
  {%- if section.settings.faq_bgcolor_check -%}
  background-color: {{ section.settings.faq_bgcolor }};
  {%- endif -%}
}
@media (max-width: 1199px) {
  .faq-page {
    padding-top: {{ section.settings.section_padding_top_ip }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_ip }}px;
  }
}
@media (max-width: 767px) {
  .faq-page {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}
/* faq grid css */
.faq-page .main-title span.sub-title {
  color: var(--font-color-primary);
  font-size: 16px;
  text-transform: uppercase;
  padding-bottom: 15px;
  font-weight: 600;
}
.faq-page .main-title h2 {
  font-size: 30px;
}
.faq-page .content-qa-banner {
  display: flex;
  flex-wrap: wrap;
  {% if settings.enable_rtl %}
  margin: -30px -60px 0px 0px;
  {% else %}
  margin: -30px 0px 0px -60px;
  {% endif %}
}
.faq-page .content-qa-banner .faq-sidebar{
  width: calc(25% - 60px);
  {% if settings.enable_rtl %}
  border-left: var(--sti-border);
  margin: 30px 60px 0px 0px;
  padding: 0 0 0 30px;
  {% else %}
  border-right: var(--sti-border);
  margin: 30px 0px 0px 60px;
  padding: 0 30px 0 0;
  {% endif %}
}
.faq-page .content-qa-banner .que-ans{
  width: calc(75% - 60px);
  {% if settings.enable_rtl %}
  margin: 30px 60px 0px 0px;
  {% else %}
  margin: 30px 0px 0px 60px;
  {% endif %}
}
@media (max-width: 1199px) {
  .faq-page .content-qa-banner {
    {% if settings.enable_rtl %}
    margin: -30px -30px 0px 0px;
    {% else %}
    margin: -30px 0px 0px -30px;
    {% endif %}
  }
  .faq-page .content-qa-banner .que-ans {
    width: calc(66.67% - 30px);
    {% if settings.enable_rtl %}
    margin: 30px 30px 0px 0px;
    {% else %}
    margin: 30px 0px 0px 30px;
    {% endif %}
  }
  .faq-page .content-qa-banner .faq-sidebar {
    width: calc(33.33% - 30px);
    {% if settings.enable_rtl %}
    margin: 30px 30px 0px 0px;
    {% else %}
    margin: 30px 0px 0px 30px;
    {% endif %}
  }
}
@media (max-width: 767px) {
  .faq-page .content-qa-banner {
    {% if settings.enable_rtl %}
    margin: -30px -12px 0px 0px;
    {% else %}
    margin: -30px 0px 0px -12px;
    {% endif %}
  }
  .faq-page .content-qa-banner .que-ans {
    width: calc(66.67% - 12px);
    {% if settings.enable_rtl %}
    margin: 30px 12px 0px 0px;
    {% else %}
    margin: 30px 0px 0px 12px;
    {% endif %}
  }
  .faq-page .content-qa-banner .faq-sidebar {
    width: calc(33.33% - 12px);
    {% if settings.enable_rtl %}
    margin: 30px 12px 0px 0px;
    {% else %}
    margin: 30px 0px 0px 12px;
    {% endif %}
  }
}
@media (max-width: 600px) {
  .faq-page .content-qa-banner .que-ans,
  .faq-page .content-qa-banner .faq-sidebar {
    width: calc(100% - 12px);
    border: none;
  }
  .faq-page .content-qa-banner .faq-sidebar {
    padding: 0;
  }
}
.faq-page .content-qa-banner .que-ans h6.list-main-title {
  padding-top: 100px;
  color: var(--font-color-secondary);
  font-size: 34px;
  font-weight: 400;
}

.faq-page .content-qa-banner .que-ans h6.list-main-title:first-child {
    padding-top: 0px;
}
.faq-page .que-ans ul {
  margin-top: 60px;
}
.faq-page .que-ans .accordian-block {
  margin-top: 60px;
}
.faq-page .que-ans .accordian-block:empty {
  margin-top: 0;
}
.faq-page .que-ans .accordian-block:first-child {
  margin-top: 0;
}
.faq-page .que-ans ul li {
  margin-top: 23px;
  padding-top: 25px;
  border-top: 1px solid var(--theme-border-color);
}

.faq-page .que-ans ul li:first-child {
  margin-top: 0px;
  padding-top: 0px;
  border-top: none;
}

.faq-page .que-ans ul li a.question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}
.faq-page .que-ans ul li a.question h6.que {
  font-size: var(--font-size-subtitle);
  display: block;
  width: calc(100% - 45px);
  text-transform: uppercase;
  font-weight: var(--font-weight-subtitle);
