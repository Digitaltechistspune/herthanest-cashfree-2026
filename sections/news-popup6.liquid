{% if template == 'index' %}
<div class="newspopup6 modal fade" id="news-modal6">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body">
        {% form 'customer' %}
        <button type="button" class="close-btn" aria-label="Close btn" data-bs-dismiss="modal"><i class="feather-x"></i></button>
        <div class="newsletter-info">
          <div class="news-banner">
            <a href="{{ section.settings.button_text_url }}">
            {%- if section.settings.news_banner -%}
            {{ section.settings.news_banner | image_url: width: 900, height: 500 | image_tag:
             loading: 'lazy',
             width: section.settings.news_banner.width,
             height: section.settings.news_banner.height,
             class: "img-fluid lazyload desk-img",
             alt: section.settings.news_banner.alt | escape }}
            {%- else -%}
            {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
            {%- endif -%}
            </a>
          </div>
          <div class="subscribe_area">
            <div class="subscribe-content">
              {% if section.settings.news_sub_title != '' %}
              <span class="sub-title" data-fade-in style="color: {{ section.settings.news_sub_title_color }};">{{ section.settings.news_sub_title }}</span>
              {% endif %}
              {% if section.settings.news_title != '' %}
              <h2 data-fade-in style="color: {{ section.settings.news_title_color }};">{{ section.settings.news_title }}</h2>
              {% endif %}
            </div>
            <div class="popup-newsletter">
              <div class="subscribe-con">
                {{ form.errors | default_errors }}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="subscribe-block" data-fade-in>
                  <input type="email" name="contact[email]" class="email mail" id="E-mail" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}" autocapitalize="off" required>
                  <div class="email-submit">
                    <button type="submit" class="news-btn" name="commit" id="Subscribe"><i class="feather-mail"></i></button>
                  </div>
                </div>
              </div>
            </div>
            {% if form.posted_successfully? %}
            <p class="text-success" data-fade-in>
              <span class="subscribe-text">{{ section.settings.newsletter_success_text }} <span class="subscribe-code bg-success">{{ section.settings.newsletter_coupan_code }}</span></span>
            </p>
            {% endif %}
            <div class="dont-show" data-fade-in>
              <label>
                <input type="checkbox" id="1" class="box6">
                <span class="cust-check"></span>
                <span>{{ section.settings.dont_show_text }}</span>
              </label>
            </div>
          </div>
        </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
  let boxes6 = document.getElementsByClassName('box6').length;
  function save6() {
    for(let i = 1; i <= boxes6; i++){
      var checkbox6 = document.getElementById(String(i));
      localStorage.setItem("news_popup6", checkbox6.checked); 
    }
  }
  for(let i = 1; i <= boxes6; i++){
    if(localStorage.length > 0){
      var checked = JSON.parse(localStorage.getItem("news_popup6"));
      document.getElementById(String(i)).checked = checked;
    }
  }
  window.addEventListener('change', save6);
  addEventListener('DOMContentLoaded', (event) => {
    $(window).on('load',function(){
      setTimeout(function () {
        var popup = localStorage.getItem('news_popup6');
        if(popup == null | popup == "false"){
          $('#news-modal6').modal('show');
        }
      },{{ section.settings.timeout }});
    });
  });
</script>
<style>
   .newspopup6 .modal-dialog {
    max-width: 950px;
  }
   .newspopup6 .modal-content {
    border: none;
    border-radius: 0;
    overflow: hidden;
    background-color: {{ section.settings.modal_bg_color }};
  }
   .newspopup6 .modal-body {
    padding: 0px;
  }
  @media (max-width: 600px) {
     .newspopup6 .modal-dialog {
      max-width: 100%;
      margin: 0px;
      padding: 12px;
    }
  }
  @media (max-width: 479px) {
     .newspopup6 .newsletter-info {
      padding: 0;
    }
  }
  /* newsletter close button css */
  .newspopup6 .modal-body button.close-btn {
    font-size: 20px;
    position: absolute;
    top: 20px;
    {% if settings.enable_rtl %}
    left: 20px;
    {% else %}
    right: 20px;
    {% endif %}
    line-height: 1;
  }
  .newspopup6 .modal-body button.close-btn:hover {
    opacity: 1;
    color: var(--font-color-primary);
  }
  /* Subscribe content css */
  .newspopup6 .newsletter-info {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .newspopup6 .newsletter-info .subscribe_area {
    padding: 30px 60px;
    margin: 0 auto;
    width: 50%;
  }
  .newspopup6 .newsletter-info .news-banner {
    width: 50%;
  }
  .newspopup6 .newsletter-info .news-banner a {
    display: block;
  }
  .newspopup6 .newsletter-info .news-banner a svg {
    width: 100%;
  }
  .newspopup6 .newsletter-info .subscribe_area .subscribe-content span.sub-title {
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 15px;
   }
  .newspopup6 .newsletter-info .subscribe_area .subscribe-content h2 {
    font-size: 28px;
  }
  .newspopup6 .newsletter-info .subscribe_area .popup-newsletter {
    margin-top: 30px;
  }
  .newspopup6 .newsletter-info .subscribe_area .popup-newsletter .subscribe-con .subscribe-block {
    position: relative;
    display: flex;
  }
  .newspopup6 .newsletter-info .subscribe_area .popup-newsletter .subscribe-con .subscribe-block input {
    width: 100%;
  }
  .newspopup6 .newsletter-info .subscribe_area .popup-newsletter .subscribe-con .subscribe-block .email-submit button {
    color: #fff;
    font-size: 20px;
    height: 50px;
    width: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--font-color-header);
  }
  .newspopup6 .newsletter-info .subscribe_area .popup-newsletter .subscribe-con .subscribe-block .email-submit button:hover {
    background-color: var(--font-color-primary);
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show {
    margin-top: 30px;
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show label {
    position: relative;
    margin-bottom: 0;
    cursor: pointer;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    display: flex;
    align-items: center;
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show label span {
    font-size: var(--font-size-body);
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show label input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show label .cust-check {
    width: 17px;
    height: 17px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    border: var(--sti-border);
    overflow: hidden;
    background-color: #fff;
    margin-inline-end: 10px;
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show label .cust-check:after {
    display: none;
    content: "\e92b";
    font-family: feather!important;
    color: #666;
    font-size: 16px;
  }
  .newspopup6 .newsletter-info .subscribe_area .dont-show label input:checked~span.cust-check:after {
    display: block;
  }

  @media (max-width: 1199px) {
    .newspopup6 .modal-dialog {
      max-width: 700px;
    }
    .newspopup6 .newsletter-info .subscribe_area .subscribe-content span.sub-title {
      font-size: 16px;
      max-width: 100%;
      margin-bottom: 15px;
    }
    .newspopup6 .newsletter-info .subscribe_area .dont-show {
      margin-top: 20px;
    }
    .newspopup6 .newsletter-info .subscribe_area .popup-newsletter {
      margin-top: 15px;
    }
  }
  @media (max-width: 600px) {
    .newspopup6 .newsletter-info .subscribe_area,
    .newspopup6 .newsletter-info .news-banner {
      width: 100%;
    }
    .newspopup6 .newsletter-info .subscribe_area {
      padding: 30px 12px;
    }
  }
  @media (max-width: 479px) {
    .newspopup6 .modal-body button.close-btn {
      top: 10px;
      {% if settings.enable_rtl %}
      left: 10px;
      {% else %}
      right: 10px;
      {% endif %}
    }
    .newspopup6 .newsletter-info .subscribe_area .subscribe-content span {
      font-size: 16px;
    }
    .newspopup6 .newsletter-info .subscribe_area .subscribe-content h2 {
      font-size: 20px;
    }
  }
  @media(max-width: 320px){
    .newspopup .newsletter-info .subscribe_area .popup-newsletter .subscribe-con .subscribe-block {
      flex-direction: column;
    }
    .newspopup .newsletter-info .subscribe_area .popup-newsletter .subscribe-con .subscribe-block button {
      margin-top: 10px;
      width: 100%;
    }
  }
</style>
{% endif %}
{% schema %}
{
  "name": "Newsletter popup6",
  "settings": [
    {
      "type": "number",
      "id": "timeout",
      "label": "How many seconds to show when the website is opened",
      "default": 3000,
      "info": "NOTE: 1000 count euqal to (1 second)"
    },
    {
      "type": "color",
      "id": "modal_bg_color",
      "label": "Modal background color",
      "default": "#fff"
    },
    {
      "type": "text",
      "id": "news_sub_title",
      "label": "Newsletter sub title",
      "default": "Gift bundles for every type of person"
    },
    {
      "type": "color",
      "id": "news_sub_title_color",
      "label": "Sub title color",
      "default": "#676767"
    },
    {
      "type": "text",
      "id": "news_title",
      "label": "Newsletter title",
      "default": "40% OFF"
    },
    {
      "type": "color",
      "id": "news_title_color",
      "label": "Title color",
      "default": "#2c2c32"
    },
    {
      "type": "text",
      "id": "dont_show_text",
      "label": "Dont show text",
      "default": "Don’t show this popup again"
    },
    {
      "type": "image_picker",
      "id": "news_banner",
      "label": "Newsletter banner",
      "info": "Recommended Size: 730x700px"
    }
  ]
}
{% endschema %}