<style>
  .slider-category2 {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    background-color: {{ section.settings.section_bg_color }};
    text-align: center;
  }
  @media (max-width: 1199px) {
    .slider-category2 {
      padding-top: {{ section.settings.section_padding_top_ipad }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_ipad }}px;
    }
  }
  @media (max-width: 767px) {
    .slider-category2 {
      padding-top: {{ section.settings.section_padding_top_xs }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
  }

  .slider-category2 .cat-item-wrap {
    margin-bottom: 60px;
  }
  .slider-category2 .cat-item-wrap .cat-block {
    position: relative;
    padding-bottom: 100%;
    text-align: center;
  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    border-radius: 100%;
  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url::before {
    background-color: var(--extra-color-body);
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: -1;
    border-radius: 100%;
  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url .text-block {
    padding: 35px 0px 35px 0px;
  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url .text-block span.count {
    {% if settings.other_custom_font_handle_enable %}
    font-family: '{{ settings.other_custom_font_handle }}', sans-serif;
    {% endif %}
    color: var(--font-color-primary);
    font-size: 25px;
    font-style: italic;
    display: block;
    font-weight: var(--font-custom-weight-header);
    line-height: 1;
  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url .text-block span.cat-title {
    margin-top: 6px;
    font-weight: var(--font-weight-subtitle);
    text-transform: uppercase;
  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url .cat-img{

  }
  .slider-category2 .cat-item-wrap .cat-block a.cat-url .cat-img svg {
    width: 100%;
  }

  /*slider arrow*/
  .slider-category2 .cat-main-wrap {
    position: relative;
  }
  .slider-category2 .cat-main-wrap .slider-arrow button {
    position: absolute;
    bottom: 50%;
    transform: translateY(50%);
  }
  .slider-category2 .cat-main-wrap .slider-arrow button.swiper-prev {
    left: -8.33%;
  }
  .slider-category2 .cat-main-wrap .slider-arrow button.swiper-next {
    right: -8.33%;
  }
  @media (max-width: 1499px) {
    .slider-category2 .cat-main-wrap .slider-arrow button.swiper-prev {
      left: -50px;
    }
    .slider-category2 .cat-main-wrap .slider-arrow button.swiper-next {
      right: -50px;
    }
  }
  @media (max-width: 1499px) {
    .slider-category2 .cat-main-wrap .slider-arrow {
      display: none;
    }
  }
</style>
