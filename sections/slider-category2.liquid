<section class="slider-category2">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        {% if section.settings.section_title != '' or section.settings.section_subtitle != '' %}
        <div class="section-capture">
          <div class="section-title">
            {% if section.settings.section_subtitle != '' %}
            <span data-fade-in class="sub-title fade-in">{{ section.settings.section_subtitle }}</span>
            {% endif %}
            {% if section.settings.section_title != '' %}
            <h2 data-fade-in>{{ section.settings.section_title }}</h2>
            {% endif %}
          </div>
        </div>
        {% endif %}
        <div class="cat-main-wrap">
          <div class="cat-slider swiper" id="cat-{{ section.id }}">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
              {% case block.type %}
              {% when 'slider_cat' %}
              {% assign category_product = collections[block.settings.slider_category_handle] %}
              <div class="swiper-slide ">
                <div class="cat-item-wrap">
                  <div class="cat-block">
                    <a href="{{ category_product.url }}" class="cat-url">
                      <div class="text-block">
                        {%- if section.settings.item_title_enable -%}
                        <span class="count">{{ category_product.products_count }} {{ section.settings.item_title }}</span>
                        {%- endif -%}
                        <span class="cat-title">{{ category_product.title }}</span>
                      </div>
                      <div class="cat-img">
                        {% comment %}
                        <img src="https://dummyimage.com/175x180/e2e2e2/999999" class="img-fluid" alt="image">
                        {% endcomment %}
                        {%- if block.settings.cat_img -%}
                        {{
                        block.settings.cat_img
                        | image_url: width: 650
                        | image_tag:
                          loading: 'lazy',
                          width: block.settings.cat_img.width,
                          height: block.settings.cat_img.height,
                          class: 'img-fluid lazyload',
                          alt: block.settings.cat_img.alt
                        | escape
                        }}
                        {%- else -%}
                        {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                        {%- endif -%}
                      </div>
                    </a>
                  </div>
                </div>
              </div>
              {% endcase %}
              {% endfor %}
            </div>
          </div>
          <div class="slider-arrow">
            <button class="swiper-prev swiper-prev-{{ section.id }}"><i class="feather-arrow-left"></i></button>
            <button class="swiper-next swiper-next-{{ section.id }}"><i class="feather-arrow-right"></i></button>
          </div>
          <div class="swiper-dots">
            <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#cat-{{ section.id }}', {
      slidesPerView: {{ section.settings.slide_view }},
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      spaceBetween: 30,
      loop: true,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {%- if settings.enable_rtl -%}
      rtl: true,
      {%- endif -%}
      navigation: {
        nextEl: '.swiper-next-{{ section.id }}',
        prevEl: '.swiper-prev-{{ section.id }}',
      },
      pagination: {
        el: ".swiper-pagination-{{ section.id }}",
        clickable: true
      },
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: 1000,
      breakpoints: {
        0: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        320: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        360: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        540: {
          slidesPerView: 2,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        640: {
          slidesPerView: 3,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        768: {
          slidesPerView: 3,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1024: {
          slidesPerView: 3,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1199: {
          slidesPerView: 4,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1399: {
          slidesPerView: {{ section.settings.slide_view }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        },
        1499: {
          slidesPerView: {{ section.settings.slide_view }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30
        }
      }
    });
  });
</script>
