<section class="testimonial">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="section-capture">
          <div class="section-title">
            {% if section.settings.section_sub_title != '' %}
            <span class="sub-title">{{ section.settings.section_sub_title }}</span>
            {% endif %}
            {% if section.settings.section_title != '' %}
            <h2>{{ section.settings.section_title }}</h2>
            {% endif %}
          </div>
        </div>
        <div class="testimonial-main">
          <div class="testimonial-slider swiper" id="testi-slider-{{ section.id }}">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
              <div class="swiper-slide">
                <div class="testimonial-item">
                  <div class="testimonial-desc">
                    <span class="testi-icon">
                      {% comment %}
                      <img src="https://dummyimage.com/50x40/e2e2e2/999999" class="img-fluid" alt="image">
                      {% endcomment %}
                      {%- if block.settings.testimonial_icon_image -%}
                      {{ block.settings.testimonial_icon_image | image_url: width: 1024 | image_tag:
                        loading: 'lazy',
                        width: block.settings.testimonial_icon_image.width,
                        height: block.settings.testimonial_icon_image.height,
                        class: "img-fluid",
                        alt: block.settings.testimonial_icon_image.alt | escape }}
                      {%- else -%}
                      {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </span>
                    {% if block.settings.testimonial_desc != '' %}
                    <p class="description">{{ block.settings.testimonial_desc }}</p>
                    {% endif %}
                  </div>
                  <div class="testimonial-author">
                    <div class="author-image">
                      <span class="image">
                        {% comment %}
                        <img src="https://dummyimage.com/85x85/e2e2e2/999999" class="img-fluid" alt="image">
                        {% endcomment %}
                        {%- if block.settings.testimonial_image -%}
                        {{ block.settings.testimonial_image | image_url: width: 1024 | image_tag:
                          loading: 'lazy',
                          width: block.settings.testimonial_image.width,
                          height: block.settings.testimonial_image.height,
                          class: "img-fluid",
                          alt: block.settings.testimonial_image.alt | escape }}
                        {%- else -%}
                        {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                        {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                        {%- endif -%}
                      </span>
                    </div>
                    <div class="author-content">
                      {% if block.settings.testi_author != '' %}
                      <span class="author-title">{{ block.settings.testi_author }}</span>
                      {% endif %}
                      {% if block.settings.testi_author_bio != '' %}
                      <p class="author-bio">{{ block.settings.testi_author_bio }}</p>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
              {%- endfor -%}
            </div>
          </div>
          {% if section.settings.arrow_enable %}
          <div class="slider-arrow"> 
            <button class="arrow-prev" aria-label="Slider arrow"><i class="feather-arrow-left"></i></button>
            <button class="arrow-next" aria-label="Slider arrow"><i class="feather-arrow-right"></i></button>
          </div>
          {% endif %}
        </div>
        {% if section.settings.section_button_enable %}
        <div class="testi-section-btn">
          <a
            data-fade-in
            href="{{ section.settings.section_button_text_url }}"
            class="{% if section.settings.section_button_style == 'btn-style1' %}btn-style{% elsif section.settings.section_button_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}"
          >
            {{- section.settings.section_button_text -}}
          </a>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<script>
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#testi-slider-{{ section.id }}', {
      slidesPerView: {{ section.settings.product_view }},
      loop: true,
      grid: {
        rows: 1,
        fill: 'row' | 'column',
      },
      spaceBetween: 0,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {% if section.settings.slider_autoplay_enable %}
      autoplay: {
        delay: {{ section.settings.slider_autoplay_timeout }},
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: {{ section.settings.slider_autoplay_speed }},
      {% endif %}
      {% if section.settings.arrow_enable %}
      navigation: {
        nextEl: ".arrow-next",
        prevEl: ".arrow-prev",
      },
      {% endif %}
      breakpoints: {
        0: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        320: {
          slidesPerView: 1,
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        360: {
          slidesPerView: {{ section.settings.product_view_sm }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        540: {
          slidesPerView: {{ section.settings.product_view_sm }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        640: {
          slidesPerView: {{ section.settings.product_view_sm }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        768: {
          slidesPerView: {{ section.settings.product_view_sm }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1024: {
          slidesPerView: {{ section.settings.product_view_lg }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1199: {
          slidesPerView: {{ section.settings.product_view }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1499: {
          slidesPerView: {{ section.settings.product_view }},
          grid: {
            rows: 1,
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        }
      }
    });
  });
</script>
