<style>
.testimonial {
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
  {% if section.settings.section_bgcolor_enable %}
  background-color: {{ section.settings.section_bgcolor }};
  {% endif %}
  {% if section.settings.border_enable %}
  border-top: {{ section.settings.border }}px solid {{ section.settings.border_color | color_modify: 'alpha', section.settings.border_color_opacity }};
  {% endif %}
}
@media (max-width: 1199px) {
  .testimonial {
    padding-top: {{ section.settings.section_padding_top_ipad }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_ipad }}px;
  }
}
@media (max-width: 767px) {
  .testimonial {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}
.testimonial .section-title h2{
  margin-top: 0;
}
/* testimonial css */
.testimonial .testimonial-main {
  position: relative;
}
.testimonial .testimonial-main .testimonial-slider {
  width: 83.33%;
  margin: 0 auto;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc {
  position: relative;
  padding: 42px 50px 40px 50px;
  margin-top: 20px;
  border-radius: var(--sti-border-radius);
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc::after {
  background-color: #FFFFFF;
  content: '';
  position: absolute;
  top: 0px;
  inset-inline-end: 0px;
  bottom: 0px;
  inset-inline-start: 0px;
  z-index: -1;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc::before {
  content: '';
  position: absolute;
  bottom: -60px;
  inset-inline-start: 47px;
  border-top: 30px solid #FFFFFF;
  border-right: 25px solid transparent;
  border-bottom: 30px solid transparent;
  border-left: 25px solid transparent;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc span.testi-icon {
  position: absolute;
  top: -20px;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc p.description {
  font-weight: var(--font-custom-weight-body);
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author {
  margin-top: 60px;
  margin-inline-start: 30px;
  display: flex;
  align-items: center;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author .author-image span.image {
  width: 85px;
  overflow: hidden;
  display: block;
  border-radius: 100%;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author .author-image span.image svg {
  width: 100%;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author .author-content {
  padding-inline-start: 20px;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author .author-content span.author-title {
  font-weight: var(--font-weight-subtitle);
  text-transform: uppercase;
}
.testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author .author-content p.author-bio {
  margin-top: 9px;
  line-height: 1;
}
@media (max-width: 1199px) {
  .testimonial .testimonial-main .testimonial-slider {
    width: 100%;
  }
}
@media (max-width: 767px) {
  .testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc::before {
    inset-inline-start: 29px;
  }
  .testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-desc {
    padding: 30px 12px;
  }
  .testimonial .testimonial-main .testimonial-slider .testimonial-item .testimonial-author {
    margin-inline-start: 12px;
  }
}

/* section button css */
{% if section.settings.section_button_enable %}
.testimonial .testi-section-btn {
  margin-top: {{ settings.title_padding_bottom }}px;
  text-align: {{ section.settings.section_button_alignment }};
}
@media (max-width: 1199px) {
  .testimonial .testi-section-btn {
    margin-top: {{ settings.title_padding_bottom }}px;
  }
}
@media (max-width: 767px) {
  .testimonial .testi-section-btn {
    margin-top: {{ settings.title_padding_bottom_xs }}px;
  }
}
{% endif %}

/* slider button css */
.testimonial .slider-arrow button {
  position: absolute;
  bottom: 50%;
  transform: translateY(50%);
  z-index: 1;
}
.testimonial .slider-arrow button.arrow-prev {
  inset-inline-start: -60px;
}
.testimonial .slider-arrow button.arrow-next {
  inset-inline-end: -60px;
}
@media (max-width: 1499px) {
  .testimonial .slider-arrow button.arrow-prev {
    inset-inline-start: -30px;
  }
  .testimonial .slider-arrow button.arrow-next {
    inset-inline-end: -30px;
  }
}
@media (max-width: 1199px) {
  .testimonial .slider-arrow {
    margin-top: 40px;
  }
  .testimonial .slider-arrow button {
    position: unset;
    transform: unset;
    margin-inline-start: 15px;
  }
  .testimonial .slider-arrow button:first-child {
    margin-inline-start: 0px;
  }
} 
@media (max-width: 767px) {
  .testimonial .slider-arrow {
    margin-top: 30px;
  }
}
</style>