<section class="about-section3" {% if section.settings.testi_bgimg_enable %}style="background-image: url('{% if section.settings.testi_bgimg %}{{ section.settings.testi_bgimg | image_url: 'master' }}{% else %}https://dummyimage.com/1920x710/f7f7f7/999999{% endif %}');"{% endif %}>
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        {% if section.settings.testi_title != '' %}
        <div class="section-capture">
          <div class="section-title" data-fade-in>
            {% if section.settings.testi_title != '' %}
            <h2>{{ section.settings.testi_title }}</h2>
            {% endif %}
            </div>
            {% if section.settings.testi_desc != '' %}
            <p>{{ section.settings.testi_desc }}</p>
            {% endif %}
          </div>
        </div>
        {% endif %}
        <div class="about-slider owl-carousel" id="about-slider-{{ section.id }}">
          {% for block in section.blocks %}
          <div class="item">
            <div class="testi-content">
              <div class="testi-img-avtar">
                {% if block.settings.testi_img_enable %}
                <span class="testi-img">
                  {%- if block.settings.testi_img -%}
                  {{ block.settings.testi_img | image_url: width: 90 | image_tag:
                  loading: 'lazy',
                  width: block.settings.testi_img.width,
                  height: block.settings.testi_img.height,
                  class: "img-fluid lazyload",
                  alt: block.settings.testi_img.alt | escape }}
                  {%- else -%}
                  {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                  {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                  {%- endif -%}
                </span>
                {% endif %}
                <span class="testi-det">{{ block.settings.testi_infotitle }}</span>
              </div>
              <div class="testi-desc">
                <p>{{ block.settings.testi_review_content }}</p>
                <span class="testi-name">{{ block.settings.testi_authrtitle }}</span>
              </div>
            </div>
          </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>
<script type="text/javascript">
addEventListener('DOMContentLoaded', (event) => {
  $('#about-slider-{{ section.id }}').owlCarousel({
    loop: false,
    rewind: true,
    items: 1,
    center: true,
    loop: true,
    margin: 30,
    nav: true,
    navText: ['<i class="feather-arrow-left"></i>','<i class="feather-arrow-right"></i>'],
    dots: false,
    {%- if settings.enable_rtl -%}
    rtl: true,
    {%- endif -%}
    responsive: {
      0: {
        items: 1,
        margin: 12,
        dots: true,
        nav: false
      },
      479: {
        items: 1,
        margin: 12,
        dots: true,
        nav: false
      },
      540: {
        items: 1,
        margin: 12,
        dots: true,
        nav: false
      },
      640: {
        items: 1,
        margin: 12,
        dots: true,
        nav: false
      },
      768: {
        items: 1,
        dots: true,
        nav: false
      },
      979: {
        items: 1
      },
      1199: {
        items: 1
      }
    }
  });
});
</script>
