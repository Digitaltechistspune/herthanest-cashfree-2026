<style>
.about-section3 {
  position: relative;
  padding-top: {{ section.settings.testi_padding_top }}px;
  padding-bottom: {{ section.settings.testi_padding_bottom }}px;
}
.about-section3::after {
  content: "";
  position: absolute;
  top: calc(0% - -50px);
  left: 0;
  right: 0;
  width: 100%;
  height: calc(100% - 50px);
  {% if section.settings.testi_bgcolor_enable %}
  background-color: {{ section.settings.testi_bgcolor }};
  {% endif %}
}
@media (max-width: 1199px) {
  .about-section3 {
    padding-top: {{ section.settings.testi_padding_top_ip }}px;
    padding-bottom: {{ section.settings.testi_padding_bottom_ip }}px;
  }
}
@media (max-width: 767px) {
  .about-section3 {
    padding-top: {{ section.settings.testi_padding_top_xs }}px;
    padding-bottom: {{ section.settings.testi_padding_bottom_xs }}px;
  }
}

/* testi content css */
.about-section3 .owl-item .item {
  transform: scale(0.9);
  opacity: 0.7;
  -webkit-transition: all .3s ease-in-out 0s;
  -o-transition: all .3s ease-in-out 0s;
  transition: all .3s ease-in-out 0s;
}
.about-section3 .owl-item.center .item {
  transform: scale(1);
  opacity: 1;
}
.about-section3 .testi-content {
  text-align: center;
  max-width: 41.67%;
  margin: 0 auto;
}
.about-section3 .testi-content .testi-desc {
  margin-top: 30px;
}
.about-section3 .testi-content .testi-desc p {
  font-size: 26px;
  line-height: 40px;
}
.about-section3 .testi-content .testi-desc span {
  position: relative;
  font-size: var(--font-size-subtitle);
  display: block;
  margin-top: 30px;
  color: var(--font-color-header);
  font-weight: var(--font-weight-subtitle);
  text-transform: uppercase;
}
.about-section3 .testi-content .testi-img-avtar .testi-img {
  height: 110px;
  width: 110px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100%;
  margin: 0 auto 30px auto;
  overflow: hidden;
  border: 10px solid #fff;
}
.about-section3 .testi-content .testi-img-avtar .testi-det {
  font-size: 16px;
  text-transform: uppercase;
  color: var(--font-color-header);
}
@media (max-width: 1199px) {
  .about-section3 .testi-content {
    max-width: 58.33%;
  }
  .about-section3 .testi-content .testi-desc p {
    font-size: 18px;
    line-height: 30px;
  }
  .about-section3 .testi-content .testi-desc {
    margin-top: 20px;
  }
  .about-section3 .testi-content .testi-desc span {
    margin-top: 20px;
  }
}
@media (max-width: 991px) {
  .about-section3 .testi-content {
    max-width: 100%;
  }
}

/* slider arrow css */

.about-section3 .about-slider .owl-nav {
  margin-top: 0px;
  line-height: 0;
}
.about-section3 .about-slider .owl-nav button {
  color: var(--font-color-header);
  font-size: 20px;
  position: absolute;
  bottom: 50%;
  transform: translateY(50%);
  margin: 0px;
  border-radius: 50%;
  height: 60px;
  width: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--theme-border-color);
}
.about-section3 .about-slider .owl-nav button.owl-prev {
  left: 0;
}
.about-section3 .about-slider .owl-nav button.owl-next {
  right: 0;
}
.about-section3 .about-slider .owl-nav button:hover {
  color: #fff;
  background-color: var(--font-color-primary);
}
@media (max-width: 1199px) {
  .about-section3 .about-slider .owl-nav button {
    height: 50px;
    width: 50px;
  }
}
@media (max-width: 767px) {
  .about-section3 .about-slider .owl-nav button {
    height: 40px;
    width: 40px;
  }
}

/* slider dot css */
.about-section3 .about-slider .owl-dots {
  margin-top: 30px;
  line-height: 0;
  text-align: center;
}
.about-section3 .about-slider .owl-dots button {
  {% if settings.enable_rtl %}
  margin-left: 5px;
  {% else %}
  margin-right: 5px;
  {% endif %}
}
.about-section3 .about-slider .owl-dots button:last-child {
  {% if settings.enable_rtl %}
  margin-left: 0px;
  {% else %}
  margin-right: 0px;
  {% endif %}
}
.about-section3 .about-slider .owl-dots button span {
  width: 10px;
  height: 10px;
  margin: 0;
  background-color: transparent;
  {% if section.settings.testi_bgimg_enable %}
  border: 1px solid #FFFFFF;
  {% else %}
  border: 1px solid var(--font-color-header);
  {% endif %}
  border-radius: 100%;
}
.about-section3 .about-slider .owl-dots button.active span,
.about-section3 .about-slider .owl-dots button:hover span {
  {% if section.settings.testi_bgimg_enable %}
  background-color: #FFFFFF;
  border: 1px solid #FFFFFF;
  {% else %}
  background-color: var(--font-color-header);
  border: 1px solid var(--font-color-header);
  {% endif %}
}
</style>