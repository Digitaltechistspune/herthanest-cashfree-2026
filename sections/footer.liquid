<style>
:root {
  --footer-menu-title-font-size: {{ section.settings.menu_title_font_size }}px;
  --footer-menu-title-font-size-lg: {{ section.settings.menu_title_font_size_lg }}px;
  --footer-menu-title-font-weight: {{ section.settings.menu_title_font_weight }};
  --footer-menu-title-text-transform: {{ section.settings.menu_title_text_transform }};
  --footer-menu-title-color: {{ section.settings.menu_title_color }};
  --footer-menu-text-font-size: {{ section.settings.menu_text_font_size }}px;
  --footer-menu-text-font-size-lg: {{ section.settings.menu_text_font_size_lg }}px;
  --footer-menu-text-font-weight: {{ section.settings.menu_text_font_weight }};
  --footer-menu-text-transform: {{ section.settings.menu_text_text_transform }};
  --footer-menu-text-color: {{ section.settings.menu_text_color }};
  --footer-menu-text-hover-color: {{ section.settings.menu_text_hv_color }};
}
.footer{
  padding-top: {{ section.settings.foot_padding_top }}px;
  padding-bottom: {{ section.settings.foot_padding_bottom }}px;
  position: relative;
  {% if section.settings.footer_bg_img_enable %}
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  {% endif %}
  background: {{ section.settings.footer_bg_color }};
  {% if section.settings.border_enable %}
  {% if template == 'collection' or template == 'collection.list' or template == 'collection.list-right' or template == 'collection.list-without' or template == 'collection.right' or template == 'collection.without' or template == 'page.wishlist' or template == 'product' or template == 'product.template2' or template == 'product.template3' or template == 'product.template4' or template == 'product.template5' %}
  border-top: {{ section.settings.border }}px solid {{ section.settings.border_color | color_modify: 'alpha', section.settings.border_color_opacity }};
  {% endif %}
  {% endif %}
}
@media (max-width: 1199px){
  .footer{
    padding-top: {{ section.settings.foot_padding_top_ipad }}px;
    padding-bottom: {{ section.settings.foot_padding_bottom_ipad }}px;
  }
}
@media (max-width: 767px){
  .footer{
    padding-top: {{ section.settings.foot_padding_top_xs }}px;
    padding-bottom: {{ section.settings.foot_padding_bottom_xs }}px;
  }
}
/*footer top*/
.footer .footer-top-area {
  padding-bottom: {{ section.settings.foot_padding_top }}px;
  margin-bottom: {{ section.settings.foot_padding_top }}px;
  border-bottom: 1px solid var(--theme-border-color);
}
.footer .footer-top-area ul.top-wrap {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: -50px;
  margin-inline-start: -30px;
}
.footer .footer-top-area ul.top-wrap li.top-wrapper {
  margin-top: 50px;
  margin-inline-start: 30px;
}
.footer .footer-top-area ul.top-wrap li.top-wrapper.service {
  width: calc(25% - 30px);
}  
.footer .footer-top-area ul.top-wrap li.top-wrapper.f-newsletter {
  width: calc(50% - 30px);
} 
@media (max-width: 1199px) {
  .footer .footer-top-area{
    padding-bottom: {{ section.settings.foot_padding_top_ipad }}px;
    margin-bottom: {{ section.settings.foot_padding_top_ipad }}px;
  }
  .footer .footer-top-area ul.top-wrap {
    margin-top: -40px;
  }
  .footer .footer-top-area ul.top-wrap li.top-wrapper {
    margin-top: 40px;
  }
  .footer .footer-top-area ul.top-wrap li.top-wrapper.service {
    width: calc(50% - 30px);
  }  
  .footer .footer-top-area ul.top-wrap li.top-wrapper.f-newsletter {
    width: calc(100% - 30px);
    order: -1;
  } 
}
@media(max-width: 767px){
  .footer .footer-top-area{
    padding-bottom: {{ section.settings.foot_padding_top_xs }}px;
    margin-bottom: {{ section.settings.foot_padding_top_xs }}px;
  }
  .footer .footer-top-area ul.top-wrap {
    margin-top: -30px;
    margin-inline-start: -12px;
  }
  .footer .footer-top-area ul.top-wrap li.top-wrapper {
    margin-top: 30px;
    margin-inline-start: 12px;
  }
  .footer .footer-top-area ul.top-wrap li.top-wrapper.service {
    width: calc(50% - 12px);
  }  
  .footer .footer-top-area ul.top-wrap li.top-wrapper.f-newsletter {
    width: calc(100% - 12px);
    order: -1;
  } 
}
@media(max-width: 479px){
  .footer .footer-top-area ul.top-wrap li.top-wrapper.service {
