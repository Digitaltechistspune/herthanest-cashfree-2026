<section class="footer" {% if section.settings.footer_bg_img_enable %}style="background-image: url('{% if section.settings.footer_bg_img %}{{ section.settings.footer_bg_img | image_url }}{% else %}https://dummyimage.com/1920x450/f7f7f7/999999{% endif %}');"{% endif %}>
  {% if section.settings.footer_top_enable %}
  <div class="footer-top-area">
    <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
      <div class="row">
        <div class="col">
          <div class="footer-top-block">
            <ul class="top-wrap">
              <li data-fade-in class="top-wrapper service">
                <div class="footer-ser-main">
                  {% if section.settings.service_1_icon != '' %}
                  <div class="ser-icon">
                    <span class="icon"><i class="{{ section.settings.service_1_icon }}"></i></span>
                  </div>
                  {% endif %}
                  <div class="ser-content">
                    {% if section.settings.service_1_title != '' %}
                    <h4 class="title">{{ section.settings.service_1_title }}</h4>
                    {% endif %}
                    {% if section.settings.service_1_desc != '' %}
                    <p class="desc">{{ section.settings.service_1_desc }}</p>
                    {% endif %}
                  </div>
                </div>
              </li>
              <li data-fade-in class="top-wrapper f-newsletter">
                <div class="f-news-main">
                  <div class="section-capture">
                    <div class="section-title">
                      {% if section.settings.news_subtitle != '' %}
                      <span class="sub-title">{{ section.settings.news_subtitle }}</span>
                      {% endif %}
                      {% if section.settings.news_title != '' %}
                      <h2 data-fade-in class="fade-in">{{ section.settings.news_title }}</h2>
                      {% endif %}
                    </div>
                  </div>
                  <div class="news-content">
                    {% form 'customer' %}
                    {{ form.errors | default_errors }}
                    {% if form.posted_successfully? %}
                    <p class="text-success">
                      <span>{{ 'general.newsletter_form.confirmation' | t }}</span>
                    </p>
                    {% endif %}
                    <div class="news-wrap">
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <input type="email" name="contact[email]" class="email mail" id="E-mail" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}" autocapitalize="off" required>
                      <button type="submit" name="commit" id="Subscribe" class="btn-style">{{ 'general.newsletter_form.submit' | t }}</button>
                    </div>
                    {% endform %}
                  </div>
                </div>
              </li>
              <li data-fade-in class="top-wrapper service">
                <div class="footer-ser-main">
                  {% if section.settings.service_2_icon != '' %}
                  <div class="ser-icon">
                    <span class="icon"><i class="{{ section.settings.service_2_icon }}"></i></span>
                  </div>
                  {% endif %}
                  <div class="ser-content">
                    {% if section.settings.service_2_title != '' %}
                    <h4 class="title">{{ section.settings.service_2_title }}</h4>
                    {% endif %}
                    {% if section.settings.service_2_desc != '' %}
                    <p class="desc">{{ section.settings.service_2_desc }}</p>
                    {% endif %}
                  </div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="footer-list-wrap">
          <ul class="footer-list">
            {% for block in section.blocks %}
            {%- case block.type -%}
            {%- when 'logo_info' -%}
            <li class="ftlink-li logo-info width-{{ block.id }}" data-fade-in>
              <div class="footer-info">
                {% if block.settings.logo_enable %}
                {%- render 'company-logo-footer' -%}
                {% endif %}
                {% if block.settings.logo_desc != '' %}
                <div class="logo-desc">
                  <p class="desc">{{ block.settings.logo_desc }}</p>
                </div>
                {% endif %}
                <div class="custom-info">
                  {% if block.settings.custom_info_icon != '' %}
                  <div class="info-icon">
                    <span class="icon"><i class="{{ block.settings.custom_info_icon }}"></i></span>
                  </div>
                  {% endif %}
                  <div class="info-content">
                    {% if block.settings.custom_info_label != '' %}
                    <span class="label">{{ block.settings.custom_info_label }}</span>
                    {% endif %}
                    {% if block.settings.custom_info_text != '' %}
                    <div class="text">{{ block.settings.custom_info_text }}</div>
                    {% endif %}
                  </div>
                </div>
                {% if block.settings.social_enable %}
                {%- render 'social-media' -%}
                {% endif %}
              </div>      
            </li>
            {%- when 'footer_menu' -%}
            <li class="ftlink-li link-list width-{{ block.id }}" data-fade-in>
              {% assign footer_menu = block.settings.footer_menu_handle %}
              {%- if block.settings.show_nav_title -%}
              <h2 class="ft-title">{{ linklists[footer_menu].title }}</h2>
              {%- endif -%}
              <a data-bs-toggle="collapse" href="#collapse-{{ linklists[footer_menu].title | handleize }}" class="ft-title">
                <span>{{ linklists[footer_menu].title }}</span>
                <i class="feather-plus"></i>
              </a>
              <ul class="{% if block.settings.show_nav_title %}collapse {% endif %} footer-sublist link" id="{%- if block.settings.show_nav_title -%}collapse-{{ linklists[footer_menu].title | handleize }}{%- endif -%}">
                {% assign footer_menu = block.settings.footer_menu_handle %}
                {% for link in linklists[footer_menu].links %}
                {% if linklists[footer_menu].links != '' %}
                <li class="ftsublink-li">
                  <a href="{{ link.url }}" class="ft-sublink">{{ link.title }}</a>
                </li>
                {% endif %}
                {% endfor %}
              </ul>
            </li>
            {%- when 'custom_menu' -%}
            <li class="ftlink-li link-list" data-fade-in>
              {%- if block.settings.nav_title != '' -%}
              <h2 class="ft-title">{{ block.settings.nav_title }}</h2>
              <a data-bs-toggle="collapse" href="#collapse-{{ block.settings.nav_title | handleize }}" class="ft-title">
                <span>{{ block.settings.nav_title }}</span>
                <i class="feather-plus"></i>
              </a>
              {%- endif -%}
              <ul class="collapse footer-sublist link" id="collapse-{{ block.settings.nav_title | handleize }}">
                {%- if block.settings.link_title1 != '' -%}
                <li class="ftsublink-li">
                  <a href="{{ block.settings.link_url1 }}" class="ft-sublink">{{ block.settings.link_title1 }}</a>
                </li>
                {%- endif -%}
                {%- if block.settings.link_title2 != '' -%}
                <li class="ftsublink-li">
                  <a href="{{ block.settings.link_url2 }}" class="ft-sublink">{{ block.settings.link_title2 }}</a>
                </li>
                {%- endif -%}
                {%- if block.settings.link_title3 != '' -%}
                <li class="ftsublink-li">
                  <span class="ft-sublink ft-sublink-bold">{{ block.settings.link_title3 }}</span>
                </li>
                {%- endif -%}
                {%- if block.settings.link_title4 != '' -%}
                <li class="ftsublink-li">
                  <span class="ft-sublink">{{ block.settings.link_title4 }}</span>
                </li>
                {%- endif -%}
                {%- if block.settings.link_title5 != '' -%}
                <li class="ftsublink-li">
                  <span class="ft-sublink">{{ block.settings.link_title5 }}</span>
                </li>
                {%- endif -%}
              </ul>
            </li>
            {%- endcase -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

