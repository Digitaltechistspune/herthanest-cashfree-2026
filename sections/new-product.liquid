<style>
  .new-product {
    position: relative;
    overflow: hidden;
  }
  .collection-category-{{ section.id }} {
    padding-top: {{ section.settings.category_special_padding_top }}px;
    padding-bottom: {{ section.settings.category_special_padding_bottom }}px;
    {% if section.settings.section_bgcolor_enable %}
    background-color: {{ section.settings.section_bgcolor }};
    {% endif %}
    {% if section.settings.border_enable %}
    border-top: {{ section.settings.border }}px solid {{ section.settings.border_color | color_modify: 'alpha', section.settings.border_color_opacity }};
    {% endif %}
  }
  @media (max-width: 1199px) {
    .collection-category-{{ section.id }} {
      padding-top: {{ section.settings.category_special_padding_top_ip }}px;
      padding-bottom: {{ section.settings.category_special_padding_bottom_ip }}px;
    }
  }
  @media (max-width: 767px) {
    .collection-category-{{ section.id }} {
      padding-top: {{ section.settings.category_special_padding_top_xs }}px;
      padding-bottom: {{ section.settings.category_special_padding_bottom_xs }}px;
    }
  }

  .new-product .section-capture.deal-counter {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .new-product .section-capture.deal-counter h2 {
    color: var(--font-color-primary);
  }
  .new-product ul.contdown_row {
    display: flex;
    align-items: center;
  }
  .new-product ul.contdown_row li.countdown_section {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    width: 80px;
    height: 75px;
    border: var(--sti-border);
    border-radius: var(--sti-border-radius);
    {% if settings.enable_rtl %}
    margin-left: 15px;
    {% else %}
    margin-right: 15px;
    {% endif %}
  }
  .new-product ul.contdown_row li.countdown_section:last-child:after {
    display: none;
  }
  .new-product ul.contdown_row li.countdown_section:last-child {
    {% if settings.enable_rtl %}
    margin-left: 0px;
    padding-left: 0px;
    {% else %}
    margin-right: 0px;
    padding-right: 0px;
    {% endif %}
  }
  .new-product ul.contdown_row li.countdown_section .countdown_timer {
    color: var(--font-color-secondary);
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
  }
  .new-product ul.contdown_row li.countdown_section .countdown_title {
    color: var(--font-color-body);
    font-size: 14px;
    line-height: 1;
    font-weight: 700;
    margin-top: 8px;
    text-transform: uppercase;
  }
  @media(max-width: 479px){
    .new-product ul.contdown_row li.countdown_section .countdown_timer {
      font-size: 22px;
    }
  }

  {% if section.settings.category_special_button_enable %}
  .collection-category .collection-wrap .collection-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: {{ settings.title_padding_bottom }}px;
  }
  .collection-category .collection-wrap .collection-button .offer-text {
    display: flex;
    align-items: center;
  }
  .collection-category .collection-wrap .collection-button .offer-text p {
    font-size: 16px;
    color: var(--font-color-header);
    text-transform: uppercase;
    font-weight: 700;
  }
  .collection-category .collection-wrap .collection-button .offer-text span {
    font-size: 14px;
    color: #fff;
    padding: 10px 15px;
    font-weight: 500;
    line-height: 1;
    margin-left: 15px;
    background-color: var(--font-color-header);
    border-radius: var(--sti-border-radius);
    text-transform: uppercase;
  }
  @media (max-width: 1199px) {
    .collection-category .collection-wrap .collection-button {
      flex-direction: column;
      margin-top: {{ settings.title_padding_bottom }}px;
    }
    .collection-category .collection-wrap .collection-button .offer-text {
      margin-bottom: 30px;
    }
  }
  @media (max-width: 767px) {
    .collection-category .collection-wrap .collection-button {
      margin-top: {{ settings.title_padding_bottom_xs }}px;
    }
    .collection-category .collection-wrap .collection-button .offer-text p {
      font-size: var(--font-size-body);
    }
  }
  {% endif %}

  /* slider dot css */
  .collection-category-{{ section.id }} .collection-wrap .swiper-buttons{
    display: none;
  }
  .collection-category-{{ section.id }} .collection-wrap .swiper-dots {
    display: none;
    margin-top: 100px;
    line-height: 0;
  }
  .collection-category-{{ section.id }} .collection-wrap .swiper-dots .swiper-pagination.swiper-pagination-bullets {
    width: unset;
    position: unset;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    {% if settings.enable_rtl %}
    margin: -5px -5px 0px 0px;
    {% else %}
    margin: -5px 0px 0px -5px;
    {% endif %}
  }
  .collection-category-{{ section.id }} .collection-wrap .swiper-dots .swiper-pagination.swiper-pagination-bullets span {
    width: 10px;
    height: 10px;
    {% if settings.enable_rtl %}
    margin: 5px 5px 0px 0px;
    {% else %}
    margin: 5px 0px 0px 5px;
    {% endif %}
    background-color: transparent;
    border: 1px solid var(--font-color-header);
    border-radius: 100%;
    opacity: 1;
  }
  .collection-category-{{ section.id }} .collection-wrap .swiper-dots .swiper-pagination.swiper-pagination-bullets span.swiper-pagination-bullet-active {
    background-color: var(--font-color-header);
    border: 1px solid var(--font-color-header);
  }
  @media (max-width: 1199px) {
    .collection-category-{{ section.id }} .collection-wrap .swiper-dots {
      margin-top: 80px;
    }
  }
  @media (max-width: 1199px) {
    .new-product .section-capture.deal-counter {
      flex-direction: column;
    }
    .new-product .section-capture.deal-counter .deal-content-timer {
      margin-top: 30px;
    }
  }
  @media (max-width: 767px) {
    .collection-category-{{ section.id }} .collection-wrap .swiper-dots {
      margin-top: 60px;
    }
  }
  @media (max-width: 479px) {
    .new-product ul.contdown_row li.countdown_section {
      width: 60px;
      height: 60px;
    }
  }
</style>
