<section class="new-product collection-category-{{ section.id }}">
  <div class="{% if section.settings.container == 'fluid' %}container-fluid {% else %}container{% endif %}">
    <div class="row">
      <div class="col">
        <div class="collection-category">
          <div class="section-capture {% if section.settings.countdown_enable %} deal-counter {% endif %}">
            <div class="section-title">
              {% if section.settings.section_sub_title != '' %}
                <span data-fade-in class="sub-title">{{ section.settings.section_sub_title }}</span>
              {% endif %}
              {% if section.settings.section_title != '' %}
                <h2 data-fade-in>{{ section.settings.section_title }}</h2>
              {% endif %}
            </div>
            {% if section.settings.countdown_enable %}
              <div class="deal-content-timer">
                {% if section.settings.countdown_enable %}
                  <ul data-fade-in class="contdown_row">
                    <li class="countdown_section">
                      <span id="days-{{ section.id }}" class="countdown_timer"></span>
                      <span class="countdown_title">{{ settings.day_title }}</span>
                    </li>
                    <li class="countdown_section">
                      <span id="hours-{{ section.id }}" class="countdown_timer"></span>
                      <span class="countdown_title">{{ settings.hour_title }}</span>
                    </li>
                    <li class="countdown_section">
                      <span id="minutes-{{ section.id }}" class="countdown_timer"></span>
                      <span class="countdown_title">{{ settings.minute_title }}</span>
                    </li>
                    <li class="countdown_section">
                      <span id="seconds-{{ section.id }}" class="countdown_timer"></span>
                      <span class="countdown_title">{{ settings.second_title }}</span>
                    </li>
                  </ul>
                {% endif %}
              </div>
            {% endif %}
          </div>
          <div class="collection-wrap">
            {% assign category_product = collections[section.settings.new_product_label] %}
            <div class="collection-slider swiper" id="pro-{{ section.id }}" data-slides-per-view="{{ section.settings.product_view }}">
              <div class="swiper-wrapper">
                {% assign product_limit = section.settings.category_new_product_limit_handle %}
                {% for product in category_product.products limit: product_limit %}
                  <div class="swiper-slide">
                    {%- liquid
                      if section.settings.category_new_product_view == 'grid'
                        render 'product-grid-item', product: product
                      elsif section.settings.category_new_product_view == 'list'
                        render 'product-grid-list', product: product
                      endif
                    -%}
                  </div>
                {% else %}
                  {% for i in (1..product_limit) %}
                    <div class="swiper-slide">
                      {% if section.settings.category_new_product_view == 'list' %}
                        <div class="product-grid-list">
                      {% endif %}
                      <div class="single-product-wrap">
                        <div class="product-image">
                          {%- capture placeholder -%}product-apparel-{% cycle 1, 2, 3 %}{%- endcapture -%}
                          {{ placeholder | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                        </div>
                        <div class="product-content">
                          <div class="product-title">
                            <h6>
                              <a>{{ 'homepage.sections.product_title' | t }}</a>
                            </h6>
                          </div>
                          <div class="price-box">
                            <span class="new-price">{{ 'homepage.sections.product_price' | t }}</span>
                          </div>
                        </div>
                      </div>
                      {% if section.settings.category_new_product_view == 'list' %}
                        </div>
                      {% endif %}
                    </div>
                  {% endfor %}
                {% endfor %}
              </div>
              {% if section.settings.category_special_button_enable %}
                <div class="collection-button">
                  {% if section.settings.offer_text != '' %}
                    <div data-fade-in class="offer-text">
                      <p>{{ section.settings.offer_text }}</p>
                      <span>{{ section.settings.offer_text_lable }}</span>
                    </div>
                  {% endif %}
                  <a
                    data-fade-in
                    href="{{ category_product.url }}"
                    class="{% if section.settings.category_special_button_style == 'btn-style1' %}btn-style{% elsif section.settings.category_special_button_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}"
                  >
                    {{- section.settings.category_special_button_text -}}
                    <i class="feather-arrow-right"></i>
                  </a>
                </div>
              {% endif %}
            </div>
            <div class="swiper-buttons">
              <button class="swiper-prev swiper-prev-{{ section.id }}"><i class="fa fa-angle-left"></i></button>
              <button class="swiper-next swiper-next-{{ section.id }}"><i class="fa fa-angle-right"></i></button>
            </div>
            <div class="swiper-dots">
              <div class="swiper-pagination swiper-pagination-{{ section.id }}"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script type="text/javascript">
  addEventListener('DOMContentLoaded', (event) => {
    var swiper = new Swiper('#pro-{{ section.id }}', {
      slidesPerView: {{ section.settings.product_view }},
      grid: {
        rows: {{ section.settings.category_special_product_col }},
        fill: 'row' | 'column',
      },
      spaceBetween: 30,
      observer: true,
      observeParents: true,
      watchSlidesProgress: true,
      {%- if settings.enable_rtl -%}
      rtl: true,
      {%- endif -%}
      navigation: {
        nextEl: '.swiper-next-{{ section.id }}',
        prevEl: '.swiper-prev-{{ section.id }}',
      },
      pagination: {
        el: ".swiper-pagination-{{ section.id }}",
        clickable: true
      },
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      speed: 1000,
      breakpoints: {
        0: {
          slidesPerView: 1,
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        320: {
          slidesPerView: 1,
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        360: {
          slidesPerView: {{ section.settings.product_view_sm }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        540: {
          slidesPerView: {{ section.settings.product_view_sm }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        640: {
          slidesPerView: {{ section.settings.product_view_lg }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 12
        },
        768: {
          slidesPerView: {{ section.settings.product_view_lg }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1024: {
          slidesPerView: {{ section.settings.product_view_lg }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1199: {
          slidesPerView: {{ section.settings.product_view }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        },
        1499: {
          slidesPerView: {{ section.settings.product_view }},
          grid: {
            rows: {{ section.settings.category_special_product_col }},
            fill: 'row' | 'column',
          },
          spaceBetween: 30,
        }
      }
    });
   {% if section.settings.countdown_enable %}
    const second = 1000,
    minute = second * 60,
    hour = minute * 60,
    day = hour * 24;
    let countDown = new Date('{{ section.settings.product_mont }} {{ section.settings.product_date }}, {{ section.settings.product_year }} 00:00:00').getTime(),
    x = setInterval(function() {
      let now = new Date().getTime(),
      distance = countDown - now;
      document.getElementById('days-{{ section.id }}').innerText = Math.floor(distance / (day)),
      document.getElementById('hours-{{ section.id }}').innerText = Math.floor((distance % (day)) / (hour)),
      document.getElementById('minutes-{{ section.id }}').innerText = Math.floor((distance % (hour)) / (minute)),
      document.getElementById('seconds-{{ section.id }}').innerText = Math.floor((distance % (minute)) / second);
    }, second)
  {% endif %}
  });
</script>
